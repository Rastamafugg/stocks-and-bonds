re1) {
        lastsig = 0;
        hitcount = 0;
        if (!installed) {
            intercept(sigtrap);
            installed = 1;
        }
        *okout = 1;
        return 0;
    }

    if (*action == 2) {
        *sigout = lastsig;
        *cntout = hitcount;
        *okout = 1;
        return 0;
    }

    if (*action == 3) {
        lastsig = 0;
        hitcount = 0;
        *okout = 1;
        return 0;
    }

    return 0;
}

