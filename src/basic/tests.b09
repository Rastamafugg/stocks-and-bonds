PROCEDURE TSTSCRSET
(* ================================================== *)
(* PROCEDURE: TSTSCRSET                               *)
(* PURPOSE:   Confirmation test for Task 7.2.        *)
(*            Verifies scrSetup output values.       *)
(* EXPECTED INPUT SEQUENCE:                          *)
(*   Player count: 2                                 *)
(*   Player 1 name: ALICE                            *)
(*   Player 1 type: 1 (Human)                        *)
(*   Player 2 name: BOT                              *)
(*   Player 2 type: 2 (Computer)                     *)
(*   Roll mode: 2 (B)                                *)
(* PARAMS:    None                                    *)
(* ================================================== *)
DIM plyrCount:INTEGER
DIM plyrType(6):INTEGER
DIM plyrName(6):STRING[20]
DIM rollMode:INTEGER
DIM i:INTEGER

ON ERROR GOTO 900

PRINT "testScrSu: follow the prompts."
PRINT "Enter: 2 players, ALICE Human, BOT Computer, mode B."
PRINT
RUN waitKey

RUN scrSetup(plyrCount, plyrType, plyrName, rollMode)

PRINT
PRINT "--- Results ---"
PRINT "plyrCount = "; plyrCount; "  (expected 2)"
PRINT

FOR i := 1 TO plyrCount
  PRINT "plyrName("; i; ") = "; plyrName(i)
  PRINT "plyrType("; i; ") = "; plyrType(i)
NEXT i

PRINT
PRINT "rollMode = "; rollMode; "  (expected 2)"
PRINT
PRINT "Expected:"
PRINT "  plyrCount=2"
PRINT "  plyrType(1)=1  plyrName(1)=ALICE"
PRINT "  plyrType(2)=2  plyrName(2)=BOT"
PRINT "  rollMode=2"
PRINT
PRINT "Task 7.2 test complete."
END

900 \ ! Error handler
PRINT "testScrSu error ("; ERR; ")"
END

PROCEDURE TSTSCRCF
(* ================================================== *)
(* PROCEDURE: TSTSCRCF                               *)
(* PURPOSE:   Confirmation test for Task 7.3.        *)
(*            Verifies scrConfirm display and return. *)
(* TEST 1:    Pre-set Task 7.2 values. Press 2.      *)
(*            Verify action = 2 (Back).              *)
(* TEST 2:    Change plyrName(2)/plyrType(2). Press 1*)
(*            Verify action = 1 (Confirm).           *)
(* PARAMS:    None                                    *)
(* ================================================== *)
DIM plyrCount:INTEGER
DIM plyrType(6):INTEGER
DIM plyrName(6):STRING[20]
DIM rollMode:INTEGER
DIM action:INTEGER

ON ERROR GOTO 900

! --- Pre-set Task 7.2 values ---
plyrCount  := 2
plyrName(1) := "ALICE"
plyrType(1) := 1
plyrName(2) := "BOT"
plyrType(2) := 2
rollMode   := 2

! --- Test 1: press 2 (Back) ---
PRINT "testScrCf Test 1:"
PRINT "Verify summary shows ALICE/Human, BOT/Computer, Mode B."
PRINT "Press 2 for Back."
PRINT
RUN scrConfirm(plyrCount, plyrType, plyrName, rollMode, action)
PRINT "action = "; action; "  (expected 2)"
PRINT

! --- Test 2: update player 2, press 1 (Confirm) ---
plyrName(2) := "CAROL"
plyrType(2) := 1

PRINT "testScrCf Test 2:"
PRINT "Verify summary now shows CAROL/Human for player 2."
PRINT "Press 1 for Confirm."
PRINT
RUN scrConfirm(plyrCount, plyrType, plyrName, rollMode, action)
PRINT "action = "; action; "  (expected 1)"
PRINT

PRINT "Task 7.3 test complete."
END

900 \ ! Error handler
PRINT "testScrCf error ("; ERR; ")"
END

PROCEDURE TSTSNBMN
(* ================================================== *)
(* PROCEDURE: TSTSNBMN                               *)
(* PURPOSE:   Confirmation test for Task 7.4.        *)
(*            Three manual test runs of SNBMAIN.     *)
(* TEST 1 (New Game):                                *)
(*   S1 -> press 1                                   *)
(*   S2 -> 2 players, ALICE Human, BOT Computer      *)
(*          Mode B                                   *)
(*   S7 -> press 1 (Confirm)                         *)
(*   Expected output: "STARTING GAME"               *)
(* TEST 2 (Back then Confirm):                       *)
(*   S1 -> press 1                                   *)
(*   S2 -> any valid setup                           *)
(*   S7 -> press 2 (Back)                            *)
(*   S2 -> revise setup                              *)
(*   S7 -> press 1 (Confirm)                         *)
(*   Expected output: "STARTING GAME"               *)
(* TEST 3 (Load, no file present):                   *)
(*   S1 -> press 2                                   *)
(*   Expected: error message from loadGame,          *)
(*             then "Load failed." from SNBMAIN.     *)
(* TEST 4 (Quit):                                    *)
(*   S1 -> press 3                                   *)
(*   Expected: clean exit, no further output.        *)
(* PARAMS:    None                                    *)
(* ================================================== *)
ON ERROR GOTO 900

PRINT "testSNBMN: four test runs."
PRINT

PRINT "Test 1 - New Game (Confirm on first try):"
PRINT "  S1: press 1"
PRINT "  S2: 2 players, ALICE Human, BOT Computer, Mode B"
PRINT "  S7: press 1 to Confirm"
PRINT "  Expected: STARTING GAME"
PRINT
RUN waitKey
RUN SNBMAIN
PRINT

PRINT "Test 2 - New Game (Back then Confirm):"
PRINT "  S1: press 1"
PRINT "  S2: enter any setup"
PRINT "  S7: press 2 (Back)"
PRINT "  S2: revise setup"
PRINT "  S7: press 1 (Confirm)"
PRINT "  Expected: STARTING GAME"
PRINT
RUN waitKey
RUN SNBMAIN
PRINT

PRINT "Test 3 - Load Game (no save file present):"
PRINT "  S1: press 2"
PRINT "  Expected: error from loadGame, then load failed message"
PRINT
RUN waitKey
RUN SNBMAIN
PRINT

PRINT "Test 4 - Quit:"
PRINT "  S1: press 3"
PRINT "  Expected: clean exit, no further output"
PRINT
RUN waitKey
RUN SNBMAIN
PRINT

PRINT "Task 7.4 test complete."
END

900 PRINT "testSNBMN error ("; ERR; ")"
END

PROCEDURE TSTYRHDR
(* ============================================================ *)
(* PROCEDURE : TSTYRHDR                                         *)
(* PURPOSE   : Confirmation tests for scrYearHdr (Task 8.1).   *)
(*             Three visual test cases per spec 8.1:           *)
(*               Test 1 — Year 1: no-dividends + no-sell shown *)
(*               Test 2 — Year 5: no notices shown             *)
(*               Test 3 — Year 10: no-dividends + no-margin    *)
(*             Visual output verified manually by tester.      *)
(*             Machine check: action = 1 (CONTINUE) each call. *)
(* PARAMS    : none                                             *)
(* SIDE EFX  : Calls scrYearHdr 3 times; clears screen each.  *)
(* ============================================================ *)
DIM action : BYTE
DIM passed : INTEGER
DIM failed : INTEGER

ON ERROR GOTO 900

passed := 0
failed := 0

PRINT "=== TSTYRHDR ==="
PRINT

! ---- Test 1: Year 1 — no-dividends and no-sell notices ------
PRINT "Test 1: Year 1 of 10."
PRINT "Expect: no-dividends notice, no-sell notice."
PRINT "Expect: no-margin notice absent."
PRINT "Press any key to launch screen."
RUN waitKey
RUN scrYearHdr(1, 10, 1, TRUE, FALSE, TRUE, action)
GOSUB 100

! ---- Test 2: Year 5 — no notices ----------------------------
PRINT "Test 2: Year 5 of 10."
PRINT "Expect: no rule notices displayed."
PRINT "Press any key to launch screen."
RUN waitKey
RUN scrYearHdr(5, 10, 1, FALSE, FALSE, FALSE, action)
GOSUB 200

! ---- Test 3: Year 10 — no-dividends and no-margin notices ---
PRINT "Test 3: Year 10 of 10."
PRINT "Expect: no-dividends notice, no-margin notice."
PRINT "Expect: no-sell notice absent."
PRINT "Press any key to launch screen."
RUN waitKey
RUN scrYearHdr(10, 10, 1, TRUE, TRUE, FALSE, action)
GOSUB 300

PRINT
PRINT "Results: "; passed; " passed, "; failed; " failed."
END

100 ! Test 1 action check
