PROCEDURE TSTDVINT
(* ============================================================ *)
(* PROCEDURE : TSTDVINT                                         *)
(* PURPOSE   : Confirmation tests for scrDivInt (Task 8.2).    *)
(*             Two visual test cases per spec 8.2:             *)
(*               Test 1 — spec confirmation case:              *)
(*                 Shady Brooks 100 shares = $700,             *)
(*                 1 medium bond = $250,                       *)
(*                 cashBef=5000, totRcvd=950, cashAft=5950.    *)
(*                 Verify all figures render correctly.        *)
(*               Test 2 — all-zero case:                       *)
(*                 All divRcvd=0, all bndInt=0.                *)
(*                 Verify "(none)" shown in both sections.     *)
(*             Visual output verified manually by tester.      *)
(*             Machine check: action = 1 (CONTINUE) each call. *)
(* PARAMS    : none                                             *)
(* SIDE EFX  : Calls scrDivInt twice; clears screen each call. *)
(* ============================================================ *)
DIM divRcvd(9) : INTEGER
DIM bndInt(3)  : INTEGER
DIM action     : BYTE
DIM passed     : INTEGER
DIM failed     : INTEGER
DIM s          : INTEGER
DIM b          : INTEGER

ON ERROR GOTO 900

passed := 0
failed := 0

! -- Test 1: spec confirmation case ---------------------------
! Year 2, player ALICE, 100 shares Shady Brooks (stock 4, $7)
! = $700 dividend, 1 medium bond (bond 2) = $250 interest.
! cashBef=5000, totRcvd=950, cashAft=5950.
PRINT "Test 1: Year 2, Shady Brooks $700, medium bond $250."
PRINT "Expect: Shady Brooks $   700 under DIVIDENDS RECEIVED."
PRINT "Expect: Medium       $   250 under BOND INTEREST."
PRINT "Expect: Total received $  950, cash 5000 -> 5950."
PRINT "Press any key to launch screen."
RUN waitKey

FOR s := 1 TO 9
  divRcvd(s) := 0
NEXT s
FOR b := 1 TO 3
  bndInt(b) := 0
NEXT b
divRcvd(4) := 700
bndInt(2)  := 250

RUN scrDivInt(2, "ALICE", 5000, divRcvd, bndInt, 950, 5950, action)
GOSUB 100

! -- Test 2: all-zero case ------------------------------------
! No dividends received, no bond interest.
! Expect "(none)" in both sections. totRcvd=0, cash unchanged.
PRINT "Test 2: Year 5, no dividends, no bond interest."
PRINT "Expect: (none) under DIVIDENDS RECEIVED."
PRINT "Expect: (none) under BOND INTEREST."
PRINT "Expect: Total received $     0, cash 3000 -> 3000."
PRINT "Press any key to launch screen."
RUN waitKey

FOR s := 1 TO 9
  divRcvd(s) := 0
NEXT s
FOR b := 1 TO 3
  bndInt(b) := 0
NEXT b

RUN scrDivInt(5, "BOB", 3000, divRcvd, bndInt, 0, 3000, action)
GOSUB 200

PRINT
PRINT "Results: "; passed; " passed, "; failed; " failed."
END

100 \ ! Test 1 action check
    IF action = 1 THEN
      PRINT "Test 1 PASS  action=1 (CONTINUE)"
      passed := passed + 1
    ELSE
      PRINT "Test 1 FAIL  action: exp=1 got="; action
      failed := failed + 1
    ENDIF
    PRINT
RETURN

200 \ ! Test 2 action check
    IF action = 1 THEN
      PRINT "Test 2 PASS  action=1 (CONTINUE)"
      passed := passed + 1
    ELSE
      PRINT "Test 2 FAIL  action: exp=1 got="; action
      failed := failed + 1
    ENDIF
    PRINT
RETURN

900 PRINT "Runtime error "; ERR; " in TSTDVINT"
    END

PROCEDURE TSTCRDSCR
(* ============================================================ *)
(* PROCEDURE : TSTCRDSCR                                        *)
(* PURPOSE   : Confirmation tests for scrCard (Task 8.3).      *)
(*             Three visual test cases per spec 8.3:           *)
(*               Test 1 — Card 1 (Bear, Growth Corp +10,       *)
(*                         divBonus=$2): verify market type,   *)
(*                         flavour text, delta, bonus line.    *)
(*               Test 2 — Card 34 (Bull, 4 stocks): verify all *)
(*                         four stocks and positive deltas.    *)
(*               Test 3 — Card 36 (Bear, 3 stocks): verify     *)
(*                         negative deltas render with sign.   *)
(*             Visual output verified manually by tester.      *)
(*             Machine check: action = 1 (CONTINUE) each call. *)
(* PARAMS    : none                                             *)
(* SIDE EFX  : Calls scrCard 3 times; clears screen each call. *)
(*             Calls getCard 3 times; repositions DATA pointer.*)
(* ============================================================ *)
! Line exceeds 79 chars; TYPE statement requires single line.
TYPE CardRec = crdType:INTEGER;efxCnt:INTEGER;efxStk(4):INTEGER;efxDlt(4):INTEGER;divBonus:INTEGER
DIM card    : CardRec
DIM flavTxt : STRING[160]
DIM action  : BYTE
DIM passed  : INTEGER
DIM failed  : INTEGER

ON ERROR GOTO 900

passed := 0
failed := 0

PRINT "=== TSTCRDSCR ==="
PRINT

! ---- Test 1: Card 1 — Bear, Growth Corp +10, divBonus=2 -----
PRINT "Test 1: Card 1 (Bear, Growth Corp +10, divBonus=2)."
PRINT "Expect: SITUATION CARD #1"
PRINT "Expect: BEAR MARKET"
PRINT "Expect: flavour text re: year-end dividend."
PRINT "Expect: Growth Corp   +10"
PRINT "Expect: DIVIDEND BONUS: $2 per share"
PRINT "Press any key to launch screen."
RUN waitKey
RUN getCard(1, card)
flavTxt := "Extra year-end dividend of $2 per share declared by the Board of Directors."
RUN scrCard(1, card, flavTxt, action)
GOSUB 100

! ---- Test 2: Card 34 — Bull, 4 stocks -----------------------
PRINT "Test 2: Card 34 (Bull, 4 stocks)."
PRINT "Expect: SITUATION CARD #34"
PRINT "Expect: BULL MARKET"
PRINT "Expect: flavour text re: general market rise."
PRINT "Expect: Growth Corp   +8"
PRINT "Expect: Metro Props   +5"
PRINT "Expect: Pioneer Mut   +5"
PRINT "Expect: United Auto   +7"
PRINT "Expect: no dividend bonus line."
PRINT "Press any key to launch screen."
RUN waitKey
RUN getCard(34, card)
flavTxt := "General market rise over the last two months."
RUN scrCard(34, card, flavTxt, action)
GOSUB 200

! ---- Test 3: Card 36 — Bear, 3 stocks, negative deltas ------
PRINT "Test 3: Card 36 (Bear, 3 stocks, negative deltas)."
PRINT "Expect: SITUATION CARD #36"
PRINT "Expect: BEAR MARKET"
PRINT "Expect: flavour text re: profit taking."
PRINT "Expect: Growth Corp   -8"
PRINT "Expect: Metro Props   -5"
PRINT "Expect: United Auto   -7"
PRINT "Expect: no dividend bonus line."
PRINT "Press any key to launch screen."
RUN waitKey
RUN getCard(36, card)
flavTxt := "Surge of profit taking drops stock market."
RUN scrCard(36, card, flavTxt, action)
GOSUB 300

PRINT
PRINT "Results: "; passed; " passed, "; failed; " failed."
END

100 \ ! Test 1 action check
    IF action = 1 THEN
      PRINT "Test 1 PASS  action=1 (CONTINUE)"
      passed := passed + 1
    ELSE
      PRINT "Test 1 FAIL  action: exp=1 got="; action
      failed := failed + 1
    ENDIF
    PRINT
RETURN

200 \ ! Test 2 action check
    IF action = 1 THEN
      PRINT "Test 2 PASS  action=1 (CONTINUE)"
      passed := passed + 1
    ELSE
      PRINT "Test 2 FAIL  action: exp=1 got="; action
      failed := failed + 1
    ENDIF
    PRINT
RETURN

300 \ ! Test 3 action check
    IF action = 1 THEN
      PRINT "Test 3 PASS  action=1 (CONTINUE)"
      passed := passed + 1
    ELSE
      PRINT "Test 3 FAIL  action: exp=1 got="; action
      failed := failed + 1
    ENDIF
    PRINT
RETURN

900 PRINT "Runtime error "; ERR; " in TSTCRDSCR"
    END

PROCEDURE TSTDICE
(* ============================================================ *)
(* PROCEDURE : TSTDICE                                          *)
(* PURPOSE   : Confirmation tests for scrDice (Task 8.4).      *)
(*             Three visual test cases:                        *)
(*               Test 1 — Mode A: single roll die1=3 die2=4   *)
(*                         total=7. Verify "ROLL MODE A" label  *)
(*                         and three die/total lines.           *)
(*               Test 2 — Mode B: single roll die1=5 die2=5   *)
(*                         total=10. Verify "ROLL MODE B" label *)
(*                         and distinct values from Test 1.    *)
(*               Test 3 — Mode C: 9 rolls (one per stock).     *)
(*                         Verify "ROLL MODE C" label and all   *)
(*                         9 stock rows with correct totals.   *)
(*             Visual output verified manually by tester.      *)
(*             Machine check: action = 1 (CONTINUE) each call. *)
(* PARAMS    : none                                             *)
(* SIDE EFX  : Calls scrDice 3 times; clears screen each call. *)
(* ============================================================ *)
DIM dieOne(9)  : BYTE
DIM dieTwo(9)  : BYTE
DIM rollTot(9) : BYTE
DIM action     : BYTE
DIM passed     : INTEGER
DIM failed     : INTEGER
DIM i          : INTEGER

ON ERROR GOTO 900

passed := 0
failed := 0

! ---- Test 1: Mode A — single roll, total=7 ------------------
PRINT "Test 1: Mode A. Single roll, die1=3, die2=4, total=7."
PRINT "Expect: ROLL MODE A"
PRINT "Expect: Die 1:  3"
PRINT "Expect: Die 2:  4"
PRINT "Expect: Total:  7"
PRINT "Press any key to launch screen."
RUN waitKey

FOR i := 1 TO 9
  dieOne(i)  := 0
  dieTwo(i)  := 0
  rollTot(i) := 0
NEXT i
dieOne(1)  := 3
dieTwo(1)  := 4
rollTot(1) := 7

RUN scrDice(1, 1, dieOne, dieTwo, rollTot, action)
GOSUB 100

! ---- Test 2: Mode B — single roll, total=10 -----------------
PRINT "Test 2: Mode B. Single roll, die1=5, die2=5, total=10."
PRINT "Expect: ROLL MODE B"
PRINT "Expect: Die 1:  5"
PRINT "Expect: Die 2:  5"
PRINT "Expect: Total:  10"
PRINT "Press any key to launch screen."
RUN waitKey

FOR i := 1 TO 9
  dieOne(i)  := 0
  dieTwo(i)  := 0
  rollTot(i) := 0
NEXT i
dieOne(1)  := 5
dieTwo(1)  := 5
rollTot(1) := 10

RUN scrDice(2, 1, dieOne, dieTwo, rollTot, action)
GOSUB 200

! ---- Test 3: Mode C — 9 rolls, one per stock ----------------
PRINT "Test 3: Mode C. 9 per-stock rolls."
PRINT "Expect: ROLL MODE C  (per stock)"
PRINT "Expect: 9 rows, one per stock."
PRINT "Expected totals by stock:"
PRINT "  Growth Corp   1+2=  3"
PRINT "  Metro Props   2+3=  5"
PRINT "  Pioneer Mut   3+4=  7"
PRINT "  Shady Brooks  4+5=  9"
PRINT "  Stryker Drlg  5+6= 11"
PRINT "  Tri-City Trn  6+6= 12"
PRINT "  United Auto   1+1=  2"
PRINT "  Uranium Ent   2+4=  6"
PRINT "  Valley Power  3+5=  8"
PRINT "Press any key to launch screen."
RUN waitKey

dieOne(1) := 1 \ dieTwo(1) := 2 \ rollTot(1) := 3
dieOne(2) := 2 \ dieTwo(2) := 3 \ rollTot(2) := 5
dieOne(3) := 3 \ dieTwo(3) := 4 \ rollTot(3) := 7
dieOne(4) := 4 \ dieTwo(4) := 5 \ rollTot(4) := 9
dieOne(5) := 5 \ dieTwo(5) := 6 \ rollTot(5) := 11
dieOne(6) := 6 \ dieTwo(6) := 6 \ rollTot(6) := 12
dieOne(7) := 1 \ dieTwo(7) := 1 \ rollTot(7) := 2
dieOne(8) := 2 \ dieTwo(8) := 4 \ rollTot(8) := 6
dieOne(9) := 3 \ dieTwo(9) := 5 \ rollTot(9) := 8

RUN scrDice(3, 9, dieOne, dieTwo, rollTot, action)
GOSUB 300

PRINT
PRINT "Results: "; passed; " passed, "; failed; " failed."
END

100 \ ! Test 1 action check
    IF action = 1 THEN
      PRINT "Test 1 PASS  action=1 (CONTINUE)"
      passed := passed + 1
    ELSE
      PRINT "Test 1 FAIL  action: exp=1 got="; action
      failed := failed + 1
    ENDIF
    PRINT
RETURN

200 \ ! Test 2 action check
    IF action = 1 THEN
      PRINT "Test 2 PASS  action=1 (CONTINUE)"
      passed := passed + 1
    ELSE
      PRINT "Test 2 FAIL  action: exp=1 got="; action
      failed := failed + 1
    ENDIF
    PRINT
RETURN

300 \ ! Test 3 action check
    IF action = 1 THEN
      PRINT "Test 3 PASS  action=1 (CONTINUE)"
      passed := passed + 1
    ELSE
      PRINT "Test 3 FAIL  action: exp=1 got="; action
      failed := failed + 1
    ENDIF
    PRINT
RETURN

900 PRINT "Runtime error "; ERR; " in TSTDICE"
    END


PROCEDURE TSTMKTBRD
(* ============================================================ *)
(* PROCEDURE : TSTMKTBRD                                        *)
(* PURPOSE   : Confirmation tests for scrMktBoard (Task 8.5).  *)
(*             One visual test case per spec 8.5:              *)
(*               Stock 5 (Stryker Drlg): split. prcBefCrd=173, *)
(*                 mktDlta=+73, crdDlta=0, newPrc=87.          *)
(*                 Expect flag SPLT.                            *)
(*               Stock 2 (Metro Props): suspended. prcBefCrd=40*)
(*                 mktDlta=-60, crdDlta=0, newPrc=40.          *)
(*                 Expect flag SUSP.                            *)
(*               Stock 8 (Uranium Ent): reinstated. prcBefCrd= *)
(*                 60, mktDlta=+20, crdDlta=0, newPrc=60.      *)
(*                 Expect flag RSTD.                            *)
(*               Stock 3 (Pioneer Mut): bankruptcy. prcBefCrd= *)
(*                 -5, mktDlta=-15, crdDlta=0, newPrc=0.       *)
(*                 Expect flag BKRT.                            *)
(*               Stocks 1,4,6,7,9: neutral. prcBefCrd=100,    *)
(*                 mktDlta=0, crdDlta=0, newPrc=100, no flag.  *)
(*             Visual output verified manually by tester.      *)
(*             Machine check: action = 1 (CONTINUE).           *)
(* PARAMS    : none                                             *)
(* SIDE EFX  : Calls scrMktBoard; clears screen.               *)
(* ============================================================ *)
DIM prcBefCrd(9) : INTEGER
DIM mktDlta(9)   : INTEGER
DIM crdDlta(9)   : INTEGER
DIM newPrc(9)    : INTEGER
DIM splitOcc(9)  : BOOLEAN
DIM divSuspd(9)  : BOOLEAN
DIM divRnstd(9)  : BOOLEAN
DIM action       : BYTE
DIM passed       : INTEGER
DIM failed       : INTEGER
DIM s            : INTEGER

ON ERROR GOTO 900

passed := 0
failed := 0

PRINT "=== TSTMKTBRD ==="
PRINT

! ---- Initialise all stocks to neutral ----------------------
FOR s := 1 TO 9
  prcBefCrd(s) := 100
  mktDlta(s)   := 0
  crdDlta(s)   := 0
  newPrc(s)    := 100
  splitOcc(s)  := FALSE
  divSuspd(s)  := FALSE
  divRnstd(s)  := FALSE
NEXT s

! ---- Stock 2 (Metro Props): suspended ----------------------
! Original price ~100, mktDlta=-60 → prcBefCrd=40, newPrc=40.
! 40 < DividendCutoff(50) → divSuspd=TRUE.
prcBefCrd(2) := 40
mktDlta(2)   := -60
crdDlta(2)   := 0
newPrc(2)    := 40
divSuspd(2)  := TRUE

! ---- Stock 3 (Pioneer Mut): bankruptcy floor ---------------
! Original ~10, mktDlta=-15 → prcBefCrd=-5 (unclamped).
! newPrc clamped to 0. Flag = BKRT (overrides all others).
prcBefCrd(3) := -5
mktDlta(3)   := -15
crdDlta(3)   := 0
newPrc(3)    := 0
divSuspd(3)  := TRUE

! ---- Stock 5 (Stryker Drlg): split ------------------------
! Original 100, mktDlta=+73 → prcBefCrd=173.
! resolvePrice: 173 >= 150 → split to (173+1)/2=87.
prcBefCrd(5) := 173
mktDlta(5)   := 73
crdDlta(5)   := 0
newPrc(5)    := 87
splitOcc(5)  := TRUE

! ---- Stock 8 (Uranium Ent): reinstated --------------------
! Original price ~40 (was suspended), mktDlta=+20 → prcBefCrd=60.
! 60 >= DividendCutoff(50) → reinstated.
prcBefCrd(8) := 60
mktDlta(8)   := 20
crdDlta(8)   := 0
newPrc(8)    := 60
divRnstd(8)  := TRUE

! ---- Expected output summary to guide tester ---------------
PRINT "Expected board layout:"
PRINT "  Stock 2  Metro Props:   PREV  40  MKT -60  NEW  40  SUSP"
PRINT "  Stock 3  Pioneer Mut:   PREV  -5  MKT -15  NEW   0  BKRT"
PRINT "  Stock 5  Stryker Drlg:  PREV 173  MKT +73  NEW  87  SPLT"
PRINT "  Stock 8  Uranium Ent:   PREV  60  MKT +20  NEW  60  RSTD"
PRINT "  All other stocks:       PREV 100  MKT   0  NEW 100  (blank)"
PRINT
PRINT "Press any key to launch screen."
RUN waitKey

RUN scrMktBoard(prcBefCrd, mktDlta, crdDlta, newPrc, splitOcc, divSuspd, divRnstd, action)
GOSUB 100

PRINT
PRINT "Results: "; passed; " passed, "; failed; " failed."
END

100 \ ! Action check
    IF action = 1 THEN
      PRINT "PASS  action=1 (CONTINUE)"
      passed := passed + 1
    ELSE
      PRINT "FAIL  action: exp=1 got="; action
      failed := failed + 1
    ENDIF
    PRINT
RETURN

900 PRINT "Runtime error "; ERR; " in TSTMKTBRD"
    END


PROCEDURE TSTSPLTDV
(* ============================================================ *)
(* PROCEDURE : TSTSPLTDV                                        *)
(* PURPOSE   : Confirmation tests for scrSplit and scrDivFlag  *)
(*             (Task 8.6). Three visual test cases per spec:   *)
(*               Test 1 - scrSplit: Stryker Drlg split.        *)
(*                 oldPrc=173, newPrc=87.                       *)
(*                 Player ALICE: 100 shares -> 200.             *)
(*                 Player BOB: 0 shares -> not shown.           *)
(*                 Expect: split header, prices, ALICE row only *)
(*               Test 2 - scrDivFlag SUSPENDED: Metro Props.   *)
(*                 newPrc=45, cutPrc=50.                        *)
(*                 Expect: "DIVIDEND SUSPENDED" header,         *)
(*                   current price 45, cutoff 50,              *)
(*                   suspended notice line.                     *)
(*               Test 3 - scrDivFlag REINSTATED: Uranium Ent.  *)
(*                 newPrc=55, cutPrc=50.                        *)
(*                 Expect: "DIVIDEND REINSTATED" header,        *)
(*                   current price 55, cutoff 50,              *)
(*                   reinstated notice line.                    *)
(*             Visual output verified manually by tester.      *)
(*             Machine check: action = 1 (CONTINUE) each call. *)
(* PARAMS    : none                                             *)
(* SIDE EFX  : Calls scrSplit once, scrDivFlag twice.          *)
(*             Clears screen each call.                        *)
(* ============================================================ *)
DIM plyrName(6) : STRING[20]
DIM shrBef(6)   : INTEGER
DIM shrAft(6)   : INTEGER
DIM action      : BYTE
DIM passed      : INTEGER
DIM failed      : INTEGER
DIM p           : INTEGER

ON ERROR GOTO 900

passed := 0
failed := 0

! ---- Test 1: scrSplit - Stryker Drlg, 2-for-1 split ---------
! oldPrc=173, newPrc=87.
! ALICE held 100 shares before split, doubled to 200 after.
! BOB held 0 shares - must not appear in player list.
PRINT "=== TSTSPLTDV ==="
PRINT
PRINT "Test 1: scrSplit - Stryker Drlg split."
PRINT "Expect: STOCK SPLIT  2 FOR 1"
PRINT "Expect: Stryker Drlg"
PRINT "Expect: Old price:  $ 173"
PRINT "Expect: New price:  $  87"
PRINT "Expect: ALICE row: before=100  after=200"
PRINT "Expect: BOB row: NOT shown (zero shares before)"
PRINT "Press any key to launch screen."
RUN waitKey

FOR p := 1 TO 6
  plyrName(p) := ""
  shrBef(p)   := 0
  shrAft(p)   := 0
NEXT p
plyrName(1) := "ALICE"
shrBef(1)   := 100
shrAft(1)   := 200
plyrName(2) := "BOB"
shrBef(2)   := 0
shrAft(2)   := 0

RUN scrSplit("Stryker Drlg", 173, 87, 2, plyrName, shrBef, shrAft, action)
GOSUB 100

! ---- Test 2: scrDivFlag - SUSPENDED -------------------------
! Metro Props, newPrc=45, cutPrc=50.
! 45 < 50 → newly suspended this year.
PRINT "Test 2: scrDivFlag SUSPENDED - Metro Props."
PRINT "Expect: DIVIDEND SUSPENDED"
PRINT "Expect: Metro Props"
PRINT "Expect: Current price:  $  45"
PRINT "Expect: Cutoff price:   $  50"
PRINT "Expect: suspended notice line."
PRINT "Press any key to launch screen."
RUN waitKey

RUN scrDivFlag("Metro Props", 1, 45, 50, action)
GOSUB 200

! ---- Test 3: scrDivFlag - REINSTATED ------------------------
! Uranium Ent, newPrc=55, cutPrc=50.
! 55 >= 50 → reinstated after prior suspension.
PRINT "Test 3: scrDivFlag REINSTATED - Uranium Ent."
PRINT "Expect: DIVIDEND REINSTATED"
PRINT "Expect: Uranium Ent"
PRINT "Expect: Current price:  $  55"
PRINT "Expect: Cutoff price:   $  50"
PRINT "Expect: reinstated notice line."
PRINT "Press any key to launch screen."
RUN waitKey

RUN scrDivFlag("Uranium Ent", 2, 55, 50, action)
GOSUB 300

PRINT
PRINT "Results: "; passed; " passed, "; failed; " failed."
END

100 \ ! Test 1 action check
    IF action = 1 THEN
      PRINT "Test 1 PASS  action=1 (CONTINUE)"
      passed := passed + 1
    ELSE
      PRINT "Test 1 FAIL  action: exp=1 got="; action
      failed := failed + 1
    ENDIF
    PRINT
RETURN

200 \ ! Test 2 action check
    IF action = 1 THEN
      PRINT "Test 2 PASS  action=1 (CONTINUE)"
      passed := passed + 1
    ELSE
      PRINT "Test 2 FAIL  action: exp=1 got="; action
      failed := failed + 1
    ENDIF
    PRINT
RETURN

300 \ ! Test 3 action check
    IF action = 1 THEN
      PRINT "Test 3 PASS  action=1 (CONTINUE)"
      passed := passed + 1
    ELSE
      PRINT "Test 3 FAIL  action: exp=1 got="; action
      failed := failed + 1
    ENDIF
    PRINT
RETURN

900 PRINT "Runtime error "; ERR; " in TSTSPLTDV"
    END

PROCEDURE TSTSELL
(* ============================================================ *)
(* PROCEDURE : TSTSELL                                          *)
(* PURPOSE   : Confirmation tests for scrSell (Task 9.1).      *)
(*             Interactive test: tester supplies specific       *)
(*             input at each prompt per the sequence below.    *)
(*             Machine checks: ordCnt, ordType, ordId, ordQty. *)
(*                                                             *)
(* SETUP:                                                      *)
(*   Player ALICE holds:                                       *)
(*     100 Growth Corp (stock 1) at $120                       *)
(*      50 Shady Brooks (stock 4) at $85                       *)
(*       1 medium bond (bond 2)                               *)
(*                                                             *)
(* REQUIRED INPUT SEQUENCE:                                    *)
(*   Initial menu  : press 1 (enter orders)                    *)
(*   Growth Corp   : enter 15  -> verify rejection msg         *)
(*   Growth Corp   : enter 150 -> verify rejection msg         *)
(*   Growth Corp   : enter 50  -> accepted                     *)
(*   Shady Brooks  : enter 0   (skip)                          *)
(*   Medium bond   : enter 1   -> accepted                     *)
(*   Summary screen: press 1   (Confirm)                       *)
(*                                                             *)
(* EXPECTED:                                                   *)
(*   ordCnt = 2                                               *)
(*   ordType(1)=1, ordId(1)=1, ordQty(1)=50  (Growth Corp)   *)
(*   ordType(2)=2, ordId(2)=2, ordQty(2)=1   (medium bond)   *)
(*   Proceeds: 50*120 + 1*5000 = 11000                        *)
(*   cashBal update verified by TSTASLL (Task 9.2)           *)
(* PARAMS    : none                                             *)
(* SIDE EFX  : Calls scrSell; clears screen multiple times.   *)
(* ============================================================ *)
! Line exceeds 79 chars; TYPE statement requires single line.
TYPE PlyrRec = plyrName:STRING[20];plyrType,aiTier:BYTE;cashBal,marginTot:INTEGER;isBankrupt,hadCashPur:BOOLEAN;stckShrs(9):INTEGER;mgnHeld(9):BOOLEAN;bondUnts(3):INTEGER
TYPE MktState = stckPrice(9):INTEGER;divSuspnd(9):BOOLEAN
DIM plyr        : PlyrRec
DIM mkt         : MktState
DIM ordType(12) : INTEGER
DIM ordId(12)   : INTEGER
DIM ordQty(12)  : INTEGER
DIM ordCnt      : INTEGER
DIM action      : BYTE
DIM passed      : INTEGER
DIM failed      : INTEGER
DIM i           : INTEGER

ON ERROR GOTO 900

passed := 0
failed := 0

! --- Initialize player record --------------------------------
RUN initPlayer(plyr)
plyr.plyrName    := "ALICE"
plyr.stckShrs(1) := 100
plyr.stckShrs(4) := 50
plyr.bondUnts(2) := 1

! --- Initialize market state ---------------------------------
RUN initMkt(mkt)
mkt.stckPrice(1) := 120
mkt.stckPrice(4) := 85

! --- Initialize order arrays ---------------------------------
FOR i := 1 TO 12
  ordType(i) := 0
  ordId(i)   := 0
  ordQty(i)  := 0
NEXT i
ordCnt := 0
action := 0

! --- Test instructions ---------------------------------------
PRINT "=== TSTSELL  Task 9.1 ==="
PRINT
PRINT "Player ALICE holds:"
PRINT "  100 Growth Corp  @ $120"
PRINT "   50 Shady Brooks @ $ 85"
PRINT "    1 medium bond"
PRINT
PRINT "REQUIRED INPUT SEQUENCE:"
PRINT "  Initial menu  : press 1 (enter orders)"
PRINT "  Growth Corp   : enter 15  -> verify rejected"
PRINT "  Growth Corp   : enter 150 -> verify rejected"
PRINT "  Growth Corp   : enter 50  -> accepted"
PRINT "  Shady Brooks  : enter 0   (skip)"
PRINT "  Medium bond   : enter 1"
PRINT "  Summary screen: press 1   (Confirm)"
PRINT
PRINT "Press any key to launch scrSell."
RUN waitKey

RUN scrSell(2, plyr, mkt, ordType, ordId, ordQty, ordCnt, action)
GOSUB 100

PRINT
PRINT "Results: "; passed; " passed, "; failed; " failed."
END

100 \ ! --- Check returned values ---
    PRINT
    PRINT "ordCnt = "; ordCnt; "  (exp 2)"
    PRINT "action = "; action; "  (exp 1)"
    PRINT
    IF ordCnt = 2 THEN
      PRINT "ordCnt PASS"
      passed := passed + 1
    ELSE
      PRINT "ordCnt FAIL  exp=2 got="; ordCnt
      failed := failed + 1
    ENDIF
    IF action = 1 THEN
      PRINT "action PASS  (CONFIRM)"
      passed := passed + 1
    ELSE
      PRINT "action FAIL  exp=1 got="; action
      failed := failed + 1
    ENDIF
    ! Check order 1: STOCK id=1 qty=50 (Growth Corp)
    IF ordCnt >= 1 THEN
      IF ordType(1) = 1 AND ordId(1) = 1 AND ordQty(1) = 50 THEN
        PRINT "ord1 PASS  STOCK#1 qty=50"
        passed := passed + 1
      ELSE
        PRINT "ord1 FAIL  exp STOCK#1 qty=50"
        PRINT "  got type="; ordType(1); " id=";
        PRINT ordId(1); " qty="; ordQty(1)
        failed := failed + 1
      ENDIF
    ENDIF
    ! Check order 2: BOND id=2 qty=1 (medium bond)
    IF ordCnt >= 2 THEN
      IF ordType(2) = 2 AND ordId(2) = 2 AND ordQty(2) = 1 THEN
        PRINT "ord2 PASS  BOND#2 qty=1"
        passed := passed + 1
      ELSE
        PRINT "ord2 FAIL  exp BOND#2 qty=1"
        PRINT "  got type="; ordType(2); " id=";
        PRINT ordId(2); " qty="; ordQty(2)
        failed := failed + 1
      ENDIF
    ENDIF
    ! Expected proceeds (cashBal update verified in Task 9.2)
    PRINT
    PRINT "Expected proceeds: 50*120 + 1*5000 = 11000"
    PRINT "cashBal update verified by TSTASLL (Task 9.2)."
RETURN

900 PRINT "Runtime error "; ERR; " in TSTSELL"
    END

PROCEDURE TSTASLL
(* ============================================================ *)
(* PROCEDURE : TSTASLL                                         *)
(* PURPOSE   : Confirmation tests for applySells (Task 9.2).   *)
(*             Four machine-checked tests:                     *)
(*               Test 1 — cash stock + bond sell               *)
(*                 50 Growth Corp @ $120 + 1 med bond          *)
(*                 exp cashBal=16000, stckShrs(1)=50,          *)
(*                     bondUnts(2)=0                           *)
(*               Test 2 — full margin sell, proceeds>marginTot *)
(*                 100 Stryker @ $80, marginTot=5000           *)
(*                 proceeds=8000, repay=5000                   *)
(*                 exp cashBal=8000, marginTot=0,              *)
(*                     stckShrs(5)=0, mgnHeld(5)=FALSE         *)
(*               Test 3 — partial margin sell, proceeds<marginTot*)
(*                 50 Stryker @ $80, marginTot=8000            *)
(*                 proceeds=4000, repay=4000                   *)
(*                 exp cashBal=5000 (unchanged), marginTot=4000*)
(*                     stckShrs(5)=50, mgnHeld(5)=TRUE         *)
(*               Test 4 — ordCnt=0 (pass turn)                 *)
(*                 exp all fields unchanged                    *)
(* PARAMS    : none                                             *)
(* SIDE EFX  : None. No screen output from applySells.         *)
(* ============================================================ *)
! Line exceeds 79 chars; TYPE statement requires single line.
TYPE PlyrRec = plyrName:STRING[20];plyrType,aiTier:BYTE;cashBal,marginTot:INTEGER;isBankrupt,hadCashPur:BOOLEAN;stckShrs(9):INTEGER;mgnHeld(9):BOOLEAN;bondUnts(3):INTEGER
TYPE MktState = stckPrice(9):INTEGER;divSuspnd(9):BOOLEAN
DIM plyr        : PlyrRec
DIM mkt         : MktState
DIM ordType(12) : INTEGER
DIM ordId(12)   : INTEGER
DIM ordQty(12)  : INTEGER
DIM ordCnt      : INTEGER
DIM passed      : INTEGER
DIM failed      : INTEGER
DIM i           : INTEGER

ON ERROR GOTO 900

passed := 0
failed := 0

PRINT "=== TSTASLL  Task 9.2 ==="
PRINT

! ---- Test 1: cash stock sell + bond sell --------------------
! 100 Growth Corp (stock 1) cash @ $120
! 50  Shady Brooks (stock 4) cash @ $85 (not sold)
! 1 medium bond (bond 2) held
! Orders: sell 50 Growth Corp, sell 1 medium bond
! Expected: cashBal = 5000 + (50*120) + (1*5000) = 16000
!           stckShrs(1) = 50, stckShrs(4) = 50 (unchanged)
!           bondUnts(2) = 0
!           mgnHeld(1) = FALSE (was already FALSE; shares remain)

RUN initPlayer(plyr)
RUN initMkt(mkt)
plyr.stckShrs(1) := 100
plyr.stckShrs(4) := 50
plyr.bondUnts(2) := 1
mkt.stckPrice(1) := 120
mkt.stckPrice(4) := 85

FOR i := 1 TO 12
  ordType(i) := 0
  ordId(i)   := 0
  ordQty(i)  := 0
NEXT i
ordType(1) := 1 \ ordId(1) := 1 \ ordQty(1) := 50
ordType(2) := 2 \ ordId(2) := 2 \ ordQty(2) := 1
ordCnt := 2

RUN applySells(plyr, mkt, ordType, ordId, ordQty, ordCnt)
GOSUB 100

! ---- Test 2: full margin sell, proceeds > marginTot ---------
! 100 Stryker (stock 5) on margin @ $80, marginTot=5000
! Sell 100 shares: proceeds=8000, repay=5000
! Expected: cashBal = 5000 + (8000-5000) = 8000
!           marginTot = 0
!           stckShrs(5) = 0, mgnHeld(5) = FALSE

RUN initPlayer(plyr)
RUN initMkt(mkt)
plyr.stckShrs(5) := 100
plyr.mgnHeld(5)  := TRUE
plyr.marginTot   := 5000
mkt.stckPrice(5) := 80

FOR i := 1 TO 12
  ordType(i) := 0
  ordId(i)   := 0
  ordQty(i)  := 0
NEXT i
ordType(1) := 1 \ ordId(1) := 5 \ ordQty(1) := 100
ordCnt := 1

RUN applySells(plyr, mkt, ordType, ordId, ordQty, ordCnt)
GOSUB 200

! ---- Test 3: partial margin sell, proceeds < marginTot ------
! 100 Stryker (stock 5) on margin @ $80, marginTot=8000
! Sell 50 shares: proceeds=4000, repay=4000 (all proceeds)
! Expected: cashBal = 5000 (unchanged; all proceeds to margin)
!           marginTot = 4000
!           stckShrs(5) = 50, mgnHeld(5) = TRUE (partial)

RUN initPlayer(plyr)
RUN initMkt(mkt)
plyr.stckShrs(5) := 100
plyr.mgnHeld(5)  := TRUE
plyr.marginTot   := 8000
mkt.stckPrice(5) := 80

FOR i := 1 TO 12
  ordType(i) := 0
  ordId(i)   := 0
  ordQty(i)  := 0
NEXT i
ordType(1) := 1 \ ordId(1) := 5 \ ordQty(1) := 50
ordCnt := 1

RUN applySells(plyr, mkt, ordType, ordId, ordQty, ordCnt)
GOSUB 300

! ---- Test 4: ordCnt=0, pass turn — no changes ---------------
! Expected: cashBal=5000, marginTot=0, all shares/bonds zero

RUN initPlayer(plyr)
RUN initMkt(mkt)

FOR i := 1 TO 12
  ordType(i) := 0
  ordId(i)   := 0
  ordQty(i)  := 0
NEXT i
ordCnt := 0

RUN applySells(plyr, mkt, ordType, ordId, ordQty, ordCnt)
GOSUB 400

PRINT
PRINT "Results: "; passed; " passed, "; failed; " failed."
END

100 \ ! Test 1: cash sell + bond sell
    GOSUB 500
    IF plyr.cashBal = 16000 THEN
      PRINT "Test 1 PASS  cashBal=16000"
      passed := passed + 1
    ELSE
      PRINT "Test 1 FAIL  cashBal exp=16000 got="; plyr.cashBal
      failed := failed + 1
    ENDIF
    IF plyr.stckShrs(1) = 50 THEN
      PRINT "Test 1 PASS  stckShrs(1)=50"
      passed := passed + 1
    ELSE
      PRINT "Test 1 FAIL  stckShrs(1) exp=50 got="; plyr.stckShrs(1)
      failed := failed + 1
    ENDIF
    IF plyr.bondUnts(2) = 0 THEN
      PRINT "Test 1 PASS  bondUnts(2)=0"
      passed := passed + 1
    ELSE
      PRINT "Test 1 FAIL  bondUnts(2) exp=0 got="; plyr.bondUnts(2)
      failed := failed + 1
    ENDIF
    IF NOT plyr.mgnHeld(1) THEN
      PRINT "Test 1 PASS  mgnHeld(1)=FALSE"
      passed := passed + 1
    ELSE
      PRINT "Test 1 FAIL  mgnHeld(1) exp=FALSE got=TRUE"
      failed := failed + 1
    ENDIF
    PRINT
RETURN

200 \ ! Test 2: full margin sell
    GOSUB 500
    IF plyr.cashBal = 8000 THEN
      PRINT "Test 2 PASS  cashBal=8000"
      passed := passed + 1
    ELSE
      PRINT "Test 2 FAIL  cashBal exp=8000 got="; plyr.cashBal
      failed := failed + 1
    ENDIF
    IF plyr.marginTot = 0 THEN
      PRINT "Test 2 PASS  marginTot=0"
      passed := passed + 1
    ELSE
      PRINT "Test 2 FAIL  marginTot exp=0 got="; plyr.marginTot
      failed := failed + 1
    ENDIF
    IF plyr.stckShrs(5) = 0 THEN
      PRINT "Test 2 PASS  stckShrs(5)=0"
      passed := passed + 1
    ELSE
      PRINT "Test 2 FAIL  stckShrs(5) exp=0 got="; plyr.stckShrs(5)
      failed := failed + 1
    ENDIF
    IF NOT plyr.mgnHeld(5) THEN
      PRINT "Test 2 PASS  mgnHeld(5)=FALSE"
      passed := passed + 1
    ELSE
      PRINT "Test 2 FAIL  mgnHeld(5) exp=FALSE got=TRUE"
      failed := failed + 1
    ENDIF
    PRINT
RETURN

300 \ ! Test 3: partial margin sell
    GOSUB 500
    IF plyr.cashBal = 5000 THEN
      PRINT "Test 3 PASS  cashBal=5000 (unchanged)"
      passed := passed + 1
    ELSE
      PRINT "Test 3 FAIL  cashBal exp=5000 got="; plyr.cashBal
      failed := failed + 1
    ENDIF
    IF plyr.marginTot = 4000 THEN
      PRINT "Test 3 PASS  marginTot=4000"
      passed := passed + 1
    ELSE
      PRINT "Test 3 FAIL  marginTot exp=4000 got="; plyr.marginTot
      failed := failed + 1
    ENDIF
    IF plyr.stckShrs(5) = 50 THEN
      PRINT "Test 3 PASS  stckShrs(5)=50"
      passed := passed + 1
    ELSE
      PRINT "Test 3 FAIL  stckShrs(5) exp=50 got="; plyr.stckShrs(5)
      failed := failed + 1
    ENDIF
    IF plyr.mgnHeld(5) THEN
      PRINT "Test 3 PASS  mgnHeld(5)=TRUE"
      passed := passed + 1
    ELSE
      PRINT "Test 3 FAIL  mgnHeld(5) exp=TRUE got=FALSE"
      failed := failed + 1
    ENDIF
    PRINT
RETURN

400 \ ! Test 4: pass turn — no changes
    GOSUB 500
    IF plyr.cashBal = 5000 THEN
      PRINT "Test 4 PASS  cashBal=5000 (unchanged)"
      passed := passed + 1
    ELSE
      PRINT "Test 4 FAIL  cashBal exp=5000 got="; plyr.cashBal
      failed := failed + 1
    ENDIF
    IF plyr.marginTot = 0 THEN
      PRINT "Test 4 PASS  marginTot=0 (unchanged)"
      passed := passed + 1
    ELSE
      PRINT "Test 4 FAIL  marginTot exp=0 got="; plyr.marginTot
      failed := failed + 1
    ENDIF
    PRINT
RETURN

500 \ ! Print state for inspection
     PRINT "  cashBal="; plyr.cashBal;
     PRINT "  marginTot="; plyr.marginTot;
     PRINT "  stckShrs(1)="; plyr.stckShrs(1);
     PRINT "  stckShrs(5)="; plyr.stckShrs(5)
     PRINT "  bondUnts(2)="; plyr.bondUnts(2);
     PRINT "  mgnHeld(1)="; plyr.mgnHeld(1);
     PRINT "  mgnHeld(5)="; plyr.mgnHeld(5)
RETURN

900 PRINT "Runtime error "; ERR; " in TSTASLL"
    END

PROCEDURE TSTABUY
(* ============================================================ *)
(* PROCEDURE : TSTABUY                                          *)
(* PURPOSE   : Confirmation test for applyBuys (Task 9.3).     *)
(*             Four scenarios; 13 assertions.                  *)
(*                                                             *)
(*   Scenario A — Cash stock buy (ordPurch=1)                  *)
(*     20 shares Growth Corp @ $100. cost=2000.                *)
(*     cashBal:    5000 -> 3000                                 *)
(*     stckShrs(3): 0   -> 20                                  *)
(*     hadCashPur: FALSE -> TRUE                               *)
(*     marginTot:  0    unchanged                               *)
(*     mgnHeld(3): FALSE unchanged                             *)
(*                                                             *)
(*   Scenario B — Margin stock buy (ordPurch=2)                *)
(*     20 shares Growth Corp @ $100. cost=2000.                *)
(*     cashPay=1000 (50%), mgnPay=1000 (50%).                  *)
(*     cashBal:    5000 -> 4000                                 *)
(*     marginTot:  0    -> 1000                                 *)
(*     mgnHeld(1): FALSE -> TRUE                               *)
(*     stckShrs(1): 0   -> 20                                  *)
(*     hadCashPur: FALSE unchanged (margin does not qualify)   *)
(*                                                             *)
(*   Scenario C — Bond buy                                     *)
(*     1 medium bond, par=5000.                                *)
(*     cashBal:    5000 -> 0                                   *)
(*     bondUnts(2): 0   -> 1                                   *)
(*                                                             *)
(*   Scenario D — No-op (ordCnt=0)                            *)
(*     No orders. All fields unchanged.                        *)
(*     cashBal:    5000 unchanged                              *)
(*                                                             *)
(* SIDE EFX  : Prints PASS/FAIL per assertion. Prints summary. *)
(* ============================================================ *)
! Line exceeds 79 chars; TYPE statement requires single line.
TYPE PlyrRec = plyrName:STRING[20];plyrType,aiTier:BYTE;cashBal,marginTot:INTEGER;isBankrupt,hadCashPur:BOOLEAN;stckShrs(9):INTEGER;mgnHeld(9):BOOLEAN;bondUnts(3):INTEGER
TYPE MktState = stckPrice(9):INTEGER;divSuspnd(9):BOOLEAN

DIM plyr        : PlyrRec
DIM mkt         : MktState
DIM ordType(12) : INTEGER
DIM ordId(12)   : INTEGER
DIM ordQty(12)  : INTEGER
DIM ordPurch(12): INTEGER
DIM ordCnt      : INTEGER
DIM fails       : INTEGER
DIM i           : INTEGER

ON ERROR GOTO 900

fails := 0

! ============================================================
! Scenario A — Cash stock buy
! ordType=1, ordId=3 (Pioneer Mut), ordQty=20, ordPurch=1
! stckPrice(3)=100 (initMkt default)
! cost = 20 * 100 = 2000
! Expected: cashBal=3000, stckShrs(3)=20,
!           hadCashPur=TRUE, marginTot=0, mgnHeld(3)=FALSE
! ============================================================
PRINT "--- Scenario A: cash stock buy ---"

RUN initPlayer(plyr)
RUN initMkt(mkt)

FOR i := 1 TO 12
  ordType(i)  := 0
  ordId(i)    := 0
  ordQty(i)   := 0
  ordPurch(i) := 0
NEXT i

ordType(1)  := 1 \ ! STOCK
ordId(1)    := 3 \ ! Pioneer Mut; price=100 from initMkt
ordQty(1)   := 20
ordPurch(1) := 1 \ ! CASH
ordCnt      := 1

RUN applyBuys(plyr, mkt, ordType, ordId, ordQty, ordPurch, ordCnt)

IF plyr.cashBal = 3000 THEN
  PRINT "  A1 PASS  cashBal=3000"
ELSE
  PRINT "  A1 FAIL  cashBal="; plyr.cashBal; " (expected 3000)"
  fails := fails + 1
ENDIF

IF plyr.stckShrs(3) = 20 THEN
  PRINT "  A2 PASS  stckShrs(3)=20"
ELSE
  PRINT "  A2 FAIL  stckShrs(3)="; plyr.stckShrs(3); " (expected 20)"
  fails := fails + 1
ENDIF

IF plyr.hadCashPur = TRUE THEN
  PRINT "  A3 PASS  hadCashPur=TRUE"
ELSE
  PRINT "  A3 FAIL  hadCashPur=FALSE (expected TRUE)"
  fails := fails + 1
ENDIF

IF plyr.marginTot = 0 THEN
  PRINT "  A4 PASS  marginTot=0"
ELSE
  PRINT "  A4 FAIL  marginTot="; plyr.marginTot; " (expected 0)"
  fails := fails + 1
ENDIF

IF plyr.mgnHeld(3) = FALSE THEN
  PRINT "  A5 PASS  mgnHeld(3)=FALSE"
ELSE
  PRINT "  A5 FAIL  mgnHeld(3)=TRUE (expected FALSE)"
  fails := fails + 1
ENDIF

! ============================================================
! Scenario B — Margin stock buy
! ordType=1, ordId=1 (Growth Corp), ordQty=20, ordPurch=2
! stckPrice(1)=100 (initMkt default)
! cost=2000; cashPay=1000; mgnPay=1000
! Expected: cashBal=4000, marginTot=1000, mgnHeld(1)=TRUE,
!           stckShrs(1)=20, hadCashPur=FALSE
! ============================================================
PRINT "--- Scenario B: margin stock buy ---"

RUN initPlayer(plyr)
RUN initMkt(mkt)

FOR i := 1 TO 12
  ordType(i)  := 0
  ordId(i)    := 0
  ordQty(i)   := 0
  ordPurch(i) := 0
NEXT i

ordType(1)  := 1 \ ! STOCK
ordId(1)    := 1 \ ! Growth Corp; price=100 from initMkt
ordQty(1)   := 20
ordPurch(1) := 2 \ ! MARGIN
ordCnt      := 1

RUN applyBuys(plyr, mkt, ordType, ordId, ordQty, ordPurch, ordCnt)

IF plyr.cashBal = 4000 THEN
  PRINT "  B1 PASS  cashBal=4000"
ELSE
  PRINT "  B1 FAIL  cashBal="; plyr.cashBal; " (expected 4000)"
  fails := fails + 1
ENDIF

IF plyr.marginTot = 1000 THEN
  PRINT "  B2 PASS  marginTot=1000"
ELSE
  PRINT "  B2 FAIL  marginTot="; plyr.marginTot; " (expected 1000)"
  fails := fails + 1
ENDIF

IF plyr.mgnHeld(1) = TRUE THEN
  PRINT "  B3 PASS  mgnHeld(1)=TRUE"
ELSE
  PRINT "  B3 FAIL  mgnHeld(1)=FALSE (expected TRUE)"
  fails := fails + 1
ENDIF

IF plyr.stckShrs(1) = 20 THEN
  PRINT "  B4 PASS  stckShrs(1)=20"
ELSE
  PRINT "  B4 FAIL  stckShrs(1)="; plyr.stckShrs(1); " (expected 20)"
  fails := fails + 1
ENDIF

IF plyr.hadCashPur = FALSE THEN
  PRINT "  B5 PASS  hadCashPur=FALSE"
ELSE
  PRINT "  B5 FAIL  hadCashPur=TRUE (expected FALSE)"
  fails := fails + 1
ENDIF

! ============================================================
! Scenario C — Bond buy
! ordType=2, ordId=2 (medium; par=5000), ordQty=1, ordPurch=1
! Expected: cashBal=0, bondUnts(2)=1
! ============================================================
PRINT "--- Scenario C: bond buy ---"

RUN initPlayer(plyr)
RUN initMkt(mkt)

FOR i := 1 TO 12
  ordType(i)  := 0
  ordId(i)    := 0
  ordQty(i)   := 0
  ordPurch(i) := 0
NEXT i

ordType(1)  := 2 \ ! BOND
ordId(1)    := 2 \ ! medium; bPar(2)=5000
ordQty(1)   := 1
ordPurch(1) := 1 \ ! CASH (bonds always cash)
ordCnt      := 1

RUN applyBuys(plyr, mkt, ordType, ordId, ordQty, ordPurch, ordCnt)

IF plyr.cashBal = 0 THEN
  PRINT "  C1 PASS  cashBal=0"
ELSE
  PRINT "  C1 FAIL  cashBal="; plyr.cashBal; " (expected 0)"
  fails := fails + 1
ENDIF

IF plyr.bondUnts(2) = 1 THEN
  PRINT "  C2 PASS  bondUnts(2)=1"
ELSE
  PRINT "  C2 FAIL  bondUnts(2)="; plyr.bondUnts(2); " (expected 1)"
  fails := fails + 1
ENDIF

! ============================================================
! Scenario D — No-op: ordCnt=0
! initPlayer sets cashBal=5000. Nothing should change.
! Expected: cashBal=5000 (spot check)
! ============================================================
PRINT "--- Scenario D: no-op (ordCnt=0) ---"

RUN initPlayer(plyr)
RUN initMkt(mkt)

ordCnt := 0

RUN applyBuys(plyr, mkt, ordType, ordId, ordQty, ordPurch, ordCnt)

IF plyr.cashBal = 5000 THEN
  PRINT "  D1 PASS  cashBal=5000"
ELSE
  PRINT "  D1 FAIL  cashBal="; plyr.cashBal; " (expected 5000)"
  fails := fails + 1
ENDIF

! ============================================================
! Summary
! ============================================================
PRINT
PRINT "TSTABUY: "; 13 - fails; " of 13 passed."
IF fails = 0 THEN
  PRINT "ALL PASS"
ELSE
  PRINT fails; " FAILURE(S)"
ENDIF

END

900 PRINT "TSTABUY error ("; ERR; ")"
END

PROCEDURE TSTBUY
(* ============================================================ *)
(* PROCEDURE : TSTBUY                                          *)
(* PURPOSE   : Confirmation test for scrBuy (Task 9.3).        *)
(*             Tests are interactive: scrBuy uses INPUT and    *)
(*             cannot be driven without terminal input.        *)
(*             Each subtest prints its setup, required input   *)
(*             sequence, and expected outcome. The tester      *)
(*             follows the sequence and then confirms the      *)
(*             machine-checked assertions match.               *)
(*                                                             *)
(*             Subtest 1 — margin ineligible, cash purchases   *)
(*               Setup: cashBal=3000, mgnElig=FALSE            *)
(*               Input sequence:                               *)
(*                 Menu: 1 (Enter orders)                      *)
(*                 Growth Corp qty: 20  purch type: N/A (cash) *)
(*                 Verify rejection of qty=20 if cost rejected,*)
(*                 confirm qty accepted (cost=$2000)           *)
(*                 Growth Corp qty: 20 again → reject          *)
(*                   (simCash=1000 < 2000)                     *)
(*                 Growth Corp qty: 0 (skip)                   *)
(*                 [Stocks 2-9: Enter/skip]                    *)
(*                 Small bond qty: 1 (cost=$1000, accepted)    *)
(*                 Med/Large bond: 0/Enter                     *)
(*                 Summary: 1 (Confirm)                        *)
(*               Checks: ordCnt=2, ord1 stock 1 qty 20 cash,  *)
(*                 ord2 bond 1 qty 1, mgnRepay=0, action=1,   *)
(*                 simCash after=0                            *)
(*                                                             *)
(*             Subtest 2 — pass turn                           *)
(*               Setup: cashBal=5000, mgnElig=FALSE            *)
(*               Input sequence: Menu: 2 (Pass)                *)
(*               Checks: ordCnt=0, action=2, mgnRepay=0        *)
(*                                                             *)
(*             Subtest 3 — margin eligible, one margin buy     *)
(*               Setup: cashBal=4000, marginTot=1000,          *)
(*                 mgnElig=TRUE, mgnYrOk=TRUE                  *)
(*               Input sequence:                               *)
(*                 Menu: 1 (Enter orders)                      *)
(*                 Growth Corp qty: 20, type: 2 (Margin)       *)
(*                   cost=50% of 20*100=$1000 cash             *)
(*                 [remaining stocks: 0/Enter]                 *)
(*                 [bonds: 0/Enter]                            *)
(*                 Summary: 1 (Confirm)                        *)
(*               Checks: ordCnt=1, ord1 stock 1 qty 20        *)
(*                 ordPurch=2 (MARGIN), mgnRepay=0, action=1   *)
(*                                                             *)
(*             Subtest 4 — margin repayment then buy           *)
(*               Setup: cashBal=5000, marginTot=2000,          *)
(*                 mgnElig=TRUE, mgnYrOk=TRUE                  *)
(*               Input sequence:                               *)
(*                 Menu: 2 (Repay margin)                      *)
(*                 scrMgnRepay: enter 1000                     *)
(*                 Menu (redisplay): 1 (Enter orders)          *)
(*                 [all stocks/bonds: 0/Enter]                 *)
(*                 Summary: 1 (Confirm)                        *)
(*               Checks: mgnRepay=1000, ordCnt=0, action=1     *)
(* PARAMS    : none                                            *)
(* SIDE EFX  : Calls scrBuy which clears screen and uses INPUT.*)
(* ============================================================ *)
! Line exceeds 79 chars; TYPE statement requires single line.
TYPE PlyrRec = plyrName:STRING[20];plyrType,aiTier:BYTE;cashBal,marginTot:INTEGER;isBankrupt,hadCashPur:BOOLEAN;stckShrs(9):INTEGER;mgnHeld(9):BOOLEAN;bondUnts(3):INTEGER
TYPE MktState = stckPrice(9):INTEGER;divSuspnd(9):BOOLEAN
DIM plyr        : PlyrRec
DIM mkt         : MktState
DIM ordType(12) : INTEGER
DIM ordId(12)   : INTEGER
DIM ordQty(12)  : INTEGER
DIM ordPurch(12): INTEGER
DIM ordCnt      : INTEGER
DIM mgnRepay    : INTEGER
DIM action      : BYTE
DIM passed      : INTEGER
DIM failed      : INTEGER
DIM s           : INTEGER
DIM i           : INTEGER

ON ERROR GOTO 900

passed := 0
failed := 0

PRINT "=== TSTBUY  Task 9.3 ==="
PRINT "Interactive test: follow each input sequence exactly."
PRINT

! ---- Subtest 1: margin ineligible, cash buys ----------------
RUN initPlayer(plyr)
RUN initMkt(mkt)
plyr.plyrName    := "ALICE"
plyr.cashBal     := 3000
plyr.hadCashPur  := FALSE
FOR s := 1 TO 9
  mkt.stckPrice(s) := 100
NEXT s

PRINT "--- Subtest 1: mgnElig=FALSE, cashBal=3000 ---"
PRINT "Input sequence:"
PRINT "  Menu: 1 (Enter orders)"
PRINT "  Growth Corp qty: 20  [cost=2000, accepted, cash type]"
PRINT "  Metro Props qty: 20  [expect reject: simCash=1000]"
PRINT "  Metro Props qty: 0   [skip]"
PRINT "  Stocks 2-9: Enter (skip each)"
PRINT "  Small bond qty: 1    [cost=1000, accepted]"
PRINT "  Med/Large bond: Enter (skip each)"
PRINT "  Summary: 1 (Confirm)"
PRINT
INPUT "Press Enter to launch Subtest 1...", plyr.plyrName
plyr.plyrName := "ALICE"

! Line exceeds 79 chars; RUN parameter list cannot be split.
RUN scrBuy(1, plyr, mkt, FALSE, TRUE, ordType, ordId, ordQty, ordPurch, ordCnt, mgnRepay, action)

GOSUB 100

! ---- Subtest 2: pass turn -----------------------------------
RUN initPlayer(plyr)
RUN initMkt(mkt)
plyr.plyrName   := "BOB"
plyr.cashBal    := 5000
plyr.hadCashPur := FALSE
FOR s := 1 TO 9
  mkt.stckPrice(s) := 100
NEXT s

PRINT "--- Subtest 2: pass turn ---"
PRINT "Input sequence:"
PRINT "  Menu: 2 (Pass)"
PRINT
INPUT "Press Enter to launch Subtest 2...", plyr.plyrName
plyr.plyrName := "BOB"

! Line exceeds 79 chars; RUN parameter list cannot be split.
RUN scrBuy(3, plyr, mkt, FALSE, TRUE, ordType, ordId, ordQty, ordPurch, ordCnt, mgnRepay, action)

GOSUB 200

! ---- Subtest 3: margin eligible, margin buy -----------------
RUN initPlayer(plyr)
RUN initMkt(mkt)
plyr.plyrName   := "CAROL"
plyr.cashBal    := 4000
plyr.marginTot  := 1000
plyr.hadCashPur := TRUE
FOR s := 1 TO 9
  mkt.stckPrice(s) := 100
NEXT s

PRINT "--- Subtest 3: mgnElig=TRUE, margin buy Growth Corp ---"
PRINT "Input sequence:"
PRINT "  Menu: 1 (Enter orders)"
PRINT "  Growth Corp qty: 20  type: 2 (Margin)  [cash cost=$1000]"
PRINT "  Stocks 2-9: Enter (skip each)"
PRINT "  All bonds: Enter (skip each)"
PRINT "  Summary: 1 (Confirm)"
PRINT
INPUT "Press Enter to launch Subtest 3...", plyr.plyrName
plyr.plyrName := "CAROL"

! Line exceeds 79 chars; RUN parameter list cannot be split.
RUN scrBuy(2, plyr, mkt, TRUE, TRUE, ordType, ordId, ordQty, ordPurch, ordCnt, mgnRepay, action)

GOSUB 300

! ---- Subtest 4: repayment then enter orders -----------------
RUN initPlayer(plyr)
RUN initMkt(mkt)
plyr.plyrName   := "DAVE"
plyr.cashBal    := 5000
plyr.marginTot  := 2000
plyr.hadCashPur := TRUE
FOR s := 1 TO 9
  mkt.stckPrice(s) := 100
NEXT s

PRINT "--- Subtest 4: repay $1000 then enter no buy orders ---"
PRINT "Input sequence:"
PRINT "  Menu: 2 (Repay margin)"
PRINT "  scrMgnRepay: enter 1000"
PRINT "  Menu (redisplay): 1 (Enter orders)"
PRINT "  All stocks/bonds: Enter (skip each)"
PRINT "  Summary: 1 (Confirm)"
PRINT
INPUT "Press Enter to launch Subtest 4...", plyr.plyrName
plyr.plyrName := "DAVE"

! Line exceeds 79 chars; RUN parameter list cannot be split.
RUN scrBuy(5, plyr, mkt, TRUE, TRUE, ordType, ordId, ordQty, ordPurch, ordCnt, mgnRepay, action)

GOSUB 400

PRINT
PRINT "Results: "; passed; " passed, "; failed; " failed."
END

100 \ ! Subtest 1 assertions
    PRINT "--- Subtest 1 results ---"
    IF ordCnt = 2 THEN
      PRINT "PASS  ordCnt=2"
      passed := passed + 1
    ELSE
      PRINT "FAIL  ordCnt exp=2 got="; ordCnt
      failed := failed + 1
    ENDIF
    IF ordType(1) = 1 AND ordId(1) = 1 AND ordQty(1) = 20 THEN
      IF ordPurch(1) = 1 THEN
        PRINT "PASS  ord1: stock 1 qty=20 CASH"
        passed := passed + 1
      ELSE
        PRINT "FAIL  ord1 ordPurch exp=1 got="; ordPurch(1)
        failed := failed + 1
      ENDIF
    ELSE
      PRINT "FAIL  ord1 exp stock1 qty20 got type="; ordType(1);
      PRINT " id="; ordId(1); " qty="; ordQty(1)
      failed := failed + 1
    ENDIF
    IF ordType(2) = 2 AND ordId(2) = 1 AND ordQty(2) = 1 THEN
      PRINT "PASS  ord2: bond 1 qty=1"
      passed := passed + 1
    ELSE
      PRINT "FAIL  ord2 exp bond1 qty1 got type="; ordType(2);
      PRINT " id="; ordId(2); " qty="; ordQty(2)
      failed := failed + 1
    ENDIF
    IF mgnRepay = 0 THEN
      PRINT "PASS  mgnRepay=0"
      passed := passed + 1
    ELSE
      PRINT "FAIL  mgnRepay exp=0 got="; mgnRepay
      failed := failed + 1
    ENDIF
    IF action = 1 THEN
      PRINT "PASS  action=1 (CONFIRM)"
      passed := passed + 1
    ELSE
      PRINT "FAIL  action exp=1 got="; action
      failed := failed + 1
    ENDIF
    PRINT
RETURN

200 \ ! Subtest 2 assertions
    PRINT "--- Subtest 2 results ---"
    IF ordCnt = 0 THEN
      PRINT "PASS  ordCnt=0"
      passed := passed + 1
    ELSE
      PRINT "FAIL  ordCnt exp=0 got="; ordCnt
      failed := failed + 1
    ENDIF
    IF action = 2 THEN
      PRINT "PASS  action=2 (PASS)"
      passed := passed + 1
    ELSE
      PRINT "FAIL  action exp=2 got="; action
      failed := failed + 1
    ENDIF
    IF mgnRepay = 0 THEN
      PRINT "PASS  mgnRepay=0"
      passed := passed + 1
    ELSE
      PRINT "FAIL  mgnRepay exp=0 got="; mgnRepay
      failed := failed + 1
    ENDIF
    PRINT
RETURN

300 \ ! Subtest 3 assertions
    PRINT "--- Subtest 3 results ---"
    IF ordCnt = 1 THEN
      PRINT "PASS  ordCnt=1"
      passed := passed + 1
    ELSE
      PRINT "FAIL  ordCnt exp=1 got="; ordCnt
      failed := failed + 1
    ENDIF
    IF ordType(1) = 1 AND ordId(1) = 1 AND ordQty(1) = 20 THEN
      PRINT "PASS  ord1: stock 1 qty=20"
      passed := passed + 1
    ELSE
      PRINT "FAIL  ord1 exp stock1 qty20 got type="; ordType(1);
      PRINT " id="; ordId(1); " qty="; ordQty(1)
      failed := failed + 1
    ENDIF
    IF ordPurch(1) = 2 THEN
      PRINT "PASS  ordPurch(1)=2 (MARGIN)"
      passed := passed + 1
    ELSE
      PRINT "FAIL  ordPurch(1) exp=2 got="; ordPurch(1)
      failed := failed + 1
    ENDIF
    IF mgnRepay = 0 THEN
      PRINT "PASS  mgnRepay=0"
      passed := passed + 1
    ELSE
      PRINT "FAIL  mgnRepay exp=0 got="; mgnRepay
      failed := failed + 1
    ENDIF
    IF action = 1 THEN
      PRINT "PASS  action=1 (CONFIRM)"
      passed := passed + 1
    ELSE
      PRINT "FAIL  action exp=1 got="; action
      failed := failed + 1
    ENDIF
    PRINT
RETURN

400 \ ! Subtest 4 assertions
    PRINT "--- Subtest 4 results ---"
    IF mgnRepay = 1000 THEN
      PRINT "PASS  mgnRepay=1000"
      passed := passed + 1
    ELSE
      PRINT "FAIL  mgnRepay exp=1000 got="; mgnRepay
      failed := failed + 1
    ENDIF
    IF ordCnt = 0 THEN
      PRINT "PASS  ordCnt=0"
      passed := passed + 1
    ELSE
      PRINT "FAIL  ordCnt exp=0 got="; ordCnt
      failed := failed + 1
    ENDIF
    IF action = 1 THEN
      PRINT "PASS  action=1 (CONFIRM)"
      passed := passed + 1
    ELSE
      PRINT "FAIL  action exp=1 got="; action
      failed := failed + 1
    ENDIF
    PRINT
RETURN

900 PRINT "Runtime error "; ERR; " in TSTBUY"
    END

PROCEDURE TSTMGNRPY
(* ============================================================ *)
(* PROCEDURE : TSTMGNRPY                                        *)
(* PURPOSE   : Confirmation tests for scrMgnRepay (Task 9.4).  *)
(*             Tests are interactive: scrMgnRepay uses INPUT   *)
(*             and cannot be driven without terminal input.    *)
(*             Each subtest prints its required input sequence *)
(*             and expected outcome. Assertions are machine-   *)
(*             checked on the returned amtToRpy value.         *)
(*                                                             *)
(*             Subtest 1 — rejection then acceptance           *)
(*               Setup: marginTot=2000, cashBal=800            *)
(*                 maxRpy=800 (MIN(2000,800))                  *)
(*               Input sequence:                               *)
(*                 Enter 900  [expect rejection: > maxRpy]     *)
(*                 Enter 500  [expect accepted]                *)
(*               Checks: amtToRpy=500                          *)
(*                 implied cashBal=300, marginTot=1500          *)
(*                 (caller applies; scrMgnRepay does not)       *)
(*                                                             *)
(*             Subtest 2 — zero entry accepted                 *)
(*               Setup: marginTot=1500, cashBal=3000           *)
(*                 maxRpy=1500                                 *)
(*               Input sequence:                               *)
(*                 Enter 0    [expect accepted]                *)
(*               Checks: amtToRpy=0                            *)
(*                                                             *)
(*             Subtest 3 — bare Enter treated as 0             *)
(*               Setup: marginTot=500, cashBal=1000            *)
(*                 maxRpy=500                                  *)
(*               Input sequence:                               *)
(*                 Press Enter with no input                   *)
(*               Checks: amtToRpy=0                            *)
(*                                                             *)
(*             Subtest 4 — exact max accepted                  *)
(*               Setup: marginTot=1000, cashBal=2000           *)
(*                 maxRpy=1000                                 *)
(*               Input sequence:                               *)
(*                 Enter 1000 [expect accepted: = maxRpy]      *)
(*               Checks: amtToRpy=1000                         *)
(*                                                             *)
(*             Subtest 5 — non-numeric rejection then accept   *)
(*               Setup: marginTot=500, cashBal=1000            *)
(*                 maxRpy=500                                  *)
(*               Input sequence:                               *)
(*                 Enter "abc"  [expect rejection: non-numeric]*)
(*                 Enter 250    [expect accepted]              *)
(*               Checks: amtToRpy=250                          *)
(* PARAMS    : none                                            *)
(* SIDE EFX  : Calls scrMgnRepay which clears screen and uses  *)
(*             INPUT. No file I/O. No plyr modification.       *)
(* ============================================================ *)
DIM amtToRpy : INTEGER
DIM passed   : INTEGER
DIM failed   : INTEGER
DIM pauseIn  : STRING[1]

ON ERROR GOTO 900

passed := 0
failed := 0

PRINT "=== TSTMGNRPY  Task 9.4 ==="
PRINT "Interactive test: follow each input sequence exactly."
PRINT

! ---- Subtest 1: rejection (900 > maxRpy=800) then 500 ------
PRINT "--- Subtest 1: marginTot=2000 cashBal=800 maxRpy=800 ---"
PRINT "Input sequence:"
PRINT "  Enter 900  [expect: Invalid, exceeds max]"
PRINT "  Enter 500  [expect: accepted]"
PRINT
INPUT "Press Enter to launch Subtest 1...", pauseIn
amtToRpy := 0

RUN scrMgnRepay(2000, 800, 800, amtToRpy)
GOSUB 100

! ---- Subtest 2: zero accepted ------------------------------------
PRINT "--- Subtest 2: marginTot=1500 cashBal=3000 maxRpy=1500 ---"
PRINT "Input sequence:"
PRINT "  Enter 0  [expect: accepted, no repayment]"
PRINT
INPUT "Press Enter to launch Subtest 2...", pauseIn
amtToRpy := 0

RUN scrMgnRepay(1500, 3000, 1500, amtToRpy)
GOSUB 200

! ---- Subtest 3: bare Enter = 0 -----------------------------------
PRINT "--- Subtest 3: marginTot=500 cashBal=1000 maxRpy=500 ---"
PRINT "Input sequence:"
PRINT "  Press Enter with no input  [expect: 0, no repayment]"
PRINT
INPUT "Press Enter to launch Subtest 3...", pauseIn
amtToRpy := 0

RUN scrMgnRepay(500, 1000, 500, amtToRpy)
GOSUB 300

! ---- Subtest 4: exact max accepted --------------------------------
PRINT "--- Subtest 4: marginTot=1000 cashBal=2000 maxRpy=1000 ---"
PRINT "Input sequence:"
PRINT "  Enter 1000  [expect: accepted, = maxRpy]"
PRINT
INPUT "Press Enter to launch Subtest 4...", pauseIn
amtToRpy := 0

RUN scrMgnRepay(1000, 2000, 1000, amtToRpy)
GOSUB 400

! ---- Subtest 5: non-numeric then valid ---------------------------
PRINT "--- Subtest 5: marginTot=500 cashBal=1000 maxRpy=500 ---"
PRINT "Input sequence:"
PRINT "  Enter abc  [expect: Invalid, not a number]"
PRINT "  Enter 250  [expect: accepted]"
PRINT
INPUT "Press Enter to launch Subtest 5...", pauseIn
amtToRpy := 0

RUN scrMgnRepay(500, 1000, 500, amtToRpy)
GOSUB 500

PRINT
PRINT "Results: "; passed; " passed, "; failed; " failed."
END

100 \ ! Subtest 1: expect amtToRpy=500
    IF amtToRpy = 500 THEN
      PRINT "PASS  amtToRpy=500"
      passed := passed + 1
    ELSE
      PRINT "FAIL  amtToRpy exp=500 got="; amtToRpy
      failed := failed + 1
    ENDIF
    PRINT
RETURN

200 \ ! Subtest 2: expect amtToRpy=0
    IF amtToRpy = 0 THEN
      PRINT "PASS  amtToRpy=0 (no repayment)"
      passed := passed + 1
    ELSE
      PRINT "FAIL  amtToRpy exp=0 got="; amtToRpy
      failed := failed + 1
    ENDIF
    PRINT
RETURN

300 \ ! Subtest 3: expect amtToRpy=0
    IF amtToRpy = 0 THEN
      PRINT "PASS  amtToRpy=0 (bare Enter)"
      passed := passed + 1
    ELSE
      PRINT "FAIL  amtToRpy exp=0 got="; amtToRpy
      failed := failed + 1
    ENDIF
    PRINT
RETURN

400 \ ! Subtest 4: expect amtToRpy=1000
    IF amtToRpy = 1000 THEN
      PRINT "PASS  amtToRpy=1000 (exact max)"
      passed := passed + 1
    ELSE
      PRINT "FAIL  amtToRpy exp=1000 got="; amtToRpy
      failed := failed + 1
    ENDIF
    PRINT
RETURN

500 \ ! Subtest 5: expect amtToRpy=250
    IF amtToRpy = 250 THEN
      PRINT "PASS  amtToRpy=250"
      passed := passed + 1
    ELSE
      PRINT "FAIL  amtToRpy exp=250 got="; amtToRpy
      failed := failed + 1
    ENDIF
    PRINT
RETURN

900 PRINT "Runtime error "; ERR; " in TSTMGNRPY"
    END

PROCEDURE TSTAITURN
(* ============================================================ *)
(* PROCEDURE : TSTAITURN                                        *)
(* PURPOSE   : Confirmation tests for scrAITurn (Task 9.5).    *)
(*             scrAITurn is display-only. Visual verification  *)
(*             of rendered output is the primary check.        *)
(*             Machine assertions confirm:                     *)
(*               - Input arrays are unmodified after the call  *)
(*               - Procedure returns without error             *)
(*                                                             *)
(*             Subtest 1 — spec confirmation case              *)
(*               Sell 50 Stryker, buy 20 Pioneer Mut,          *)
(*               repay $500 margin. Phase=BUY.                 *)
(*               Expected display (tester verifies):           *)
(*                 COMPUTER TURN  BUY PHASE                    *)
(*                 Player: HAL                                 *)
(*                 SELL  50  Stryker Drlg                      *)
(*                 BUY   20  Pioneer Mut                       *)
(*                 REPAY $500 margin                           *)
(*               Machine checks: decAct/Id/Type/Qty unchanged  *)
(*                                                             *)
(*             Subtest 2 — all PASS (no action this phase)     *)
(*               decCnt=3, all entries decAct=4 (PASS).        *)
(*               Expected display:                             *)
(*                 (no action this phase)                      *)
(*                                                             *)
(*             Subtest 3 — SELL phase, bond sell only          *)
(*               Sell 1 medium bond. Phase=SELL.               *)
(*               Expected display:                             *)
(*                 COMPUTER TURN  SELL PHASE                   *)
(*                 SELL  1  $5000 bond                         *)
(*                                                             *)
(*             Subtest 4 — decCnt=0 (empty decision set)       *)
(*               Expected display:                             *)
(*                 (no action this phase)                      *)
(* PARAMS    : none                                            *)
(* SIDE EFX  : Calls scrAITurn which clears screen and waits   *)
(*             for keypress at end of each subtest.            *)
(* ============================================================ *)
DIM decAct(12)  : BYTE
DIM decType(12) : INTEGER
DIM decId(12)   : INTEGER
DIM decQty(12)  : INTEGER
DIM decCnt      : INTEGER
DIM passed      : INTEGER
DIM failed      : INTEGER
DIM i           : INTEGER

ON ERROR GOTO 900

passed := 0
failed := 0

PRINT "=== TSTAITURN  Task 9.5 ==="
PRINT "Visual verification required for each subtest."
PRINT

! ---- Subtest 1: spec confirmation case ----------------------
! Sell 50 Stryker (stock 5), buy 20 Pioneer Mut (stock 3),
! repay $500 margin. Phase=BUY.
GOSUB 500
decAct(1)  := 1 \ decType(1) := 1 \ decId(1) := 5 \ decQty(1) := 50
decAct(2)  := 2 \ decType(2) := 1 \ decId(2) := 3 \ decQty(2) := 20
decAct(3)  := 3 \ decType(3) := 0 \ decId(3) := 0 \ decQty(3) := 500
decCnt     := 3

PRINT "--- Subtest 1: sell Stryker + buy Pioneer + repay ---"
PRINT "Expected: SELL 50 Stryker Drlg, BUY 20 Pioneer Mut,"
PRINT "          REPAY $500 margin.  Phase header: BUY PHASE."
PRINT

RUN scrAITurn("HAL", 2, decAct, decType, decId, decQty, decCnt)
GOSUB 100

! ---- Subtest 2: all PASS ------------------------------------
GOSUB 500
decAct(1)  := 4 \ decType(1) := 1 \ decId(1) := 5 \ decQty(1) := 0
decAct(2)  := 4 \ decType(2) := 2 \ decId(2) := 1 \ decQty(2) := 0
decAct(3)  := 4 \ decType(3) := 1 \ decId(3) := 3 \ decQty(3) := 0
decCnt     := 3

PRINT "--- Subtest 2: all PASS ---"
PRINT "Expected: (no action this phase).  Phase header: SELL PHASE."
PRINT

RUN scrAITurn("HAL", 1, decAct, decType, decId, decQty, decCnt)
GOSUB 200

! ---- Subtest 3: SELL phase, bond sell only ------------------
GOSUB 500
decAct(1)  := 1 \ decType(1) := 2 \ decId(1) := 2 \ decQty(1) := 1
decCnt     := 1

PRINT "--- Subtest 3: sell 1 medium bond ---"
PRINT "Expected: SELL 1 $5000 bond.  Phase header: SELL PHASE."
PRINT

RUN scrAITurn("HAL", 1, decAct, decType, decId, decQty, decCnt)
GOSUB 300

! ---- Subtest 4: empty decision set -------------------------
GOSUB 500
decCnt := 0

PRINT "--- Subtest 4: decCnt=0 ---"
PRINT "Expected: (no action this phase)."
PRINT

RUN scrAITurn("HAL", 2, decAct, decType, decId, decQty, decCnt)
GOSUB 400

PRINT
PRINT "Results: "; passed; " passed, "; failed; " failed."
END

100 \ ! Subtest 1: machine checks — arrays unmodified
    PRINT "--- Subtest 1 machine checks ---"
    IF decAct(1) = 1 AND decType(1) = 1 AND decId(1) = 5 THEN
      IF decQty(1) = 50 THEN
        PRINT "PASS  dec(1) unmodified (SELL stock 5 qty 50)"
        passed := passed + 1
      ELSE
        PRINT "FAIL  dec(1).qty modified; exp=50 got="; decQty(1)
        failed := failed + 1
      ENDIF
    ELSE
      PRINT "FAIL  dec(1) act/type/id modified"
      failed := failed + 1
    ENDIF
    IF decAct(2) = 2 AND decId(2) = 3 AND decQty(2) = 20 THEN
      PRINT "PASS  dec(2) unmodified (BUY stock 3 qty 20)"
      passed := passed + 1
    ELSE
      PRINT "FAIL  dec(2) modified"
      failed := failed + 1
    ENDIF
    IF decAct(3) = 3 AND decQty(3) = 500 THEN
      PRINT "PASS  dec(3) unmodified (REPAY 500)"
      passed := passed + 1
    ELSE
      PRINT "FAIL  dec(3) modified"
      failed := failed + 1
    ENDIF
    IF decCnt = 3 THEN
      PRINT "PASS  decCnt unmodified (3)"
      passed := passed + 1
    ELSE
      PRINT "FAIL  decCnt exp=3 got="; decCnt
      failed := failed + 1
    ENDIF
    PRINT
RETURN

200 \ ! Subtest 2: machine checks — arrays unmodified
    PRINT "--- Subtest 2 machine checks ---"
    IF decAct(1) = 4 AND decAct(2) = 4 AND decAct(3) = 4 THEN
      PRINT "PASS  all decAct=4 (PASS) unmodified"
      passed := passed + 1
    ELSE
      PRINT "FAIL  decAct entries modified"
      failed := failed + 1
    ENDIF
    IF decCnt = 3 THEN
      PRINT "PASS  decCnt unmodified (3)"
      passed := passed + 1
    ELSE
      PRINT "FAIL  decCnt exp=3 got="; decCnt
      failed := failed + 1
    ENDIF
    PRINT
RETURN

300 \ ! Subtest 3: machine checks — arrays unmodified
    PRINT "--- Subtest 3 machine checks ---"
    IF decAct(1) = 1 AND decType(1) = 2 AND decId(1) = 2 THEN
      IF decQty(1) = 1 THEN
        PRINT "PASS  dec(1) unmodified (SELL bond 2 qty 1)"
        passed := passed + 1
      ELSE
        PRINT "FAIL  dec(1).qty modified; exp=1 got="; decQty(1)
        failed := failed + 1
      ENDIF
    ELSE
      PRINT "FAIL  dec(1) act/type/id modified"
      failed := failed + 1
    ENDIF
    IF decCnt = 1 THEN
      PRINT "PASS  decCnt unmodified (1)"
      passed := passed + 1
    ELSE
      PRINT "FAIL  decCnt exp=1 got="; decCnt
      failed := failed + 1
    ENDIF
    PRINT
RETURN

400 \ ! Subtest 4: machine checks
    PRINT "--- Subtest 4 machine checks ---"
    IF decCnt = 0 THEN
      PRINT "PASS  decCnt unmodified (0)"
      passed := passed + 1
    ELSE
      PRINT "FAIL  decCnt exp=0 got="; decCnt
      failed := failed + 1
    ENDIF
    PRINT
RETURN

500 \ ! Reset all decision arrays to zero
    FOR i := 1 TO 12
      decAct(i)  := 0
      decType(i) := 0
      decId(i)   := 0
      decQty(i)  := 0
    NEXT i
    decCnt := 0
RETURN

900 PRINT "Runtime error "; ERR; " in TSTAITURN"
    END

PROCEDURE TSTMGNCALL
(* ============================================================ *)
(* PROCEDURE : TSTMGNCALL                                       *)
(* PURPOSE   : Confirmation tests for scrMgnCall (Task 10.1).  *)
(*             scrMgnCall is display-only. Visual verification *)
(*             of rendered output is the primary check.        *)
(*             Machine assertions confirm:                     *)
(*               - All input params unmodified after call      *)
(*               - Procedure returns without runtime error     *)
(*                                                             *)
(*             Subtest 1 — spec confirmation case              *)
(*               Stryker at $22, callPrice=$25, amtDue=$3000.  *)
(*               Expected display (tester verifies):           *)
(*                 *** MARGIN CALL ***                         *)
(*                 Player  : ALICE                             *)
(*                 Stock   : Stryker Drlg                      *)
(*                 Current price     : $22                     *)
(*                 Margin call at    : $25                     *)
(*                 Amount due        : $3000                   *)
(*                 [liquidation message]                       *)
(*               Machine checks: all params unmodified         *)
(*                                                             *)
(*             Subtest 2 — different stock, higher obligation  *)
(*               Shady Brooks at $20, callPrice=$25,           *)
(*               amtDue=$7500.                                 *)
(*               Expected display (tester verifies):           *)
(*                 Stock   : Shady Brooks                      *)
(*                 Current price     : $20                     *)
(*                 Amount due        : $7500                   *)
(*               Machine checks: all params unmodified         *)
(* PARAMS    : none                                            *)
(* SIDE EFX  : Calls scrMgnCall which clears screen and waits  *)
(*             for keypress.                                   *)
(* ============================================================ *)
DIM tPlyrNam  : STRING[20]
DIM tStckNam  : STRING[14]
DIM tCurPrice : INTEGER
DIM tCallPrc  : INTEGER
DIM tAmtDue   : INTEGER
DIM passed    : INTEGER
DIM failed    : INTEGER

ON ERROR GOTO 900

passed := 0
failed := 0

PRINT "=== TSTMGNCALL  Task 10.1 ==="
PRINT "Visual verification required for each subtest."
PRINT

! ---- Subtest 1: spec confirmation case ----------------------
tPlyrNam  := "ALICE"
tStckNam  := "Stryker Drlg"
tCurPrice := 22
tCallPrc  := 25
tAmtDue   := 3000

PRINT "--- Subtest 1: Stryker $22, amtDue=$3000 ---"
PRINT "Expected: MARGIN CALL header, player=ALICE,"
PRINT "  stock=Stryker Drlg, price=$22, call=$25, due=$3000."
PRINT

RUN scrMgnCall(tPlyrNam, tStckNam, tCurPrice, tCallPrc, tAmtDue)
GOSUB 100

! ---- Subtest 2: different stock, larger obligation ----------
tPlyrNam  := "BOB"
tStckNam  := "Shady Brooks"
tCurPrice := 20
tCallPrc  := 25
tAmtDue   := 7500

PRINT "--- Subtest 2: Shady Brooks $20, amtDue=$7500 ---"
PRINT "Expected: player=BOB, stock=Shady Brooks,"
PRINT "  price=$20, call=$25, due=$7500."
PRINT

RUN scrMgnCall(tPlyrNam, tStckNam, tCurPrice, tCallPrc, tAmtDue)
GOSUB 200

PRINT
PRINT "Results: "; passed; " passed, "; failed; " failed."
END

100 \ ! Subtest 1: params unmodified
    PRINT "--- Subtest 1 machine checks ---"
    IF tPlyrNam = "ALICE" THEN
      PRINT "PASS  tPlyrNam unmodified"
      passed := passed + 1
    ELSE
      PRINT "FAIL  tPlyrNam modified"
      failed := failed + 1
    ENDIF
    IF tStckNam = "Stryker Drlg" THEN
      PRINT "PASS  tStckNam unmodified"
      passed := passed + 1
    ELSE
      PRINT "FAIL  tStckNam modified"
      failed := failed + 1
    ENDIF
    IF tCurPrice = 22 THEN
      PRINT "PASS  tCurPrice=22 unmodified"
      passed := passed + 1
    ELSE
      PRINT "FAIL  tCurPrice exp=22 got="; tCurPrice
      failed := failed + 1
    ENDIF
    IF tCallPrc = 25 THEN
      PRINT "PASS  tCallPrc=25 unmodified"
      passed := passed + 1
    ELSE
      PRINT "FAIL  tCallPrc exp=25 got="; tCallPrc
      failed := failed + 1
    ENDIF
    IF tAmtDue = 3000 THEN
      PRINT "PASS  tAmtDue=3000 unmodified"
      passed := passed + 1
    ELSE
      PRINT "FAIL  tAmtDue exp=3000 got="; tAmtDue
      failed := failed + 1
    ENDIF
    PRINT
RETURN

200 \ ! Subtest 2: params unmodified
    PRINT "--- Subtest 2 machine checks ---"
    IF tPlyrNam = "BOB" THEN
      PRINT "PASS  tPlyrNam unmodified"
      passed := passed + 1
    ELSE
      PRINT "FAIL  tPlyrNam modified"
      failed := failed + 1
    ENDIF
    IF tStckNam = "Shady Brooks" THEN
      PRINT "PASS  tStckNam unmodified"
      passed := passed + 1
    ELSE
      PRINT "FAIL  tStckNam modified"
      failed := failed + 1
    ENDIF
    IF tCurPrice = 20 THEN
      PRINT "PASS  tCurPrice=20 unmodified"
      passed := passed + 1
    ELSE
      PRINT "FAIL  tCurPrice exp=20 got="; tCurPrice
      failed := failed + 1
    ENDIF
    IF tAmtDue = 7500 THEN
      PRINT "PASS  tAmtDue=7500 unmodified"
      passed := passed + 1
    ELSE
      PRINT "FAIL  tAmtDue exp=7500 got="; tAmtDue
      failed := failed + 1
    ENDIF
    PRINT
RETURN

900 PRINT "Runtime error "; ERR; " in TSTMGNCALL"
    END

PROCEDURE TSTFORCELIQ
(* ============================================================ *)
(* PROCEDURE : TSTFORCELIQ                                      *)
(* PURPOSE   : Confirmation tests for applyLiqOrdr (machine)   *)
(*             and scrForceLiq (visual), Task 10.2.            *)
(*                                                             *)
(*   Machine tests (applyLiqOrdr):                             *)
(*   Test 1 — spec case, two sequential rounds                 *)
(*     Obligation=3000. Holds: 50 Metro@$50, 1 small bond.     *)
(*     cashBal=5000, marginTot=0.                              *)
(*     Round 1: sell 50 Metro→prcd=2500, cashBal=7500,         *)
(*              oblgRem=500.                                   *)
(*     Round 2: sell 1 small bond→prcd=1000, cashBal=8500,     *)
(*              oblgRem=0.                                     *)
(*     Assert: cashBal=8500, oblgRem=0, stckShrs(2)=0,        *)
(*             bondUnts(1)=0.                                  *)
(*                                                             *)
(*   Test 2 — margin stock sell                                *)
(*     100 Stryker@$80, mgnHeld=TRUE, marginTot=5000,          *)
(*     cashBal=0, oblgRem=8000.                                *)
(*     Sell 100: prcd=8000, repay=MIN(5000,8000)=5000.         *)
(*     After: marginTot=0, cashBal=3000, stckShrs(5)=0,        *)
(*            mgnHeld(5)=FALSE, oblgRem=0.                     *)
(*                                                             *)
(*   Test 3 — oblgRem clamped at 0                             *)
(*     cashBal=0, oblgRem=500, bondUnts(3)=1 ($10000 bond).    *)
(*     Sell 1: prcd=10000. oblgRem→0 (not -9500).              *)
(*     cashBal=10000.                                          *)
(*                                                             *)
(*   Test 4 — ordCnt=0 no-op                                   *)
(*     No fields modified.                                     *)
(*                                                             *)
(*   Visual test (scrForceLiq):                                *)
(*   Subtest 5 — interactive display check                     *)
(*     Obligation=2500, holds 100 Growth Corp@$30 (margin),   *)
(*     50 Shady Brooks@$60, 1 medium bond.                     *)
(*     Tester verifies display, exercises order entry,         *)
(*     selects Submit. Machine checks action=1 on return.      *)
(* PARAMS    : none                                            *)
(* SIDE EFX  : Subtest 5 clears screen and waits for input.    *)
(* ============================================================ *)
! Line exceeds 79 chars; TYPE statement requires single line.
TYPE PlyrRec = plyrName:STRING[20];plyrType,aiTier:BYTE;cashBal,marginTot:INTEGER;isBankrupt,hadCashPur:BOOLEAN;stckShrs(9):INTEGER;mgnHeld(9):BOOLEAN;bondUnts(3):INTEGER
TYPE MktState = stckPrice(9):INTEGER;divSuspnd(9):BOOLEAN
DIM plyr      : PlyrRec
DIM mkt       : MktState
DIM ordType(12): INTEGER
DIM ordId(12)  : INTEGER
DIM ordQty(12) : INTEGER
DIM ordCnt     : INTEGER
DIM oblgRem    : INTEGER
DIM action     : BYTE
DIM passed     : INTEGER
DIM failed     : INTEGER
DIM i          : INTEGER

ON ERROR GOTO 900

passed := 0
failed := 0

PRINT "=== TSTFORCELIQ  Task 10.2 ==="
PRINT

! ---- Shared mkt setup --------------------------------------
FOR i := 1 TO 9
  mkt.stckPrice(i) := 0
  mkt.divSuspnd(i) := FALSE
NEXT i
mkt.stckPrice(2) := 50  \ ! Metro Props
mkt.stckPrice(5) := 80  \ ! Stryker
mkt.stckPrice(1) := 30  \ ! Growth Corp (visual test)
mkt.stckPrice(4) := 60  \ ! Shady Brooks (visual test)

! ---- Test 1: spec case, two rounds -------------------------
PRINT "--- Test 1: spec case (50 Metro + 1 small bond) ---"
GOSUB 600
plyr.cashBal     := 5000
plyr.marginTot   := 0
plyr.stckShrs(2) := 50
plyr.bondUnts(1) := 1
oblgRem          := 3000

! Round 1: sell 50 Metro
ordCnt     := 1
ordType(1) := 1
ordId(1)   := 2
ordQty(1)  := 50

RUN applyLiqOrdr(plyr, mkt, ordType, ordId, ordQty, ordCnt, oblgRem)

! Round 2: sell 1 small bond
ordCnt     := 1
ordType(1) := 2
ordId(1)   := 1
ordQty(1)  := 1

RUN applyLiqOrdr(plyr, mkt, ordType, ordId, ordQty, ordCnt, oblgRem)

GOSUB 100

! ---- Test 2: margin stock sell -----------------------------
PRINT "--- Test 2: full margin sell (Stryker @80, mgnTot=5000) ---"
GOSUB 600
plyr.cashBal     := 0
plyr.marginTot   := 5000
plyr.stckShrs(5) := 100
plyr.mgnHeld(5)  := TRUE
oblgRem          := 8000

ordCnt     := 1
ordType(1) := 1
ordId(1)   := 5
ordQty(1)  := 100

RUN applyLiqOrdr(plyr, mkt, ordType, ordId, ordQty, ordCnt, oblgRem)

GOSUB 200

! ---- Test 3: oblgRem clamped at 0 --------------------------
PRINT "--- Test 3: oblgRem clamp (1 large bond, oblgRem=500) ---"
GOSUB 600
plyr.cashBal     := 0
plyr.bondUnts(3) := 1
oblgRem          := 500

ordCnt     := 1
ordType(1) := 2
ordId(1)   := 3
ordQty(1)  := 1

RUN applyLiqOrdr(plyr, mkt, ordType, ordId, ordQty, ordCnt, oblgRem)

GOSUB 300

! ---- Test 4: ordCnt=0 no-op --------------------------------
PRINT "--- Test 4: ordCnt=0 no-op ---"
GOSUB 600
plyr.cashBal     := 2000
plyr.marginTot   := 1000
plyr.stckShrs(1) := 50
plyr.bondUnts(2) := 2
oblgRem          := 1500
ordCnt           := 0

RUN applyLiqOrdr(plyr, mkt, ordType, ordId, ordQty, ordCnt, oblgRem)

GOSUB 400

! ---- Subtest 5: scrForceLiq visual -------------------------
PRINT "--- Subtest 5: scrForceLiq visual + action check ---"
PRINT "Obligation=$2500, 100 Growth Corp@$30 [M],"
PRINT "  50 Shady Brooks@$60, 1 medium bond."
PRINT "Enter some orders, select Submit. Verify action=1."
PRINT

GOSUB 600
plyr.plyrName    := "ALICE"
plyr.cashBal     := 500
plyr.marginTot   := 1200
plyr.stckShrs(1) := 100
plyr.mgnHeld(1)  := TRUE
plyr.stckShrs(4) := 50
plyr.bondUnts(2) := 1
oblgRem          := 2500

! Line exceeds 79 chars; RUN parameter list cannot be split.
RUN scrForceLiq(plyr.plyrName, oblgRem, plyr, mkt, ordType, ordId, ordQty, ordCnt, action)

GOSUB 500

PRINT
PRINT "Results: "; passed; " passed, "; failed; " failed."
END

100 \ ! Test 1 assertions
    IF plyr.cashBal = 8500 THEN
      PRINT "PASS  T1 cashBal=8500"
      passed := passed + 1
    ELSE
      PRINT "FAIL  T1 cashBal exp=8500 got="; plyr.cashBal
      failed := failed + 1
    ENDIF
    IF oblgRem = 0 THEN
      PRINT "PASS  T1 oblgRem=0"
      passed := passed + 1
    ELSE
      PRINT "FAIL  T1 oblgRem exp=0 got="; oblgRem
      failed := failed + 1
    ENDIF
    IF plyr.stckShrs(2) = 0 THEN
      PRINT "PASS  T1 stckShrs(2)=0"
      passed := passed + 1
    ELSE
      PRINT "FAIL  T1 stckShrs(2) exp=0 got="; plyr.stckShrs(2)
      failed := failed + 1
    ENDIF
    IF plyr.bondUnts(1) = 0 THEN
      PRINT "PASS  T1 bondUnts(1)=0"
      passed := passed + 1
    ELSE
      PRINT "FAIL  T1 bondUnts(1) exp=0 got="; plyr.bondUnts(1)
      failed := failed + 1
    ENDIF
    PRINT
RETURN

200 \ ! Test 2 assertions
    IF plyr.cashBal = 3000 THEN
      PRINT "PASS  T2 cashBal=3000"
      passed := passed + 1
    ELSE
      PRINT "FAIL  T2 cashBal exp=3000 got="; plyr.cashBal
      failed := failed + 1
    ENDIF
    IF plyr.marginTot = 0 THEN
      PRINT "PASS  T2 marginTot=0"
      passed := passed + 1
    ELSE
      PRINT "FAIL  T2 marginTot exp=0 got="; plyr.marginTot
      failed := failed + 1
    ENDIF
    IF plyr.stckShrs(5) = 0 THEN
      PRINT "PASS  T2 stckShrs(5)=0"
      passed := passed + 1
    ELSE
      PRINT "FAIL  T2 stckShrs(5) exp=0 got="; plyr.stckShrs(5)
      failed := failed + 1
    ENDIF
    IF NOT plyr.mgnHeld(5) THEN
      PRINT "PASS  T2 mgnHeld(5)=FALSE"
      passed := passed + 1
    ELSE
      PRINT "FAIL  T2 mgnHeld(5) exp=FALSE got=TRUE"
      failed := failed + 1
    ENDIF
    IF oblgRem = 0 THEN
      PRINT "PASS  T2 oblgRem=0"
      passed := passed + 1
    ELSE
      PRINT "FAIL  T2 oblgRem exp=0 got="; oblgRem
      failed := failed + 1
    ENDIF
    PRINT
RETURN

300 \ ! Test 3 assertions
    IF plyr.cashBal = 10000 THEN
      PRINT "PASS  T3 cashBal=10000"
      passed := passed + 1
    ELSE
      PRINT "FAIL  T3 cashBal exp=10000 got="; plyr.cashBal
      failed := failed + 1
    ENDIF
    IF oblgRem = 0 THEN
      PRINT "PASS  T3 oblgRem=0 (clamped)"
      passed := passed + 1
    ELSE
      PRINT "FAIL  T3 oblgRem exp=0 got="; oblgRem
      failed := failed + 1
    ENDIF
    IF plyr.bondUnts(3) = 0 THEN
      PRINT "PASS  T3 bondUnts(3)=0"
      passed := passed + 1
    ELSE
      PRINT "FAIL  T3 bondUnts(3) exp=0 got="; plyr.bondUnts(3)
      failed := failed + 1
    ENDIF
    PRINT
RETURN

400 \ ! Test 4 assertions
    IF plyr.cashBal = 2000 THEN
      PRINT "PASS  T4 cashBal=2000 (no-op)"
      passed := passed + 1
    ELSE
      PRINT "FAIL  T4 cashBal exp=2000 got="; plyr.cashBal
      failed := failed + 1
    ENDIF
    IF plyr.marginTot = 1000 THEN
      PRINT "PASS  T4 marginTot=1000 (no-op)"
      passed := passed + 1
    ELSE
      PRINT "FAIL  T4 marginTot exp=1000 got="; plyr.marginTot
      failed := failed + 1
    ENDIF
    IF oblgRem = 1500 THEN
      PRINT "PASS  T4 oblgRem=1500 (no-op)"
      passed := passed + 1
    ELSE
      PRINT "FAIL  T4 oblgRem exp=1500 got="; oblgRem
      failed := failed + 1
    ENDIF
    PRINT
RETURN

500 \ ! Subtest 5 assertion
    IF action = 1 THEN
      PRINT "PASS  Subtest5 action=1 (SUBMIT)"
      passed := passed + 1
    ELSE
      PRINT "FAIL  Subtest5 action exp=1 got="; action
      PRINT "      (2=DECLARE_BANKRUPTCY — was that intended?)"
      failed := failed + 1
    ENDIF
    PRINT
RETURN

600 \ ! Reset plyr record to clean state
    plyr.plyrName  := ""
    plyr.plyrType  := 0
    plyr.aiTier    := 0
    plyr.cashBal   := 0
    plyr.marginTot := 0
    plyr.isBankrupt   := FALSE
    plyr.hadCashPur   := FALSE
    FOR i := 1 TO 9
      plyr.stckShrs(i) := 0
      plyr.mgnHeld(i)  := FALSE
    NEXT i
    FOR i := 1 TO 3
      plyr.bondUnts(i) := 0
    NEXT i
RETURN

900 PRINT "Runtime error "; ERR; " in TSTFORCELIQ"
    END

PROCEDURE TSTBANKRUPT
(* ============================================================ *)
(* PROCEDURE : TSTBANKRUPT                                      *)
(* PURPOSE   : Confirmation tests for scrBankrupt (Task 10.3). *)
(*                                                             *)
(*   Machine assertions (both subtests):                       *)
(*     - plyr.isBankrupt was FALSE before call                 *)
(*     - plyr.isBankrupt is TRUE after call                    *)
(*     - All other plyr fields unmodified                      *)
(*                                                             *)
(*   Subtest 1 — MARGIN_INTEREST reason, Year 5               *)
(*     finalCash=-500, reason=1, currYear=5.                   *)
(*     Expected display (tester verifies):                     *)
(*       *** BANKRUPTCY ***                                    *)
(*       Player  : ALICE                                       *)
(*       Year    : 5 of 10                                     *)
(*       Reason  : Margin interest charge                      *)
(*       Final cash : $-500                                    *)
(*       ALICE has been eliminated from the game.              *)
(*                                                             *)
(*   Subtest 2 — MARGIN_CALL reason, Year 3                   *)
(*     finalCash=-200, reason=2, currYear=3.                   *)
(*     Expected display (tester verifies):                     *)
(*       Reason  : Margin call                                 *)
(*       Final cash : $-200                                    *)
(*       BOB has been eliminated from the game.                *)
(* PARAMS    : none                                            *)
(* SIDE EFX  : Calls scrBankrupt which clears screen and waits *)
(*             for keypress.                                   *)
(* ============================================================ *)
! Line exceeds 79 chars; TYPE statement requires single line.
TYPE PlyrRec = plyrName:STRING[20];plyrType,aiTier:BYTE;cashBal,marginTot:INTEGER;isBankrupt,hadCashPur:BOOLEAN;stckShrs(9):INTEGER;mgnHeld(9):BOOLEAN;bondUnts(3):INTEGER
DIM plyr    : PlyrRec
DIM passed  : INTEGER
DIM failed  : INTEGER
DIM i       : INTEGER

ON ERROR GOTO 900

passed := 0
failed := 0

PRINT "=== TSTBANKRUPT  Task 10.3 ==="
PRINT "Visual verification required for each subtest."
PRINT

! ---- Subtest 1: MARGIN_INTEREST, Year 5 --------------------
GOSUB 500
plyr.plyrName  := "ALICE"
plyr.cashBal   := -500
plyr.marginTot := 2000

! Pre-call check: isBankrupt must be FALSE
IF NOT plyr.isBankrupt THEN
  PRINT "PASS  S1 pre-call isBankrupt=FALSE"
  passed := passed + 1
ELSE
  PRINT "FAIL  S1 pre-call isBankrupt already TRUE (reset failure)"
  failed := failed + 1
ENDIF

PRINT "--- Subtest 1: MARGIN_INTEREST, Year 5 ---"
PRINT "Expected: Reason=margin interest, year=5, cash=-500."
PRINT

RUN scrBankrupt(plyr, -500, 1, 5)

GOSUB 100

! ---- Subtest 2: MARGIN_CALL, Year 3 -----------------------
GOSUB 500
plyr.plyrName  := "BOB"
plyr.cashBal   := -200
plyr.marginTot := 3000

IF NOT plyr.isBankrupt THEN
  PRINT "PASS  S2 pre-call isBankrupt=FALSE"
  passed := passed + 1
ELSE
  PRINT "FAIL  S2 pre-call isBankrupt already TRUE (reset failure)"
  failed := failed + 1
ENDIF

PRINT "--- Subtest 2: MARGIN_CALL, Year 3 ---"
PRINT "Expected: Reason=margin call, year=3, cash=-200."
PRINT

RUN scrBankrupt(plyr, -200, 2, 3)

GOSUB 200

PRINT
PRINT "Results: "; passed; " passed, "; failed; " failed."
END

100 \ ! Subtest 1 post-call assertions
    PRINT "--- Subtest 1 machine checks ---"
    IF plyr.isBankrupt THEN
      PRINT "PASS  S1 isBankrupt=TRUE after call"
      passed := passed + 1
    ELSE
      PRINT "FAIL  S1 isBankrupt still FALSE after call"
      failed := failed + 1
    ENDIF
    IF plyr.plyrName = "ALICE" THEN
      PRINT "PASS  S1 plyrName unmodified"
      passed := passed + 1
    ELSE
      PRINT "FAIL  S1 plyrName modified"
      failed := failed + 1
    ENDIF
    IF plyr.cashBal = -500 THEN
      PRINT "PASS  S1 cashBal=-500 unmodified"
      passed := passed + 1
    ELSE
      PRINT "FAIL  S1 cashBal exp=-500 got="; plyr.cashBal
      failed := failed + 1
    ENDIF
    IF plyr.marginTot = 2000 THEN
      PRINT "PASS  S1 marginTot=2000 unmodified"
      passed := passed + 1
    ELSE
      PRINT "FAIL  S1 marginTot exp=2000 got="; plyr.marginTot
      failed := failed + 1
    ENDIF
    PRINT
RETURN

200 \ ! Subtest 2 post-call assertions
    PRINT "--- Subtest 2 machine checks ---"
    IF plyr.isBankrupt THEN
      PRINT "PASS  S2 isBankrupt=TRUE after call"
      passed := passed + 1
    ELSE
      PRINT "FAIL  S2 isBankrupt still FALSE after call"
      failed := failed + 1
    ENDIF
    IF plyr.plyrName = "BOB" THEN
      PRINT "PASS  S2 plyrName unmodified"
      passed := passed + 1
    ELSE
      PRINT "FAIL  S2 plyrName modified"
      failed := failed + 1
    ENDIF
    IF plyr.cashBal = -200 THEN
      PRINT "PASS  S2 cashBal=-200 unmodified"
      passed := passed + 1
    ELSE
      PRINT "FAIL  S2 cashBal exp=-200 got="; plyr.cashBal
      failed := failed + 1
    ENDIF
    IF plyr.marginTot = 3000 THEN
      PRINT "PASS  S2 marginTot=3000 unmodified"
      passed := passed + 1
    ELSE
      PRINT "FAIL  S2 marginTot exp=3000 got="; plyr.marginTot
      failed := failed + 1
    ENDIF
    PRINT
RETURN

500 \ ! Reset plyr to clean state
    plyr.plyrName   := ""
    plyr.plyrType   := 0
    plyr.aiTier     := 0
    plyr.cashBal    := 0
    plyr.marginTot  := 0
    plyr.isBankrupt := FALSE
    plyr.hadCashPur := FALSE
    FOR i := 1 TO 9
      plyr.stckShrs(i) := 0
      plyr.mgnHeld(i)  := FALSE
    NEXT i
    FOR i := 1 TO 3
      plyr.bondUnts(i) := 0
    NEXT i
RETURN

900 PRINT "Runtime error "; ERR; " in TSTBANKRUPT"
    END

PROCEDURE TSTMGNCLR
(* ============================================================ *)
(* PROCEDURE : TSTMGNCLR                                        *)
(* PURPOSE   : Confirmation tests for scrMgnClr (Task 10.4).   *)
(*                                                             *)
(*   Machine tests replicate the two-phase apply logic of      *)
(*   scrMgnClr (applyLiqOrdr + cash repayment) without         *)
(*   requiring interactive input. scrMgnClr is also called     *)
(*   directly in Subtest 5 for visual and action verification. *)
(*                                                             *)
(*   Test 1 — Cash stock sell + partial cash repayment         *)
(*     Valley Power 50 shrs @$50, cashBal=1000, marginTot=4000 *)
(*     mgnHeld=FALSE. Sell 50 VP, repay=1500.                  *)
(*     applyLiqOrdr: prcd=2500, cashBal→3500, marginTot=4000   *)
(*     actualRpy=MIN(1500,4000,3500)=1500.                     *)
(*     Expected: cashBal=2000, marginTot=2500, stckShrs(9)=0.  *)
(*                                                             *)
(*   Test 2 — Pure cash repayment, no sells                    *)
(*     cashBal=5000, marginTot=4000, no assets.                *)
(*     ordCnt=0, repay=4000.                                   *)
(*     Expected: cashBal=1000, marginTot=0.                    *)
(*                                                             *)
(*   Test 3 — mgnHeld sell clears marginTot; cash repay        *)
(*             clamped to 0                                     *)
(*     Stryker 50 @$60, mgnHeld=TRUE, marginTot=2000,          *)
(*     cashBal=500, repay=500.                                  *)
(*     applyLiqOrdr: prcd=3000, repay_inner=2000,              *)
(*       marginTot→0, cashBal→1500.                            *)
(*     actualRpy=MIN(500,0,1500)=0 (marginTot=0 clamps it).    *)
(*     Expected: cashBal=1500, marginTot=0.                    *)
(*                                                             *)
(*   Test 4 — Partial mgnHeld sell; cash repayment covers rest *)
(*     Sell 30 of 50 Stryker @$60, mgnHeld=TRUE,               *)
(*     marginTot=2000, cashBal=200, repay=500.                  *)
(*     applyLiqOrdr: prcd=1800, repay_inner=1800,              *)
(*       marginTot→200, cashBal→200.                           *)
(*     actualRpy=MIN(500,200,200)=200.                         *)
(*     Expected: cashBal=0, marginTot=0.                       *)
(*                                                             *)
(*   Subtest 5 — Visual: scrMgnClr direct call                 *)
(*     marginTot=3000, cashBal=500, 100 Metro Props @$50,      *)
(*     1 medium bond.                                          *)
(*     Tester enters orders and/or repayment, submits.         *)
(*     Machine checks: action=1 on return.                     *)
(* PARAMS    : none                                            *)
(* SIDE EFX  : Subtest 5 clears screen and waits for input.    *)
(* ============================================================ *)
! Line exceeds 79 chars; TYPE statement requires single line.
TYPE PlyrRec = plyrName:STRING[20];plyrType,aiTier:BYTE;cashBal,marginTot:INTEGER;isBankrupt,hadCashPur:BOOLEAN;stckShrs(9):INTEGER;mgnHeld(9):BOOLEAN;bondUnts(3):INTEGER
TYPE MktState = stckPrice(9):INTEGER;divSuspnd(9):BOOLEAN
DIM plyr       : PlyrRec
DIM mkt        : MktState
DIM ordType(12): INTEGER
DIM ordId(12)  : INTEGER
DIM ordQty(12) : INTEGER
DIM ordCnt     : INTEGER
DIM oblgRem    : INTEGER
DIM repay      : INTEGER
DIM actualRpy  : INTEGER
DIM action     : BYTE
DIM passed     : INTEGER
DIM failed     : INTEGER
DIM i          : INTEGER

ON ERROR GOTO 900

passed := 0
failed := 0

PRINT "=== TSTMGNCLR  Task 10.4 ==="
PRINT

! Shared mkt setup
FOR i := 1 TO 9
  mkt.stckPrice(i) := 0
  mkt.divSuspnd(i) := FALSE
NEXT i
mkt.stckPrice(2) := 50  \ ! Metro Props (visual test)
mkt.stckPrice(5) := 60  \ ! Stryker Drlg
mkt.stckPrice(9) := 50  \ ! Valley Power

! ---- Test 1: cash stock sell + partial cash repayment ------
PRINT "--- Test 1: VP sell + $1500 cash repay ---"
GOSUB 700
plyr.cashBal     := 1000
plyr.marginTot   := 4000
plyr.stckShrs(9) := 50  \ ! Valley Power; not mgnHeld

ordCnt     := 1
ordType(1) := 1
ordId(1)   := 9
ordQty(1)  := 50
repay      := 1500

GOSUB 600  \ ! Two-phase apply

GOSUB 100

! ---- Test 2: pure cash repayment, no sells -----------------
PRINT "--- Test 2: pure cash repayment (no sells) ---"
GOSUB 700
plyr.cashBal   := 5000
plyr.marginTot := 4000
ordCnt         := 0
repay          := 4000

GOSUB 600  \ ! Two-phase apply

GOSUB 200

! ---- Test 3: full mgnHeld sell; repay clamped to 0 ---------
PRINT "--- Test 3: full mgnHeld sell; repay clamped at 0 ---"
GOSUB 700
plyr.cashBal     := 500
plyr.marginTot   := 2000
plyr.stckShrs(5) := 50
plyr.mgnHeld(5)  := TRUE
ordCnt     := 1
ordType(1) := 1
ordId(1)   := 5
ordQty(1)  := 50
repay      := 500

GOSUB 600  \ ! Two-phase apply

GOSUB 300

! ---- Test 4: partial mgnHeld sell; cash covers residual ----
PRINT "--- Test 4: partial mgnHeld sell + cash repay ---"
GOSUB 700
plyr.cashBal     := 200
plyr.marginTot   := 2000
plyr.stckShrs(5) := 50
plyr.mgnHeld(5)  := TRUE
ordCnt     := 1
ordType(1) := 1
ordId(1)   := 5
ordQty(1)  := 30
repay      := 500

GOSUB 600  \ ! Two-phase apply

GOSUB 400

! ---- Subtest 5: scrMgnClr visual + action check ------------
PRINT "--- Subtest 5: scrMgnClr visual ---"
PRINT "Player: ALICE  marginTot=$3000  cashBal=$500"
PRINT "Holdings: 100 Metro Props @$50, 1 medium bond."
PRINT "Enter sell orders and/or cash repayment, then Submit."
PRINT "Machine checks action=1 on return."
PRINT

GOSUB 700
plyr.plyrName    := "ALICE"
plyr.cashBal     := 500
plyr.marginTot   := 3000
plyr.stckShrs(2) := 100
plyr.bondUnts(2) := 1

RUN scrMgnClr(plyr, mkt, action)

GOSUB 500

PRINT
PRINT "Results: "; passed; " passed, "; failed; " failed."
END

100 \! Test 1 assertions
    IF plyr.cashBal = 2000 THEN
      PRINT "PASS  T1 cashBal=2000"
      passed := passed + 1
    ELSE
      PRINT "FAIL  T1 cashBal exp=2000 got="; plyr.cashBal
      failed := failed + 1
    ENDIF
    IF plyr.marginTot = 2500 THEN
      PRINT "PASS  T1 marginTot=2500"
      passed := passed + 1
    ELSE
      PRINT "FAIL  T1 marginTot exp=2500 got="; plyr.marginTot
      failed := failed + 1
    ENDIF
    IF plyr.stckShrs(9) = 0 THEN
      PRINT "PASS  T1 stckShrs(9)=0"
      passed := passed + 1
    ELSE
      PRINT "FAIL  T1 stckShrs(9) exp=0 got="; plyr.stckShrs(9)
      failed := failed + 1
    ENDIF
    PRINT
RETURN

200 \! Test 2 assertions
    IF plyr.cashBal = 1000 THEN
      PRINT "PASS  T2 cashBal=1000"
      passed := passed + 1
    ELSE
      PRINT "FAIL  T2 cashBal exp=1000 got="; plyr.cashBal
      failed := failed + 1
    ENDIF
    IF plyr.marginTot = 0 THEN
      PRINT "PASS  T2 marginTot=0"
      passed := passed + 1
    ELSE
      PRINT "FAIL  T2 marginTot exp=0 got="; plyr.marginTot
      failed := failed + 1
    ENDIF
    PRINT
RETURN

300 \! Test 3 assertions
    IF plyr.cashBal = 1500 THEN
      PRINT "PASS  T3 cashBal=1500"
      passed := passed + 1
    ELSE
      PRINT "FAIL  T3 cashBal exp=1500 got="; plyr.cashBal
      failed := failed + 1
    ENDIF
    IF plyr.marginTot = 0 THEN
      PRINT "PASS  T3 marginTot=0"
      passed := passed + 1
    ELSE
      PRINT "FAIL  T3 marginTot exp=0 got="; plyr.marginTot
      failed := failed + 1
    ENDIF
    IF plyr.stckShrs(5) = 0 THEN
      PRINT "PASS  T3 stckShrs(5)=0"
      passed := passed + 1
    ELSE
      PRINT "FAIL  T3 stckShrs(5) exp=0 got="; plyr.stckShrs(5)
      failed := failed + 1
    ENDIF
    IF NOT plyr.mgnHeld(5) THEN
      PRINT "PASS  T3 mgnHeld(5)=FALSE"
      passed := passed + 1
    ELSE
      PRINT "FAIL  T3 mgnHeld(5) exp=FALSE got=TRUE"
      failed := failed + 1
    ENDIF
    PRINT
RETURN

400 \! Test 4 assertions
    IF plyr.cashBal = 0 THEN
      PRINT "PASS  T4 cashBal=0"
      passed := passed + 1
    ELSE
      PRINT "FAIL  T4 cashBal exp=0 got="; plyr.cashBal
      failed := failed + 1
    ENDIF
    IF plyr.marginTot = 0 THEN
      PRINT "PASS  T4 marginTot=0"
      passed := passed + 1
    ELSE
      PRINT "FAIL  T4 marginTot exp=0 got="; plyr.marginTot
      failed := failed + 1
    ENDIF
    IF plyr.stckShrs(5) = 20 THEN
      PRINT "PASS  T4 stckShrs(5)=20 (30 sold of 50)"
      passed := passed + 1
    ELSE
      PRINT "FAIL  T4 stckShrs(5) exp=20 got="; plyr.stckShrs(5)
      failed := failed + 1
    ENDIF
    PRINT
RETURN

500 \! Subtest 5: action check
    PRINT "--- Subtest 5 machine checks ---"
    IF action = 1 THEN
      PRINT "PASS  Subtest5 action=1 (SUBMIT)"
      passed := passed + 1
    ELSE
      PRINT "FAIL  Subtest5 action exp=1 got="; action
      PRINT "      (2=DECLARE_BANKRUPTCY — was that intended?)"
      failed := failed + 1
    ENDIF
    PRINT
RETURN

600 \! Two-phase apply: applyLiqOrdr then cash repayment
    oblgRem := plyr.marginTot
    RUN applyLiqOrdr(plyr, mkt, ordType, ordId, ordQty, ordCnt, oblgRem)
    actualRpy := repay
    IF actualRpy > plyr.marginTot THEN
      actualRpy := plyr.marginTot
    ENDIF
    IF actualRpy > plyr.cashBal THEN
      actualRpy := plyr.cashBal
    ENDIF
    IF actualRpy < 0 THEN
      actualRpy := 0
    ENDIF
    plyr.cashBal   := plyr.cashBal - actualRpy
    plyr.marginTot := plyr.marginTot - actualRpy
RETURN

700 \! Reset plyr record and order arrays
    plyr.plyrName  := ""
    plyr.plyrType  := 0
    plyr.aiTier    := 0
    plyr.cashBal   := 0
    plyr.marginTot := 0
    plyr.isBankrupt   := FALSE
    plyr.hadCashPur   := FALSE
    FOR i := 1 TO 9
      plyr.stckShrs(i) := 0
      plyr.mgnHeld(i)  := FALSE
    NEXT i
    FOR i := 1 TO 3
      plyr.bondUnts(i) := 0
    NEXT i
    FOR i := 1 TO 12
      ordType(i) := 0
      ordId(i)   := 0
      ordQty(i)  := 0
    NEXT i
    ordCnt  := 0
    repay   := 0
    oblgRem := 0
RETURN

900 PRINT "Runtime error "; ERR; " in TSTMGNCLR"
    END

PROCEDURE TSTEND
(* ============================================================ *)
(* PROCEDURE : TSTEND                                           *)
(* PURPOSE   : Confirmation test for Phase 11 Task 11.1.       *)
(*             Tests scrFinalMkt, scrWealth, scrWinner,        *)
(*             scrPostGame per project-timeline.md spec.       *)
(*                                                             *)
(*   Test A — Normal game end (Player 1 wins):                 *)
(*     P1: cashBal=3000, 100 Valley Power @95, 1 large bond.  *)
(*         totalWealth = 3000 + 9500 + 10000 = 22500.         *)
(*     P2: cashBal=8000, 50 Shady Brooks @140, 0 bonds.       *)
(*         totalWealth = 8000 + 7000 = 15000.                 *)
(*     Verify: wlth(1)=22500, wlth(2)=15000.                  *)
(*     Verify: srtOrd(1)=1 (P1 listed first in scrWealth).    *)
(*     Verify: scrWinner names ALICE.                          *)
(*                                                             *)
(*   Test B — Tie scenario:                                    *)
(*     Adjust P2 cashBal to 15500.                            *)
(*     P2 totalWealth = 15500 + 7000 = 22500 = P1 total.      *)
(*     Verify: both ALICE and BOB named in scrWinner.          *)
(*                                                             *)
(*   Test C — Post-game menu:                                  *)
(*     Verify 1=New Game / 2=Load Game / 3=Quit routes.       *)
(* ============================================================ *)
! Line exceeds 79 chars; TYPE statement requires single line.
TYPE PlyrRec = plyrName:STRING[20];plyrType,aiTier:BYTE;cashBal,marginTot:INTEGER;isBankrupt,hadCashPur:BOOLEAN;stckShrs(9):INTEGER;mgnHeld(9):BOOLEAN;bondUnts(3):INTEGER
TYPE MktState = stckPrice(9):INTEGER;divSuspnd(9):BOOLEAN
DIM plyrs(6)  : PlyrRec
DIM mkt       : MktState
DIM wlth(6)   : INTEGER
DIM srtOrd(6) : INTEGER
DIM action    : INTEGER
DIM plyrCount : INTEGER
DIM i         : INTEGER

ON ERROR GOTO 900

plyrCount := 2

! --- Init player 1 (ALICE) ----------------------------------
plyrs(1).plyrName   := "ALICE"
plyrs(1).plyrType   := 1
plyrs(1).aiTier     := 0
plyrs(1).cashBal    := 3000
plyrs(1).marginTot  := 0
plyrs(1).isBankrupt := FALSE
plyrs(1).hadCashPur := FALSE
FOR i := 1 TO 9
  plyrs(1).stckShrs(i) := 0
  plyrs(1).mgnHeld(i)  := FALSE
NEXT i
FOR i := 1 TO 3
  plyrs(1).bondUnts(i) := 0
NEXT i
plyrs(1).stckShrs(9) := 100 \ ! 100 Valley Power (stock 9)
plyrs(1).bondUnts(3) := 1   \ ! 1 large bond ($10000 par)

! --- Init player 2 (BOB) ------------------------------------
plyrs(2).plyrName   := "BOB"
plyrs(2).plyrType   := 1
plyrs(2).aiTier     := 0
plyrs(2).cashBal    := 8000
plyrs(2).marginTot  := 0
plyrs(2).isBankrupt := FALSE
plyrs(2).hadCashPur := FALSE
FOR i := 1 TO 9
  plyrs(2).stckShrs(i) := 0
  plyrs(2).mgnHeld(i)  := FALSE
NEXT i
FOR i := 1 TO 3
  plyrs(2).bondUnts(i) := 0
NEXT i
plyrs(2).stckShrs(4) := 50 \ ! 50 Shady Brooks (stock 4)

! --- Init market state --------------------------------------
FOR i := 1 TO 9
  mkt.stckPrice(i) := 100
  mkt.divSuspnd(i) := FALSE
NEXT i
mkt.stckPrice(9) := 95  \ ! Valley Power final price
mkt.stckPrice(4) := 140 \ ! Shady Brooks final price

! === Test A — Normal game end (P1 wins) =====================
PRINT "=== TSTEND Phase 11 Task 11.1 ==="
PRINT
PRINT "Test A: P1 wins."
PRINT "  Expected wlth(1)=22500  wlth(2)=15000"
PRINT "  srtOrd(1)=1  srtOrd(2)=2"
PRINT "  scrWinner: ALICE declared."
PRINT
PRINT "Press any key to run Test A...";
RUN waitKey

RUN scrFinalMkt(mkt)
RUN scrWealth(plyrs, plyrCount, mkt, wlth, srtOrd)

PRINT "wlth(1)="; wlth(1); "  expected 22500"
PRINT "wlth(2)="; wlth(2); "  expected 15000"
PRINT "srtOrd(1)="; srtOrd(1); "  expected 1"
PRINT "srtOrd(2)="; srtOrd(2); "  expected 2"
RUN waitKey

RUN scrWinner(plyrs, plyrCount, wlth, srtOrd)

! === Test B — Tie scenario ==================================
PRINT "=== Test B: Tie ==="
PRINT "  Setting plyrs(2).cashBal := 15500"
PRINT "  P2 totalWealth = 15500 + 7000 = 22500 = P1 total"
PRINT "  Expected: both ALICE and BOB named as winners."
PRINT
plyrs(2).cashBal := 15500
PRINT "Press any key to run Test B...";
RUN waitKey

RUN scrWealth(plyrs, plyrCount, mkt, wlth, srtOrd)

PRINT "wlth(1)="; wlth(1); "  expected 22500"
PRINT "wlth(2)="; wlth(2); "  expected 22500"
RUN waitKey

RUN scrWinner(plyrs, plyrCount, wlth, srtOrd)

! === Test C — Post-game menu ================================
PRINT "=== Test C: Post-game menu ==="
PRINT "  Press 1, 2, or 3. Verify action returned."
PRINT
PRINT "Press any key to launch scrPostGame...";
RUN waitKey

RUN scrPostGame(action)
PRINT "action = "; action
IF action = 1 THEN
  PRINT "  New Game selected. Expected: 1. OK"
ELSE IF action = 2 THEN
  PRINT "  Load Game selected. Expected: 2. OK"
ELSE
  PRINT "  Quit selected. Expected: 3. OK"
ENDIF \ENDIF

PRINT
PRINT "TSTEND complete."
END

900 PRINT "TSTEND error ("; ERR; ")"
END

PROCEDURE TSTAISELL
(* ============================================================ *)
(* PROCEDURE : TSTAISELL                                        *)
(* PURPOSE   : Confirmation tests for aiSell (Task 12.1).      *)
(*             Machine-checks all confirmation cases from      *)
(*             project-timeline.md Phase 12 Task 12.1.         *)
(*                                                             *)
(* Test A — Combined rules scenario (currYear=5, no margin)    *)
(*   stock 1: price=45, divSuspnd=TRUE, shrs=20                *)
(*            → Rule 4, SELL 20                                *)
(*   stock 2: price=0, shrs=50                                 *)
(*            → Rule 1, SELL 50                                *)
(*   stock 3: price=110, divSuspnd=FALSE, shrs=30              *)
(*            → Rule 5, PASS                                   *)
(*   stock 4: price=155, shrs=100                              *)
(*            → Rule 3, SELL 50 (50% of 100)                  *)
(*   stock 5: price=20, mgnHeld=TRUE, shrs=100                 *)
(*            → Rule 2, SELL 100                               *)
(*   cashBal=5000 (positive) → no bond sell.                  *)
(*   Verify: ordCnt=4, orders in ascending stockId order.      *)
(*   Stock 3 absent from order array.                          *)
(*                                                             *)
(* Test B — Bond emergency (currYear=5)                        *)
(*   cashBal=-100, 1 small bond held, no stocks.               *)
(*   Verify: ordCnt=1, ordType(1)=2, ordId(1)=1, ordQty(1)=1  *)
(*                                                             *)
(* Test C — Bond pass when cashBal >= 0                        *)
(*   cashBal=5000, 1 small bond held, no stocks.               *)
(*   Verify: ordCnt=0 (no bond sell).                          *)
(*                                                             *)
(* Test D — Margin clearance (currYear=9)                      *)
(*   marginTot=2000, stock 2 (Metro, div=0) 30@$100,           *)
(*   stock 4 (Shady, div=7) 50@$100. No other holdings.        *)
(*   clrSco(Metro)=0, clrSco(Shady)=70.                       *)
(*   Sort: Metro first (score 0 < 70).                         *)
(*   needed=2000. Partial sell Metro:                          *)
(*     sellLots = ceil(2000/100)=20, rounded to 20. SELL 20.   *)
(*     needed = 2000-2000 = 0. Shady skipped.                  *)
(*   Verify: ordCnt=1, ordType(1)=1, ordId(1)=2, ordQty(1)=20 *)
(*                                                             *)
(* Test E — Margin clearance below marginClrYr (currYear=5)    *)
(*   Same state as Test D but currYear=5 < 9.                  *)
(*   Verify: ordCnt=0 (clearance block skipped).               *)
(* ============================================================ *)
! Line exceeds 79 chars; TYPE statement requires single line.
TYPE PlyrRec = plyrName:STRING[20];plyrType,aiTier:BYTE;cashBal,marginTot:INTEGER;isBankrupt,hadCashPur:BOOLEAN;stckShrs(9):INTEGER;mgnHeld(9):BOOLEAN;bondUnts(3):INTEGER
TYPE MktState = stckPrice(9):INTEGER;divSuspnd(9):BOOLEAN
DIM plyr        : PlyrRec
DIM mkt         : MktState
DIM ordType(12) : INTEGER
DIM ordId(12)   : INTEGER
DIM ordQty(12)  : INTEGER
DIM ordCnt      : INTEGER
DIM passed      : INTEGER
DIM failed      : INTEGER
DIM i           : INTEGER

ON ERROR GOTO 900

passed := 0
failed := 0

PRINT "=== TSTAISELL  Phase 12 Task 12.1 ==="
PRINT

! ============================================================
! Test A — Combined stock rules, no bond sell
! ============================================================
PRINT "--- Test A: Combined stock rules ---"

RUN initPlayer(plyr)
RUN initMkt(mkt)

! stock 1: Rule 4 (divSuspnd=TRUE, price=45 <= 50)
plyr.stckShrs(1)  := 20
mkt.stckPrice(1)  := 45
mkt.divSuspnd(1)  := TRUE

! stock 2: Rule 1 (price=0)
plyr.stckShrs(2)  := 50
mkt.stckPrice(2)  := 0

! stock 3: Rule 5 (price=110, divSuspnd=FALSE) — should NOT appear
plyr.stckShrs(3)  := 30
mkt.stckPrice(3)  := 110
mkt.divSuspnd(3)  := FALSE

! stock 4: Rule 3 (price=155 >= 150, shares=100 → sell 50)
plyr.stckShrs(4)  := 100
mkt.stckPrice(4)  := 155

! stock 5: Rule 2 (price=20 <= 25, mgnHeld=TRUE)
plyr.stckShrs(5)  := 100
mkt.stckPrice(5)  := 20
plyr.mgnHeld(5)   := TRUE

plyr.cashBal      := 5000 \ ! positive; no bond emergency

RUN aiSell(5, plyr, mkt, ordType, ordId, ordQty, ordCnt)

! ordCnt must be 4 (stocks 1, 2, 4, 5)
GOSUB 100

! ord 1: stock 1, Rule 4, sell all 20
GOSUB 200

! ord 2: stock 2, Rule 1, sell all 50
GOSUB 300

! ord 3: stock 4, Rule 3, sell 50
GOSUB 400

! ord 4: stock 5, Rule 2, sell all 100
GOSUB 500

PRINT

! ============================================================
! Test B — Bond emergency: cashBal=-100
! ============================================================
PRINT "--- Test B: Bond emergency cashBal=-100 ---"

RUN initPlayer(plyr)
RUN initMkt(mkt)
plyr.cashBal     := -100
plyr.bondUnts(1) := 1 \ ! small bond $1000

RUN aiSell(5, plyr, mkt, ordType, ordId, ordQty, ordCnt)

IF ordCnt = 1 THEN
  PRINT "Test B PASS  ordCnt=1"
  passed := passed + 1
ELSE
  PRINT "Test B FAIL  ordCnt exp=1 got="; ordCnt
  failed := failed + 1
ENDIF
IF ordType(1) = 2 AND ordId(1) = 1 AND ordQty(1) = 1 THEN
  PRINT "Test B PASS  BOND#1 qty=1"
  passed := passed + 1
ELSE
  PRINT "Test B FAIL  exp BOND#1 qty=1, got type="; ordType(1);
  PRINT " id="; ordId(1); " qty="; ordQty(1)
  failed := failed + 1
ENDIF
PRINT

! ============================================================
! Test C — Bond pass: cashBal >= 0
! ============================================================
PRINT "--- Test C: Bond pass cashBal=5000 ---"

RUN initPlayer(plyr)
RUN initMkt(mkt)
plyr.cashBal     := 5000
plyr.bondUnts(1) := 1

RUN aiSell(5, plyr, mkt, ordType, ordId, ordQty, ordCnt)

IF ordCnt = 0 THEN
  PRINT "Test C PASS  ordCnt=0 (no bond sell)"
  passed := passed + 1
ELSE
  PRINT "Test C FAIL  ordCnt exp=0 got="; ordCnt
  failed := failed + 1
ENDIF
PRINT

! ============================================================
! Test D — Margin clearance active (currYear=9)
! stock 2 Metro (div=0, score=0), stock 4 Shady (div=7, score=70)
! needed=2000; partial sell 20 Metro covers exactly.
! ============================================================
PRINT "--- Test D: Margin clearance Year 9 ---"

RUN initPlayer(plyr)
RUN initMkt(mkt)
plyr.marginTot   := 2000
plyr.cashBal     := 5000
plyr.stckShrs(2) := 30 \ ! Metro Props, div=0
mkt.stckPrice(2) := 100
plyr.stckShrs(4) := 50 \ ! Shady Brooks, div=7
mkt.stckPrice(4) := 100

RUN aiSell(9, plyr, mkt, ordType, ordId, ordQty, ordCnt)

IF ordCnt = 1 THEN
  PRINT "Test D PASS  ordCnt=1"
  passed := passed + 1
ELSE
  PRINT "Test D FAIL  ordCnt exp=1 got="; ordCnt
  failed := failed + 1
ENDIF
IF ordType(1) = 1 AND ordId(1) = 2 AND ordQty(1) = 20 THEN
  PRINT "Test D PASS  STK#2 qty=20 (Metro, partial)"
  passed := passed + 1
ELSE
  PRINT "Test D FAIL  exp STK#2 qty=20, got type="; ordType(1);
  PRINT " id="; ordId(1); " qty="; ordQty(1)
  failed := failed + 1
ENDIF
PRINT

! ============================================================
! Test E — Margin clearance blocked (currYear=5 < 9)
! Same holdings as Test D; clearance block must not fire.
! ============================================================
PRINT "--- Test E: Margin clearance blocked Year 5 ---"

RUN initPlayer(plyr)
RUN initMkt(mkt)
plyr.marginTot   := 2000
plyr.cashBal     := 5000
plyr.stckShrs(2) := 30
mkt.stckPrice(2) := 100
plyr.stckShrs(4) := 50
mkt.stckPrice(4) := 100

RUN aiSell(5, plyr, mkt, ordType, ordId, ordQty, ordCnt)

IF ordCnt = 0 THEN
  PRINT "Test E PASS  ordCnt=0 (clearance blocked)"
  passed := passed + 1
ELSE
  PRINT "Test E FAIL  ordCnt exp=0 got="; ordCnt
  failed := failed + 1
ENDIF
PRINT

PRINT "Results: "; passed; " passed, "; failed; " failed."
END

! ---- Test A subtests ----------------------------------------

100 \ ! Check ordCnt = 4
    IF ordCnt = 4 THEN
      PRINT "Test A PASS  ordCnt=4"
      passed := passed + 1
    ELSE
      PRINT "Test A FAIL  ordCnt exp=4 got="; ordCnt
      failed := failed + 1
    ENDIF
RETURN

200 \ ! ord1: stock 1, Rule 4, qty=20
    IF ordType(1) = 1 AND ordId(1) = 1 AND ordQty(1) = 20 THEN
      PRINT "Test A PASS  ord1=STK#1 qty=20 (Rule 4)"
      passed := passed + 1
    ELSE
      PRINT "Test A FAIL  ord1 exp STK#1 qty=20";
      PRINT " got type="; ordType(1); " id="; ordId(1);
      PRINT " qty="; ordQty(1)
      failed := failed + 1
    ENDIF
RETURN

300 \ ! ord2: stock 2, Rule 1, qty=50
    IF ordType(2) = 1 AND ordId(2) = 2 AND ordQty(2) = 50 THEN
      PRINT "Test A PASS  ord2=STK#2 qty=50 (Rule 1)"
      passed := passed + 1
    ELSE
      PRINT "Test A FAIL  ord2 exp STK#2 qty=50";
      PRINT " got type="; ordType(2); " id="; ordId(2);
      PRINT " qty="; ordQty(2)
      failed := failed + 1
    ENDIF
RETURN

400 \ ! ord3: stock 4, Rule 3, qty=50
    IF ordType(3) = 1 AND ordId(3) = 4 AND ordQty(3) = 50 THEN
      PRINT "Test A PASS  ord3=STK#4 qty=50 (Rule 3)"
      passed := passed + 1
    ELSE
      PRINT "Test A FAIL  ord3 exp STK#4 qty=50";
      PRINT " got type="; ordType(3); " id="; ordId(3);
      PRINT " qty="; ordQty(3)
      failed := failed + 1
    ENDIF
RETURN

500 \ ! ord4: stock 5, Rule 2, qty=100
    IF ordType(4) = 1 AND ordId(4) = 5 AND ordQty(4) = 100 THEN
      PRINT "Test A PASS  ord4=STK#5 qty=100 (Rule 2)"
      passed := passed + 1
    ELSE
      PRINT "Test A FAIL  ord4 exp STK#5 qty=100";
      PRINT " got type="; ordType(4); " id="; ordId(4);
      PRINT " qty="; ordQty(4)
      failed := failed + 1
    ENDIF
RETURN

900 PRINT "TSTAISELL error ("; ERR; ")"
    END

PROCEDURE TSTAIBUY
(* ============================================================ *)
(* PROCEDURE : TSTAIBUY                                         *)
(* PURPOSE   : Confirmation tests for aiBuy (Task 12.2).       *)
(*             Machine-checks all confirmation cases from      *)
(*             project-timeline.md Phase 12 Task 12.2.         *)
(*                                                             *)
(* Test A — Margin repayment trigger                           *)
(*   marginTot=2000, cashBal=500. All stocks bankrupt (p=0).   *)
(*   annlChrg=100. burdenThr=50. 100>50 → repay.              *)
(*   repayAmt=500*50/100=250. mgnRepay=250. simCash=250.       *)
(*   No stocks eligible; simCash<5000 → no bond.               *)
(*   Verify: mgnRepay=250, ordCnt=0.                           *)
(*                                                             *)
(* Test B — Scoring: Shady Brooks outranks Growth Corp         *)
(*   cashBal=10000, stocks 1 (div=1) and 4 (div=7) at $100.   *)
(*   All other stocks at p=0 (bankrupt).                       *)
(*   Shady score=70 > Growth score=10 → Shady first.          *)
(*   Verify: ordId(1)=4 (Shady), ordId(2)=1 (Growth).         *)
(*                                                             *)
(* Test C — Concentration cap                                  *)
(*   cashBal=5000, only stock 4 (Shady) at $100.               *)
(*   maxCash=5000*40/100=2000. maxLots=2000/100=20 lots.       *)
(*   Verify: ordCnt=1, ordQty(1)=20.                           *)
(*                                                             *)
(* Test D — Bond fallback                                      *)
(*   cashBal=5000, all stocks bankrupt. stocksBought=FALSE.    *)
(*   5000>=5000 → eligible. 5000>=10000 FALSE.                 *)
(*   5000>=5000 → BUY 1 medium bond.                           *)
(*   Verify: ordCnt=1, ordType(1)=2, ordId(1)=2, ordQty(1)=1. *)
(*                                                             *)
(* Test E — Bond skip when stocks were bought                  *)
(*   cashBal=5000, stock 4 at $100. Buys 20 Shady.             *)
(*   stocksBought=TRUE → bond block skipped.                   *)
(*   Verify: ordCnt=1, no bond order (ordType(1)=1).           *)
(* ============================================================ *)
! Line exceeds 79 chars; TYPE statement requires single line.
TYPE PlyrRec = plyrName:STRING[20];plyrType,aiTier:BYTE;cashBal,marginTot:INTEGER;isBankrupt,hadCashPur:BOOLEAN;stckShrs(9):INTEGER;mgnHeld(9):BOOLEAN;bondUnts(3):INTEGER
TYPE MktState = stckPrice(9):INTEGER;divSuspnd(9):BOOLEAN
DIM plyr         : PlyrRec
DIM mkt          : MktState
DIM ordType(12)  : INTEGER
DIM ordId(12)    : INTEGER
DIM ordQty(12)   : INTEGER
DIM ordPurch(12) : INTEGER
DIM ordCnt       : INTEGER
DIM mgnRepay     : INTEGER
DIM passed       : INTEGER
DIM failed       : INTEGER
DIM s            : INTEGER

ON ERROR GOTO 900

passed := 0
failed := 0

PRINT "=== TSTAIBUY  Phase 12 Task 12.2 ==="
PRINT

! ============================================================
! Test A — Margin repayment trigger
! ============================================================
PRINT "--- Test A: Margin repayment trigger ---"

RUN initPlayer(plyr)
RUN initMkt(mkt)
plyr.cashBal   := 500
plyr.marginTot := 2000
! All stocks remain at initMkt default ($100); zero them out
! so no stock buys occur and bond idle threshold not met
! (simCash after repay = 250 < 5000).
FOR s := 1 TO 9
  mkt.stckPrice(s) := 0
NEXT s

! Line exceeds 79 chars; RUN parameter list cannot be split.
RUN aiBuy(5, plyr, mkt, ordType, ordId, ordQty, ordPurch, ordCnt, mgnRepay)

IF mgnRepay = 250 THEN
  PRINT "Test A PASS  mgnRepay=250"
  passed := passed + 1
ELSE
  PRINT "Test A FAIL  mgnRepay exp=250 got="; mgnRepay
  failed := failed + 1
ENDIF
IF ordCnt = 0 THEN
  PRINT "Test A PASS  ordCnt=0 (no buys)"
  passed := passed + 1
ELSE
  PRINT "Test A FAIL  ordCnt exp=0 got="; ordCnt
  failed := failed + 1
ENDIF
PRINT

! ============================================================
! Test B — Scoring: Shady Brooks (div=7) outranks Growth (div=1)
! ============================================================
PRINT "--- Test B: Scoring order Shady > Growth ---"

RUN initPlayer(plyr)
RUN initMkt(mkt)
plyr.cashBal := 10000
! Zero all stocks; then re-enable only stocks 1 and 4.
FOR s := 1 TO 9
  mkt.stckPrice(s) := 0
NEXT s
mkt.stckPrice(1) := 100 \ ! Growth Corp  div=1  score=10
mkt.stckPrice(4) := 100 \ ! Shady Brooks div=7  score=70

! Line exceeds 79 chars; RUN parameter list cannot be split.
RUN aiBuy(5, plyr, mkt, ordType, ordId, ordQty, ordPurch, ordCnt, mgnRepay)

GOSUB 100

PRINT

! ============================================================
! Test C — Concentration cap: 40% of 5000 = 2000 → 20 lots
! ============================================================
PRINT "--- Test C: Concentration cap 40% ---"

RUN initPlayer(plyr)
RUN initMkt(mkt)
plyr.cashBal := 5000
FOR s := 1 TO 9
  mkt.stckPrice(s) := 0
NEXT s
mkt.stckPrice(4) := 100 \ ! Shady Brooks only

! Line exceeds 79 chars; RUN parameter list cannot be split.
RUN aiBuy(5, plyr, mkt, ordType, ordId, ordQty, ordPurch, ordCnt, mgnRepay)

GOSUB 200

PRINT

! ============================================================
! Test D — Bond fallback: no stocks, cashBal=5000 → medium bond
! ============================================================
PRINT "--- Test D: Bond fallback cashBal=5000 ---"

RUN initPlayer(plyr)
RUN initMkt(mkt)
plyr.cashBal := 5000
FOR s := 1 TO 9
  mkt.stckPrice(s) := 0
NEXT s

! Line exceeds 79 chars; RUN parameter list cannot be split.
RUN aiBuy(5, plyr, mkt, ordType, ordId, ordQty, ordPurch, ordCnt, mgnRepay)

GOSUB 300

PRINT

! ============================================================
! Test E — Bond skip: stocks bought → bondPriority=FALSE skips
! ============================================================
PRINT "--- Test E: Bond skip when stocks bought ---"

RUN initPlayer(plyr)
RUN initMkt(mkt)
plyr.cashBal := 5000
FOR s := 1 TO 9
  mkt.stckPrice(s) := 0
NEXT s
mkt.stckPrice(4) := 100 \ ! Shady; buys 20 shares → stocksBought=TRUE

! Line exceeds 79 chars; RUN parameter list cannot be split.
RUN aiBuy(5, plyr, mkt, ordType, ordId, ordQty, ordPurch, ordCnt, mgnRepay)

GOSUB 400

PRINT

PRINT "Results: "; passed; " passed, "; failed; " failed."
END

! ---- Test B assertions: scoring order ----------------------

100 \ ! ordCnt >= 2 and Shady first, Growth second
    IF ordCnt >= 2 THEN
      PRINT "Test B PASS  ordCnt>=2 ("; ordCnt; ")"
      passed := passed + 1
    ELSE
      PRINT "Test B FAIL  ordCnt exp>=2 got="; ordCnt
      failed := failed + 1
    ENDIF
    IF ordId(1) = 4 THEN
      PRINT "Test B PASS  ordId(1)=4 (Shady first)"
      passed := passed + 1
    ELSE
      PRINT "Test B FAIL  ordId(1) exp=4 got="; ordId(1)
      failed := failed + 1
    ENDIF
    IF ordId(2) = 1 THEN
      PRINT "Test B PASS  ordId(2)=1 (Growth second)"
      passed := passed + 1
    ELSE
      PRINT "Test B FAIL  ordId(2) exp=1 got="; ordId(2)
      failed := failed + 1
    ENDIF
RETURN

! ---- Test C assertions: concentration cap ------------------

200 \ ! ordCnt=1, ordId(1)=4, ordQty(1)=20, ordPurch(1)=1
    IF ordCnt = 1 THEN
      PRINT "Test C PASS  ordCnt=1"
      passed := passed + 1
    ELSE
      PRINT "Test C FAIL  ordCnt exp=1 got="; ordCnt
      failed := failed + 1
    ENDIF
    IF ordId(1) = 4 THEN
      PRINT "Test C PASS  ordId(1)=4 (Shady)"
      passed := passed + 1
    ELSE
      PRINT "Test C FAIL  ordId(1) exp=4 got="; ordId(1)
      failed := failed + 1
    ENDIF
    IF ordQty(1) = 20 THEN
      PRINT "Test C PASS  ordQty(1)=20"
      passed := passed + 1
    ELSE
      PRINT "Test C FAIL  ordQty(1) exp=20 got="; ordQty(1)
      failed := failed + 1
    ENDIF
    IF ordPurch(1) = 1 THEN
      PRINT "Test C PASS  ordPurch(1)=1 (CASH)"
      passed := passed + 1
    ELSE
      PRINT "Test C FAIL  ordPurch(1) exp=1 got="; ordPurch(1)
      failed := failed + 1
    ENDIF
RETURN

! ---- Test D assertions: bond fallback ----------------------

300 \ ! ordCnt=1, ordType(1)=2, ordId(1)=2, ordQty(1)=1
    IF ordCnt = 1 THEN
      PRINT "Test D PASS  ordCnt=1"
      passed := passed + 1
    ELSE
      PRINT "Test D FAIL  ordCnt exp=1 got="; ordCnt
      failed := failed + 1
    ENDIF
    IF ordType(1) = 2 THEN
      PRINT "Test D PASS  ordType(1)=2 (BOND)"
      passed := passed + 1
    ELSE
      PRINT "Test D FAIL  ordType(1) exp=2 got="; ordType(1)
      failed := failed + 1
    ENDIF
    IF ordId(1) = 2 THEN
      PRINT "Test D PASS  ordId(1)=2 (medium bond)"
      passed := passed + 1
    ELSE
      PRINT "Test D FAIL  ordId(1) exp=2 got="; ordId(1)
      failed := failed + 1
    ENDIF
    IF ordQty(1) = 1 THEN
      PRINT "Test D PASS  ordQty(1)=1"
      passed := passed + 1
    ELSE
      PRINT "Test D FAIL  ordQty(1) exp=1 got="; ordQty(1)
      failed := failed + 1
    ENDIF
RETURN

! ---- Test E assertions: bond skip --------------------------

400 \ ! ordCnt=1, only a stock order (no bond)
    IF ordCnt = 1 THEN
      PRINT "Test E PASS  ordCnt=1 (stock only)"
      passed := passed + 1
    ELSE
      PRINT "Test E FAIL  ordCnt exp=1 got="; ordCnt
      failed := failed + 1
    ENDIF
    IF ordType(1) = 1 THEN
      PRINT "Test E PASS  ordType(1)=1 (STOCK, no bond)"
      passed := passed + 1
    ELSE
      PRINT "Test E FAIL  ordType(1) exp=1 got="; ordType(1)
      failed := failed + 1
    ENDIF
RETURN

900 PRINT "TSTAIBUY error ("; ERR; ")"
    END
