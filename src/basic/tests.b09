      failed := failed + 1
    ENDIF
    PRINT
RETURN

900 PRINT "Runtime error "; ERR; " in TSTYRHDR"
    END

PROCEDURE TSTDVINT
(* ============================================================ *)
(* PROCEDURE : TSTDVINT                                         *)
(* PURPOSE   : Confirmation tests for scrDivInt (Task 8.2).    *)
(*             Two visual test cases per spec 8.2:             *)
(*               Test 1 — spec confirmation case:              *)
(*                 Shady Brooks 100 shares = $700,             *)
(*                 1 medium bond = $250,                       *)
(*                 cashBef=5000, totRcvd=950, cashAft=5950.    *)
(*                 Verify all figures render correctly.        *)
(*               Test 2 — all-zero case:                       *)
(*                 All divRcvd=0, all bndInt=0.                *)
(*                 Verify "(none)" shown in both sections.     *)
(*             Visual output verified manually by tester.      *)
(*             Machine check: action = 1 (CONTINUE) each call. *)
(* PARAMS    : none                                             *)
(* SIDE EFX  : Calls scrDivInt twice; clears screen each call. *)
(* ============================================================ *)
DIM divRcvd(9) : INTEGER
DIM bndInt(3)  : INTEGER
DIM action     : BYTE
DIM passed     : INTEGER
DIM failed     : INTEGER
DIM s          : INTEGER
DIM b          : INTEGER

ON ERROR GOTO 900

passed := 0
failed := 0

! -- Test 1: spec confirmation case ---------------------------
! Year 2, player ALICE, 100 shares Shady Brooks (stock 4, $7)
! = $700 dividend, 1 medium bond (bond 2) = $250 interest.
! cashBef=5000, totRcvd=950, cashAft=5950.
PRINT "Test 1: Year 2, Shady Brooks $700, medium bond $250."
PRINT "Expect: Shady Brooks $   700 under DIVIDENDS RECEIVED."
PRINT "Expect: Medium       $   250 under BOND INTEREST."
PRINT "Expect: Total received $  950, cash 5000 -> 5950."
PRINT "Press any key to launch screen."
RUN waitKey

FOR s := 1 TO 9
  divRcvd(s) := 0
NEXT s
FOR b := 1 TO 3
  bndInt(b) := 0
NEXT b
divRcvd(4) := 700
bndInt(2)  := 250

RUN scrDivInt(2, "ALICE", 5000, divRcvd, bndInt, 950, 5950, action)
GOSUB 100

! -- Test 2: all-zero case ------------------------------------
! No dividends received, no bond interest.
! Expect "(none)" in both sections. totRcvd=0, cash unchanged.
PRINT "Test 2: Year 5, no dividends, no bond interest."
PRINT "Expect: (none) under DIVIDENDS RECEIVED."
PRINT "Expect: (none) under BOND INTEREST."
PRINT "Expect: Total received $     0, cash 3000 -> 3000."
PRINT "Press any key to launch screen."
RUN waitKey

FOR s := 1 TO 9
  divRcvd(s) := 0
NEXT s
FOR b := 1 TO 3
  bndInt(b) := 0
NEXT b

RUN scrDivInt(5, "BOB", 3000, divRcvd, bndInt, 0, 3000, action)
GOSUB 200

PRINT
PRINT "Results: "; passed; " passed, "; failed; " failed."
END

100 ! Test 1 action check
    IF action = 1 THEN
      PRINT "Test 1 PASS  action=1 (CONTINUE)"
      passed := passed + 1
    ELSE
      PRINT "Test 1 FAIL  action: exp=1 got="; action
      failed := failed + 1
    ENDIF
    PRINT
RETURN

200 ! Test 2 action check
    IF action = 1 THEN
      PRINT "Test 2 PASS  action=1 (CONTINUE)"
      passed := passed + 1
    ELSE
      PRINT "Test 2 FAIL  action: exp=1 got="; action
      failed := failed + 1
    ENDIF
    PRINT
RETURN

900 PRINT "Runtime error "; ERR; " in TSTDVINT"
    END

PROCEDURE TSTCRDSCR
(* ============================================================ *)
(* PROCEDURE : TSTCRDSCR                                        *)
(* PURPOSE   : Confirmation tests for scrCard (Task 8.3).      *)
(*             Three visual test cases per spec 8.3:           *)
(*               Test 1 — Card 1 (Bear, Growth Corp +10,       *)
(*                         divBonus=$2): verify market type,   *)
(*                         flavour text, delta, bonus line.    *)
(*               Test 2 — Card 34 (Bull, 4 stocks): verify all *)
(*                         four stocks and positive deltas.    *)
(*               Test 3 — Card 36 (Bear, 3 stocks): verify     *)
(*                         negative deltas render with sign.   *)
(*             Visual output verified manually by tester.      *)
(*             Machine check: action = 1 (CONTINUE) each call. *)
(* PARAMS    : none                                             *)
(* SIDE EFX  : Calls scrCard 3 times; clears screen each call. *)
(*             Calls getCard 3 times; repositions DATA pointer.*)
(* ============================================================ *)
! Line exceeds 79 chars; TYPE statement requires single line.
TYPE CardRec = crdType:INTEGER;efxCnt:INTEGER;efxStk(4):INTEGER;efxDlt(4):INTEGER;divBonus:INTEGER
DIM card    : CardRec
DIM flavTxt : STRING[160]
DIM action  : BYTE
DIM passed  : INTEGER
DIM failed  : INTEGER

ON ERROR GOTO 900

passed := 0
failed := 0

PRINT "=== TSTCRDSCR ==="
PRINT

! ---- Test 1: Card 1 — Bear, Growth Corp +10, divBonus=2 -----
PRINT "Test 1: Card 1 (Bear, Growth Corp +10, divBonus=2)."
PRINT "Expect: SITUATION CARD #1"
PRINT "Expect: BEAR MARKET"
PRINT "Expect: flavour text re: year-end dividend."
PRINT "Expect: Growth Corp   +10"
PRINT "Expect: DIVIDEND BONUS: $2 per share"
PRINT "Press any key to launch screen."
RUN waitKey
RUN getCard(1, card)
flavTxt := "Extra year-end dividend of $2 per share declared by the Board of Directors."
RUN scrCard(1, card, flavTxt, action)
GOSUB 100

! ---- Test 2: Card 34 — Bull, 4 stocks -----------------------
PRINT "Test 2: Card 34 (Bull, 4 stocks)."
PRINT "Expect: SITUATION CARD #34"
PRINT "Expect: BULL MARKET"
PRINT "Expect: flavour text re: general market rise."
PRINT "Expect: Growth Corp   +8"
PRINT "Expect: Metro Props   +5"
PRINT "Expect: Pioneer Mut   +5"
PRINT "Expect: United Auto   +7"
PRINT "Expect: no dividend bonus line."
PRINT "Press any key to launch screen."
RUN waitKey
RUN getCard(34, card)
flavTxt := "General market rise over the last two months."
RUN scrCard(34, card, flavTxt, action)
GOSUB 200

! ---- Test 3: Card 36 — Bear, 3 stocks, negative deltas ------
PRINT "Test 3: Card 36 (Bear, 3 stocks, negative deltas)."
PRINT "Expect: SITUATION CARD #36"
PRINT "Expect: BEAR MARKET"
PRINT "Expect: flavour text re: profit taking."
PRINT "Expect: Growth Corp   -8"
PRINT "Expect: Metro Props   -5"
PRINT "Expect: United Auto   -7"
PRINT "Expect: no dividend bonus line."
PRINT "Press any key to launch screen."
RUN waitKey
RUN getCard(36, card)
flavTxt := "Surge of profit taking drops stock market."
RUN scrCard(36, card, flavTxt, action)
GOSUB 300

PRINT
PRINT "Results: "; passed; " passed, "; failed; " failed."
END

100 ! Test 1 action check
    IF action = 1 THEN
      PRINT "Test 1 PASS  action=1 (CONTINUE)"
      passed := passed + 1
    ELSE
      PRINT "Test 1 FAIL  action: exp=1 got="; action
      failed := failed + 1
    ENDIF
    PRINT
RETURN

200 ! Test 2 action check
    IF action = 1 THEN
      PRINT "Test 2 PASS  action=1 (CONTINUE)"
      passed := passed + 1
    ELSE
      PRINT "Test 2 FAIL  action: exp=1 got="; action
      failed := failed + 1
    ENDIF
    PRINT
RETURN

300 ! Test 3 action check
    IF action = 1 THEN
      PRINT "Test 3 PASS  action=1 (CONTINUE)"
      passed := passed + 1
    ELSE
      PRINT "Test 3 FAIL  action: exp=1 got="; action
      failed := failed + 1
    ENDIF
    PRINT
RETURN

900 PRINT "Runtime error "; ERR; " in TSTCRDSCR"
    END

PROCEDURE TSTDICE
(* ============================================================ *)
(* PROCEDURE : TSTDICE                                          *)
(* PURPOSE   : Confirmation tests for scrDice (Task 8.4).      *)
(*             Three visual test cases:                        *)
(*               Test 1 — Mode A: single roll die1=3 die2=4   *)
(*                         total=7. Verify "ROLL MODE A" label  *)
(*                         and three die/total lines.           *)
(*               Test 2 — Mode B: single roll die1=5 die2=5   *)
(*                         total=10. Verify "ROLL MODE B" label *)
(*                         and distinct values from Test 1.    *)
(*               Test 3 — Mode C: 9 rolls (one per stock).     *)
(*                         Verify "ROLL MODE C" label and all   *)
(*                         9 stock rows with correct totals.   *)
(*             Visual output verified manually by tester.      *)
(*             Machine check: action = 1 (CONTINUE) each call. *)
(* PARAMS    : none                                             *)
(* SIDE EFX  : Calls scrDice 3 times; clears screen each call. *)
(* ============================================================ *)
DIM dieOne(9)  : BYTE
DIM dieTwo(9)  : BYTE
DIM rollTot(9) : BYTE
DIM action     : BYTE
DIM passed     : INTEGER
DIM failed     : INTEGER
DIM i          : INTEGER

ON ERROR GOTO 900

passed := 0
failed := 0

! ---- Test 1: Mode A — single roll, total=7 ------------------
PRINT "Test 1: Mode A. Single roll, die1=3, die2=4, total=7."
PRINT "Expect: ROLL MODE A"
PRINT "Expect: Die 1:  3"
PRINT "Expect: Die 2:  4"
PRINT "Expect: Total:  7"
PRINT "Press any key to launch screen."
RUN waitKey

FOR i := 1 TO 9
  dieOne(i)  := 0
  dieTwo(i)  := 0
  rollTot(i) := 0
NEXT i
dieOne(1)  := 3
dieTwo(1)  := 4
rollTot(1) := 7

RUN scrDice(1, 1, dieOne, dieTwo, rollTot, action)
GOSUB 100

! ---- Test 2: Mode B — single roll, total=10 -----------------
PRINT "Test 2: Mode B. Single roll, die1=5, die2=5, total=10."
PRINT "Expect: ROLL MODE B"
PRINT "Expect: Die 1:  5"
PRINT "Expect: Die 2:  5"
PRINT "Expect: Total:  10"
PRINT "Press any key to launch screen."
RUN waitKey

FOR i := 1 TO 9
  dieOne(i)  := 0
  dieTwo(i)  := 0
  rollTot(i) := 0
NEXT i
dieOne(1)  := 5
dieTwo(1)  := 5
rollTot(1) := 10

RUN scrDice(2, 1, dieOne, dieTwo, rollTot, action)
GOSUB 200

! ---- Test 3: Mode C — 9 rolls, one per stock ----------------
PRINT "Test 3: Mode C. 9 per-stock rolls."
PRINT "Expect: ROLL MODE C  (per stock)"
PRINT "Expect: 9 rows, one per stock."
PRINT "Expected totals by stock:"
PRINT "  Growth Corp   1+2=  3"
PRINT "  Metro Props   2+3=  5"
PRINT "  Pioneer Mut   3+4=  7"
PRINT "  Shady Brooks  4+5=  9"
PRINT "  Stryker Drlg  5+6= 11"
PRINT "  Tri-City Trn  6+6= 12"
PRINT "  United Auto   1+1=  2"
PRINT "  Uranium Ent   2+4=  6"
PRINT "  Valley Power  3+5=  8"
PRINT "Press any key to launch screen."
RUN waitKey

dieOne(1) := 1 \ dieTwo(1) := 2 \ rollTot(1) := 3
dieOne(2) := 2 \ dieTwo(2) := 3 \ rollTot(2) := 5
dieOne(3) := 3 \ dieTwo(3) := 4 \ rollTot(3) := 7
dieOne(4) := 4 \ dieTwo(4) := 5 \ rollTot(4) := 9
dieOne(5) := 5 \ dieTwo(5) := 6 \ rollTot(5) := 11
dieOne(6) := 6 \ dieTwo(6) := 6 \ rollTot(6) := 12
dieOne(7) := 1 \ dieTwo(7) := 1 \ rollTot(7) := 2
dieOne(8) := 2 \ dieTwo(8) := 4 \ rollTot(8) := 6
dieOne(9) := 3 \ dieTwo(9) := 5 \ rollTot(9) := 8

RUN scrDice(3, 9, dieOne, dieTwo, rollTot, action)
GOSUB 300

PRINT
PRINT "Results: "; passed; " passed, "; failed; " failed."
END

100 ! Test 1 action check
    IF action = 1 THEN
      PRINT "Test 1 PASS  action=1 (CONTINUE)"
      passed := passed + 1
    ELSE
      PRINT "Test 1 FAIL  action: exp=1 got="; action
      failed := failed + 1
    ENDIF
    PRINT
RETURN

200 ! Test 2 action check
    IF action = 1 THEN
      PRINT "Test 2 PASS  action=1 (CONTINUE)"
      passed := passed + 1
    ELSE
      PRINT "Test 2 FAIL  action: exp=1 got="; action
      failed := failed + 1
    ENDIF
    PRINT
RETURN

300 ! Test 3 action check
    IF action = 1 THEN
      PRINT "Test 3 PASS  action=1 (CONTINUE)"
      passed := passed + 1
    ELSE
      PRINT "Test 3 FAIL  action: exp=1 got="; action
      failed := failed + 1
    ENDIF
    PRINT
RETURN

900 PRINT "Runtime error "; ERR; " in TSTDICE"
    END


PROCEDURE TSTMKTBRD
(* ============================================================ *)
(* PROCEDURE : TSTMKTBRD                                        *)
(* PURPOSE   : Confirmation tests for scrMktBoard (Task 8.5).  *)
(*             One visual test case per spec 8.5:              *)
(*               Stock 5 (Stryker Drlg): split. prcBefCrd=173, *)
(*                 mktDlta=+73, crdDlta=0, newPrc=87.          *)
(*                 Expect flag SPLT.                            *)
(*               Stock 2 (Metro Props): suspended. prcBefCrd=40*)
(*                 mktDlta=-60, crdDlta=0, newPrc=40.          *)
(*                 Expect flag SUSP.                            *)
(*               Stock 8 (Uranium Ent): reinstated. prcBefCrd= *)
(*                 60, mktDlta=+20, crdDlta=0, newPrc=60.      *)
(*                 Expect flag RSTD.                            *)
(*               Stock 3 (Pioneer Mut): bankruptcy. prcBefCrd= *)
(*                 -5, mktDlta=-15, crdDlta=0, newPrc=0.       *)
(*                 Expect flag BKRT.                            *)
(*               Stocks 1,4,6,7,9: neutral. prcBefCrd=100,    *)
(*                 mktDlta=0, crdDlta=0, newPrc=100, no flag.  *)
(*             Visual output verified manually by tester.      *)
(*             Machine check: action = 1 (CONTINUE).           *)
(* PARAMS    : none                                             *)
(* SIDE EFX  : Calls scrMktBoard; clears screen.               *)
(* ============================================================ *)
DIM prcBefCrd(9) : INTEGER
DIM mktDlta(9)   : INTEGER
DIM crdDlta(9)   : INTEGER
DIM newPrc(9)    : INTEGER
DIM splitOcc(9)  : BOOLEAN
DIM divSuspd(9)  : BOOLEAN
DIM divRnstd(9)  : BOOLEAN
DIM action       : BYTE
DIM passed       : INTEGER
DIM failed       : INTEGER
DIM s            : INTEGER

ON ERROR GOTO 900

passed := 0
failed := 0

PRINT "=== TSTMKTBRD ==="
PRINT

! ---- Initialise all stocks to neutral ----------------------
FOR s := 1 TO 9
  prcBefCrd(s) := 100
  mktDlta(s)   := 0
  crdDlta(s)   := 0
  newPrc(s)    := 100
  splitOcc(s)  := FALSE
  divSuspd(s)  := FALSE
  divRnstd(s)  := FALSE
NEXT s

! ---- Stock 2 (Metro Props): suspended ----------------------
! Original price ~100, mktDlta=-60 → prcBefCrd=40, newPrc=40.
! 40 < DividendCutoff(50) → divSuspd=TRUE.
prcBefCrd(2) := 40
mktDlta(2)   := -60
crdDlta(2)   := 0
newPrc(2)    := 40
divSuspd(2)  := TRUE

! ---- Stock 3 (Pioneer Mut): bankruptcy floor ---------------
! Original ~10, mktDlta=-15 → prcBefCrd=-5 (unclamped).
! newPrc clamped to 0. Flag = BKRT (overrides all others).
prcBefCrd(3) := -5
mktDlta(3)   := -15
crdDlta(3)   := 0
newPrc(3)    := 0
divSuspd(3)  := TRUE

! ---- Stock 5 (Stryker Drlg): split ------------------------
! Original 100, mktDlta=+73 → prcBefCrd=173.
! resolvePrice: 173 >= 150 → split to (173+1)/2=87.
prcBefCrd(5) := 173
mktDlta(5)   := 73
crdDlta(5)   := 0
newPrc(5)    := 87
splitOcc(5)  := TRUE

! ---- Stock 8 (Uranium Ent): reinstated --------------------
! Original price ~40 (was suspended), mktDlta=+20 → prcBefCrd=60.
! 60 >= DividendCutoff(50) → reinstated.
prcBefCrd(8) := 60
mktDlta(8)   := 20
crdDlta(8)   := 0
newPrc(8)    := 60
divRnstd(8)  := TRUE

! ---- Expected output summary to guide tester ---------------
PRINT "Expected board layout:"
PRINT "  Stock 2  Metro Props:   PREV  40  MKT -60  NEW  40  SUSP"
PRINT "  Stock 3  Pioneer Mut:   PREV  -5  MKT -15  NEW   0  BKRT"
PRINT "  Stock 5  Stryker Drlg:  PREV 173  MKT +73  NEW  87  SPLT"
PRINT "  Stock 8  Uranium Ent:   PREV  60  MKT +20  NEW  60  RSTD"
PRINT "  All other stocks:       PREV 100  MKT   0  NEW 100  (blank)"
PRINT
PRINT "Press any key to launch screen."
RUN waitKey

RUN scrMktBoard(prcBefCrd, mktDlta, crdDlta, newPrc, splitOcc, divSuspd, divRnstd, action)
GOSUB 100

PRINT
PRINT "Results: "; passed; " passed, "; failed; " failed."
END

100 ! Action check
    IF action = 1 THEN
      PRINT "PASS  action=1 (CONTINUE)"
      passed := passed + 1
    ELSE
      PRINT "FAIL  action: exp=1 got="; action
      failed := failed + 1
    ENDIF
    PRINT
RETURN

900 PRINT "Runtime error "; ERR; " in TSTMKTBRD"
    END
