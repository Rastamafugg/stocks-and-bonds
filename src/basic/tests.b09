PROCEDURE TSTSIZE
(* ================================================= *)
(* PROCEDURE: TSTSIZE                               *)
(* PURPOSE  : Confirmation Test 1.1.                *)
(*            Prints SIZE() of each shared TYPE.    *)
(*            Expected output:                      *)
(*              SaveHdr  : 11                       *)
(*              PlyrRec  : 61                       *)
(*              MktState : 27                       *)
(*              AIProfile: 15                       *)
(* PARAMS   : None.                                 *)
(* SIDE FX  : Writes to stdout.                     *)
(* ================================================= *)

! Line exceeds 79 chars; TYPE statement requires single line.
TYPE SaveHdr = magic,fmtVersion,currYear,plyrCount,rollMode,savedPhase,savedPlyr,deckPos,checksum:BYTE;obligation:INTEGER

! Line exceeds 79 chars; TYPE statement requires single line.
TYPE PlyrRec = plyrName:STRING[20];plyrType,aiTier:BYTE;cashBal,marginTot:INTEGER;isBankrupt,hadCashPur:BOOLEAN;stckShrs(9):INTEGER;mgnHeld(9):BOOLEAN;bondUnts(3):INTEGER

TYPE MktState = stckPrice(9):INTEGER;divSuspnd(9):BOOLEAN

! Line exceeds 79 chars; TYPE statement requires single line.
TYPE AIProfile = tier,concenCap,spltSlPct,distSlPrc,mgnMaxExpo,mgnBuffer,mgnResvPct,repayFrac,mgnClrYear,endgameYr:BYTE;bondIdlCsh:INTEGER;zeroDivEl,useMargin,bondPriory:BOOLEAN

! Line exceeds 79 chars; TYPE statement requires single line.
TYPE CardRec = crdType:INTEGER;efxCnt:INTEGER;efxStk(4):INTEGER;efxDlt(4):INTEGER;divBonus:INTEGER

DIM hdr : SaveHdr
DIM plyr: PlyrRec
DIM mkt : MktState
DIM aipr: AIProfile
DIM card: CardRec

ON ERROR GOTO 900

PRINT "SaveHdr  : "; SIZE(hdr)
PRINT "PlyrRec  : "; SIZE(plyr)
PRINT "MktState : "; SIZE(mkt)
PRINT "AIProfile: "; SIZE(aipr)
PRINT "CardRec  : "; SIZE(card)
END

900 ! Error handler
    PRINT "Error: "; ERR
END

PROCEDURE TSTINIT
(* ================================================= *)
(* PROCEDURE: TSTINIT                               *)
(* PURPOSE  : Confirmation Test 1.2.                *)
(*            Calls initPlayer for slots 1-6.       *)
(*            Prints cashBal, marginTot, isBankrupt  *)
(*            for each slot.                         *)
(*            Expected output per slot:             *)
(*              cashBal=5000 marginTot=0            *)
(*              isBankrupt=FALSE                    *)
(* PARAMS   : None.                                 *)
(* SIDE FX  : Writes to stdout.                     *)
(* ================================================= *)

! Line exceeds 79 chars; TYPE statement requires single line.
TYPE PlyrRec = plyrName:STRING[20];plyrType,aiTier:BYTE;cashBal,marginTot:INTEGER;isBankrupt,hadCashPur:BOOLEAN;stckShrs(9):INTEGER;mgnHeld(9):BOOLEAN;bondUnts(3):INTEGER

DIM plyrs(6): PlyrRec
DIM i: INTEGER

ON ERROR GOTO 900

FOR i := 1 TO 6
    RUN initPlayer(plyrs(i))
NEXT i

FOR i := 1 TO 6
    PRINT "Slot "; i; ": cashBal="; plyrs(i).cashBal;
    PRINT " marginTot="; plyrs(i).marginTot;
    PRINT " isBankrupt="; plyrs(i).isBankrupt
NEXT i

END

900 ! Error handler
    PRINT "Error: "; ERR
END

PROCEDURE TSTMKT
(* ================================================= *)
(* PROCEDURE: TSTMKT                                 *)
(* PURPOSE  : Confirmation Test 1.3.                 *)
(*            Calls initMkt and prints stckPrice and *)
(*            divSuspnd for all 9 stocks.            *)
(*            Expected output per stock:             *)
(*              stckPrice=100 divSuspnd=FALSE        *)
(* PARAMS   : None.                                  *)
(* SIDE FX  : Writes to stdout.                      *)
(* ================================================= *)

TYPE MktState = stckPrice(9):INTEGER;divSuspnd(9):BOOLEAN

DIM mkt: MktState
DIM i:   INTEGER

ON ERROR GOTO 900

RUN initMkt(mkt)

FOR i := 1 TO 9
    PRINT "Stock "; i; ": stckPrice="; mkt.stckPrice(i);
    PRINT " divSuspnd="; mkt.divSuspnd(i)
NEXT i

END

PROCEDURE TSTAIPROF
(* ================================================= *)
(* PROCEDURE: TSTAIPROF                              *)
(* PURPOSE  : Confirmation Test 1.4.                 *)
(*            Calls initAIProf for tiers 1, 2, 3    *)
(*            and prints all AIProfile fields.       *)
(*            Verify each output column against      *)
(*            ai-difficulty-tiers.md Section 4.      *)
(* PARAMS   : None.                                  *)
(* SIDE FX  : Writes to stdout.                      *)
(* ================================================= *)

! Line exceeds 79 chars; TYPE statement requires single line.
TYPE AIProfile = tier,concenCap,spltSlPct,distSlPrc,mgnMaxExpo,mgnBuffer,mgnResvPct,repayFrac,mgnClrYear,endgameYr,spltSlPcE,repayFrcE:BYTE;bondIdlCsh,bndIdlCsE:INTEGER;zeroDivEl,useYldScr,useMargin,bondPriory:BOOLEAN

DIM prof: AIProfile
DIM t:    INTEGER

ON ERROR GOTO 900

FOR t := 1 TO 3
    RUN initAIProf(t, prof)
    PRINT "--- Tier "; t; " ---"
    PRINT "tier=";       prof.tier
    PRINT "concenCap=";  prof.concenCap
    PRINT "spltSlPct=";  prof.spltSlPct
    PRINT "distSlPrc=";  prof.distSlPrc
    PRINT "mgnMaxExpo="; prof.mgnMaxExpo
    PRINT "mgnBuffer=";  prof.mgnBuffer
    PRINT "mgnResvPct="; prof.mgnResvPct
    PRINT "repayFrac=";  prof.repayFrac
    PRINT "mgnClrYear="; prof.mgnClrYear
    PRINT "endgameYr=";  prof.endgameYr
    PRINT "spltSlPcE=";  prof.spltSlPcE
    PRINT "repayFrcE=";  prof.repayFrcE
    PRINT "bondIdlCsh="; prof.bondIdlCsh
    PRINT "bndIdlCsE=";  prof.bndIdlCsE
    PRINT "zeroDivEl=";  prof.zeroDivEl
    PRINT "useYldScr=";  prof.useYldScr
    PRINT "useMargin=";  prof.useMargin
    PRINT "bondPriory="; prof.bondPriory
NEXT t

END

900 ! Error handler
    PRINT "Error: "; ERR
END

PROCEDURE TSTMKTDLTA
(* ============================================================ *)
(* PROCEDURE : TSTMKTDLTA                                       *)
(* PURPOSE   : Confirmation tests for getMktDelta (Task 2.1).  *)
(*             Runs five test cases, prints PASS or FAIL with  *)
(*             expected and actual values on failure.           *)
(* PARAMS    : none                                             *)
(* ============================================================ *)
DIM delta    : INTEGER
DIM passed   : INTEGER
DIM failed   : INTEGER

ON ERROR GOTO 900

passed := 0
failed := 0

! ---- Test 1: Stryker Drilling, Bull, roll=9, expected=67 ----
RUN getMktDelta(5, 1, 9, delta)
GOSUB 100

! ---- Test 2: Stryker Drilling, Bear, roll=4, expected=-20 ---
RUN getMktDelta(5, 2, 4, delta)
GOSUB 200

! ---- Test 3: Valley Power, Bull, roll=7, expected=14 --------
RUN getMktDelta(9, 1, 7, delta)
GOSUB 300

! ---- Test 4: Valley Power, Bear, roll=2, expected=8 ---------
RUN getMktDelta(9, 2, 2, delta)
GOSUB 400

! ---- Test 5: Growth Corp, Bull, roll=2, expected=-2 ---------
RUN getMktDelta(1, 1, 2, delta)
GOSUB 500

PRINT
PRINT "Results: "; passed; " passed, "; failed; " failed."
END

100 ! Test 1 check
    IF delta = 67 THEN
      PRINT "Test 1 PASS  getMktDelta(5,1,9) = 67"
      passed := passed + 1
    ELSE
      PRINT "Test 1 FAIL  getMktDelta(5,1,9)"
      PRINT "  expected=67  actual="; delta
      failed := failed + 1
    ENDIF
    RETURN

200 ! Test 2 check
    IF delta = -20 THEN
      PRINT "Test 2 PASS  getMktDelta(5,2,4) = -20"
      passed := passed + 1
    ELSE
      PRINT "Test 2 FAIL  getMktDelta(5,2,4)"
      PRINT "  expected=-20  actual="; delta
      failed := failed + 1
    ENDIF
    RETURN

300 ! Test 3 check
    IF delta = 14 THEN
      PRINT "Test 3 PASS  getMktDelta(9,1,7) = 14"
      passed := passed + 1
    ELSE
      PRINT "Test 3 FAIL  getMktDelta(9,1,7)"
      PRINT "  expected=14  actual="; delta
      failed := failed + 1
    ENDIF
    RETURN

400 ! Test 4 check
    IF delta = 8 THEN
      PRINT "Test 4 PASS  getMktDelta(9,2,2) = 8"
      passed := passed + 1
    ELSE
      PRINT "Test 4 FAIL  getMktDelta(9,2,2)"
      PRINT "  expected=8  actual="; delta
      failed := failed + 1
    ENDIF
    RETURN

500 ! Test 5 check
    IF delta = -2 THEN
      PRINT "Test 5 PASS  getMktDelta(1,1,2) = -2"
      passed := passed + 1
    ELSE
      PRINT "Test 5 FAIL  getMktDelta(1,1,2)"
      PRINT "  expected=-2  actual="; delta
      failed := failed + 1
    ENDIF
    RETURN

900 PRINT "Runtime error "; ERR; " in TSTMKT"
    END

PROCEDURE TSTCARD
(* ============================================================ *)
(* PROCEDURE : TSTCARD                                          *)
(* PURPOSE   : Confirmation tests for getCard (Task 2.2).      *)
(*             Runs five test cases covering boundary cards,    *)
(*             anomaly classifications, multi-stock cards, and  *)
(*             divBonus. Prints per-field FAIL detail and a     *)
(*             final pass/fail summary.                         *)
(* PARAMS    : none                                             *)
(* ============================================================ *)
! Line exceeds 79 chars; TYPE statement requires single line.
TYPE CardRec = crdType:INTEGER;efxCnt:INTEGER;efxStk(4):INTEGER;efxDlt(4):INTEGER;divBonus:INTEGER
DIM card   : CardRec
DIM passed : INTEGER
DIM failed : INTEGER
DIM ok     : BOOLEAN

ON ERROR GOTO 900

passed := 0
failed := 0

! Test 1: Card 1 - Bear anomaly, Growth Corp +10, divBonus=2
RUN getCard(1, card)
GOSUB 100

! Test 2: Card 5 - Bull anomaly, Growth Corp -10, divBonus=0
RUN getCard(5, card)
GOSUB 200

! Test 3: Card 8 - Bear anomaly, Metro Properties +10, divBonus=0
RUN getCard(8, card)
GOSUB 300

! Test 4: Card 34 - Bull, 4 stocks, correct deltas
RUN getCard(34, card)
GOSUB 400

! Test 5: Card 36 - Bear, 3 stocks, correct deltas
RUN getCard(36, card)
GOSUB 500

PRINT
PRINT "Results: "; passed; " passed, "; failed; " failed."
END

100 ! Test 1: Card 1 Bear, stk=1 dlt=10, divBonus=2
    ok := TRUE
    IF card.crdType <> 2 THEN
      PRINT "Test 1 FAIL crdType: exp=2 got="; card.crdType
      ok := FALSE
    ENDIF
    IF card.efxCnt <> 1 THEN
      PRINT "Test 1 FAIL efxCnt: exp=1 got="; card.efxCnt
      ok := FALSE
    ENDIF
    IF card.efxStk(1) <> 1 THEN
      PRINT "Test 1 FAIL efxStk(1): exp=1 got="; card.efxStk(1)
      ok := FALSE
    ENDIF
    IF card.efxDlt(1) <> 10 THEN
      PRINT "Test 1 FAIL efxDlt(1): exp=10 got="; card.efxDlt(1)
      ok := FALSE
    ENDIF
    IF card.divBonus <> 2 THEN
      PRINT "Test 1 FAIL divBonus: exp=2 got="; card.divBonus
      ok := FALSE
    ENDIF
    IF ok THEN
      PRINT "Test 1 PASS  Card 1 Bear Growth+10 divBonus=2"
      passed := passed + 1
    ELSE
      failed := failed + 1
    ENDIF
    RETURN

200 ! Test 2: Card 5 Bull, stk=1 dlt=-10, divBonus=0
    ok := TRUE
    IF card.crdType <> 1 THEN
      PRINT "Test 2 FAIL crdType: exp=1 got="; card.crdType
      ok := FALSE
    ENDIF
    IF card.efxCnt <> 1 THEN
      PRINT "Test 2 FAIL efxCnt: exp=1 got="; card.efxCnt
      ok := FALSE
    ENDIF
    IF card.efxStk(1) <> 1 THEN
      PRINT "Test 2 FAIL efxStk(1): exp=1 got="; card.efxStk(1)
      ok := FALSE
    ENDIF
    IF card.efxDlt(1) <> -10 THEN
      PRINT "Test 2 FAIL efxDlt(1): exp=-10 got="; card.efxDlt(1)
      ok := FALSE
    ENDIF
    IF card.divBonus <> 0 THEN
      PRINT "Test 2 FAIL divBonus: exp=0 got="; card.divBonus
      ok := FALSE
    ENDIF
    IF ok THEN
      PRINT "Test 2 PASS  Card 5 Bull Growth-10 divBonus=0"
      passed := passed + 1
    ELSE
      failed := failed + 1
    ENDIF
    RETURN

300 ! Test 3: Card 8 Bear, stk=2 dlt=10, divBonus=0
    ok := TRUE
    IF card.crdType <> 2 THEN
      PRINT "Test 3 FAIL crdType: exp=2 got="; card.crdType
      ok := FALSE
    ENDIF
    IF card.efxCnt <> 1 THEN
      PRINT "Test 3 FAIL efxCnt: exp=1 got="; card.efxCnt
      ok := FALSE
    ENDIF
    IF card.efxStk(1) <> 2 THEN
      PRINT "Test 3 FAIL efxStk(1): exp=2 got="; card.efxStk(1)
      ok := FALSE
    ENDIF
    IF card.efxDlt(1) <> 10 THEN
      PRINT "Test 3 FAIL efxDlt(1): exp=10 got="; card.efxDlt(1)
      ok := FALSE
    ENDIF
    IF card.divBonus <> 0 THEN
      PRINT "Test 3 FAIL divBonus: exp=0 got="; card.divBonus
      ok := FALSE
    ENDIF
    IF ok THEN
      PRINT "Test 3 PASS  Card 8 Bear Metro+10 divBonus=0"
      passed := passed + 1
    ELSE
      failed := failed + 1
    ENDIF
    RETURN

400 ! Test 4: Card 34 Bull, 4 stocks
    ok := TRUE
    IF card.crdType <> 1 THEN
      PRINT "Test 4 FAIL crdType: exp=1 got="; card.crdType
      ok := FALSE
    ENDIF
    IF card.efxCnt <> 4 THEN
      PRINT "Test 4 FAIL efxCnt: exp=4 got="; card.efxCnt
      ok := FALSE
    ENDIF
    IF card.efxStk(1) <> 1 THEN
      PRINT "Test 4 FAIL efxStk(1): exp=1 got="; card.efxStk(1)
      ok := FALSE
    ENDIF
    IF card.efxDlt(1) <> 8 THEN
      PRINT "Test 4 FAIL efxDlt(1): exp=8 got="; card.efxDlt(1)
      ok := FALSE
    ENDIF
    IF card.efxStk(2) <> 2 THEN
      PRINT "Test 4 FAIL efxStk(2): exp=2 got="; card.efxStk(2)
      ok := FALSE
    ENDIF
    IF card.efxDlt(2) <> 5 THEN
      PRINT "Test 4 FAIL efxDlt(2): exp=5 got="; card.efxDlt(2)
      ok := FALSE
    ENDIF
    IF card.efxStk(3) <> 3 THEN
      PRINT "Test 4 FAIL efxStk(3): exp=3 got="; card.efxStk(3)
      ok := FALSE
    ENDIF
    IF card.efxDlt(3) <> 5 THEN
      PRINT "Test 4 FAIL efxDlt(3): exp=5 got="; card.efxDlt(3)
      ok := FALSE
    ENDIF
    IF card.efxStk(4) <> 7 THEN
      PRINT "Test 4 FAIL efxStk(4): exp=7 got="; card.efxStk(4)
      ok := FALSE
    ENDIF
    IF card.efxDlt(4) <> 7 THEN
      PRINT "Test 4 FAIL efxDlt(4): exp=7 got="; card.efxDlt(4)
      ok := FALSE
    ENDIF
    IF card.divBonus <> 0 THEN
      PRINT "Test 4 FAIL divBonus: exp=0 got="; card.divBonus
      ok := FALSE
    ENDIF
    IF ok THEN
      PRINT "Test 4 PASS  Card 34 Bull 4-stock deltas correct"
      passed := passed + 1
    ELSE
      failed := failed + 1
    ENDIF
    RETURN

500 ! Test 5: Card 36 Bear, 3 stocks
    ok := TRUE
    IF card.crdType <> 2 THEN
      PRINT "Test 5 FAIL crdType: exp=2 got="; card.crdType
      ok := FALSE
    ENDIF
    IF card.efxCnt <> 3 THEN
      PRINT "Test 5 FAIL efxCnt: exp=3 got="; card.efxCnt
      ok := FALSE
    ENDIF
    IF card.efxStk(1) <> 1 THEN
      PRINT "Test 5 FAIL efxStk(1): exp=1 got="; card.efxStk(1)
      ok := FALSE
    ENDIF
    IF card.efxDlt(1) <> -8 THEN
      PRINT "Test 5 FAIL efxDlt(1): exp=-8 got="; card.efxDlt(1)
      ok := FALSE
    ENDIF
    IF card.efxStk(2) <> 2 THEN
      PRINT "Test 5 FAIL efxStk(2): exp=2 got="; card.efxStk(2)
      ok := FALSE
    ENDIF
    IF card.efxDlt(2) <> -5 THEN
      PRINT "Test 5 FAIL efxDlt(2): exp=-5 got="; card.efxDlt(2)
      ok := FALSE
    ENDIF
    IF card.efxStk(3) <> 7 THEN
      PRINT "Test 5 FAIL efxStk(3): exp=7 got="; card.efxStk(3)
      ok := FALSE
    ENDIF
    IF card.efxDlt(3) <> -7 THEN
      PRINT "Test 5 FAIL efxDlt(3): exp=-7 got="; card.efxDlt(3)
      ok := FALSE
    ENDIF
    IF card.divBonus <> 0 THEN
      PRINT "Test 5 FAIL divBonus: exp=0 got="; card.divBonus
      ok := FALSE
    ENDIF
    IF ok THEN
      PRINT "Test 5 PASS  Card 36 Bear 3-stock deltas correct"
      passed := passed + 1
    ELSE
      failed := failed + 1
    ENDIF
    RETURN

900 PRINT "Runtime error "; ERR; " in TSTCARD"
    END

PROCEDURE TSTDIVINT
(* ============================================================ *)
(* PROCEDURE : TSTDIVINT                                        *)
(* PURPOSE   : Confirmation tests for applyDivInt (Task 3.1).  *)
(*             Five tests covering: spec confirmation case,     *)
(*             Year 1 guard, Year 10 guard, bankrupt player     *)
(*             skip, and suspended dividend stock.              *)
(* PARAMS    : none                                             *)
(* ============================================================ *)
! Line exceeds 79 chars; TYPE statement requires single line.
TYPE PlyrRec = plyrName:STRING[20];plyrType,aiTier:BYTE;cashBal,marginTot:INTEGER;isBankrupt,hadCashPur:BOOLEAN;stckShrs(9):INTEGER;mgnHeld(9):BOOLEAN;bondUnts(3):INTEGER
TYPE MktState = stckPrice(9):INTEGER;divSuspnd(9):BOOLEAN
DIM plyrs(6) : PlyrRec
DIM mkt      : MktState
DIM passed   : INTEGER
DIM failed   : INTEGER
DIM p        : INTEGER

ON ERROR GOTO 900

passed := 0
failed := 0

! Initialize all six player slots to prevent garbage reads.
FOR p := 1 TO 6
  RUN initPlayer(plyrs(p))
NEXT p
RUN initMkt(mkt)

! ---- Test 1: spec confirmation case -------------------------
! Year 2, 100 shares Shady Brooks (stock 4, $7/share),
! 1 medium bond ($250 interest). Expected: 5000+700+250=5950.
plyrs(1).stckShrs(4) := 100
plyrs(1).bondUnts(2) := 1
RUN applyDivInt(2, 1, plyrs, mkt)
GOSUB 100

! ---- Test 2: Year 1 guard -----------------------------------
RUN initPlayer(plyrs(1))
RUN initMkt(mkt)
plyrs(1).stckShrs(4) := 100
plyrs(1).bondUnts(2) := 1
RUN applyDivInt(1, 1, plyrs, mkt)
GOSUB 200

! ---- Test 3: Year 10 guard ----------------------------------
RUN initPlayer(plyrs(1))
RUN initMkt(mkt)
plyrs(1).stckShrs(4) := 100
plyrs(1).bondUnts(2) := 1
RUN applyDivInt(10, 1, plyrs, mkt)
GOSUB 300

! ---- Test 4: bankrupt player skipped -----------------------
RUN initPlayer(plyrs(1))
RUN initMkt(mkt)
plyrs(1).stckShrs(4) := 100
plyrs(1).bondUnts(2) := 1
plyrs(1).isBankrupt  := TRUE
RUN applyDivInt(2, 1, plyrs, mkt)
GOSUB 400

! ---- Test 5: suspended dividend — bond interest only --------
! Shady Brooks suspended; only medium bond interest applies.
! Expected: 5000 + 250 = 5250.
RUN initPlayer(plyrs(1))
RUN initMkt(mkt)
plyrs(1).stckShrs(4) := 100
plyrs(1).bondUnts(2) := 1
mkt.divSuspnd(4)     := TRUE
RUN applyDivInt(2, 1, plyrs, mkt)
GOSUB 500

PRINT
PRINT "Results: "; passed; " passed, "; failed; " failed."
END

100 ! Test 1: 100 Shady + 1 med bond, Year 2 → 5950
    IF plyrs(1).cashBal = 5950 THEN
      PRINT "Test 1 PASS  Year2 100xShady+1med bond cashBal=5950"
      passed := passed + 1
    ELSE
      PRINT "Test 1 FAIL  exp=5950 got="; plyrs(1).cashBal
      failed := failed + 1
    ENDIF
    RETURN

200 ! Test 2: Year 1 guard → cashBal unchanged
    IF plyrs(1).cashBal = 5000 THEN
      PRINT "Test 2 PASS  Year1 guard cashBal unchanged=5000"
      passed := passed + 1
    ELSE
      PRINT "Test 2 FAIL  exp=5000 got="; plyrs(1).cashBal
      failed := failed + 1
    ENDIF
    RETURN

300 ! Test 3: Year 10 guard → cashBal unchanged
    IF plyrs(1).cashBal = 5000 THEN
      PRINT "Test 3 PASS  Year10 guard cashBal unchanged=5000"
      passed := passed + 1
    ELSE
      PRINT "Test 3 FAIL  exp=5000 got="; plyrs(1).cashBal
      failed := failed + 1
    ENDIF
    RETURN

400 ! Test 4: bankrupt player → cashBal unchanged
    IF plyrs(1).cashBal = 5000 THEN
      PRINT "Test 4 PASS  bankrupt player skipped cashBal=5000"
      passed := passed + 1
    ELSE
      PRINT "Test 4 FAIL  exp=5000 got="; plyrs(1).cashBal
      failed := failed + 1
    ENDIF
    RETURN

500 ! Test 5: Shady suspended → bond interest only → 5250
    IF plyrs(1).cashBal = 5250 THEN
      PRINT "Test 5 PASS  suspended div bond-only cashBal=5250"
      passed := passed + 1
    ELSE
      PRINT "Test 5 FAIL  exp=5250 got="; plyrs(1).cashBal
      failed := failed + 1
    ENDIF
    RETURN

900 PRINT "Runtime error "; ERR; " in TSTDIVINT"
    END

PROCEDURE TSTMGNINT
(* ============================================================ *)
(* PROCEDURE : TSTMGNINT                                        *)
(* PURPOSE   : Confirmation tests for applyMgnInt (Task 3.2).  *)
(*             Six tests covering: spec confirmation case,      *)
(*             Year 1 guard, Year 10 guard, bankrupt player     *)
(*             skip, zero-margin player untouched, and charge   *)
(*             that does not exhaust cash (no forceLiq).        *)
(* PARAMS    : none                                             *)
(* ============================================================ *)
! Line exceeds 79 chars; TYPE statement requires single line.
TYPE PlyrRec = plyrName:STRING[20];plyrType,aiTier:BYTE;cashBal,marginTot:INTEGER;isBankrupt,hadCashPur:BOOLEAN;stckShrs(9):INTEGER;mgnHeld(9):BOOLEAN;bondUnts(3):INTEGER
DIM plyrs(6)    : PlyrRec
DIM forceLiq(6) : BOOLEAN
DIM passed      : INTEGER
DIM failed      : INTEGER
DIM p           : INTEGER

ON ERROR GOTO 900

passed := 0
failed := 0

! ---- Test 1: spec confirmation case -------------------------
! marginTot=2000, cashBal=80.
! charge = 2000*5/100 = 100. cashBal = 80-100 = -20. forceLiq=TRUE.
FOR p := 1 TO 6
  RUN initPlayer(plyrs(p))
  forceLiq(p) := FALSE
NEXT p
plyrs(1).cashBal   := 80
plyrs(1).marginTot := 2000
RUN applyMgnInt(2, 1, plyrs, forceLiq)
GOSUB 100

! ---- Test 2: Year 1 guard -----------------------------------
! No charge applied; cashBal and forceLiq unchanged.
FOR p := 1 TO 6
  RUN initPlayer(plyrs(p))
  forceLiq(p) := FALSE
NEXT p
plyrs(1).cashBal   := 80
plyrs(1).marginTot := 2000
RUN applyMgnInt(1, 1, plyrs, forceLiq)
GOSUB 200

! ---- Test 3: Year 10 guard ----------------------------------
FOR p := 1 TO 6
  RUN initPlayer(plyrs(p))
  forceLiq(p) := FALSE
NEXT p
plyrs(1).cashBal   := 80
plyrs(1).marginTot := 2000
RUN applyMgnInt(10, 1, plyrs, forceLiq)
GOSUB 300

! ---- Test 4: bankrupt player skipped -----------------------
! isBankrupt=TRUE; cashBal and forceLiq must remain unchanged.
FOR p := 1 TO 6
  RUN initPlayer(plyrs(p))
  forceLiq(p) := FALSE
NEXT p
plyrs(1).cashBal    := 80
plyrs(1).marginTot  := 2000
plyrs(1).isBankrupt := TRUE
RUN applyMgnInt(2, 1, plyrs, forceLiq)
GOSUB 400

! ---- Test 5: zero-margin player — no charge, no forceLiq ----
! marginTot=0; cashBal unchanged, forceLiq stays FALSE.
FOR p := 1 TO 6
  RUN initPlayer(plyrs(p))
  forceLiq(p) := FALSE
NEXT p
plyrs(1).cashBal   := 5000
plyrs(1).marginTot := 0
RUN applyMgnInt(2, 1, plyrs, forceLiq)
GOSUB 500

! ---- Test 6: charge does not exhaust cash -------------------
! marginTot=2000, cashBal=5000. charge=100. cashBal=4900.
! forceLiq must remain FALSE.
FOR p := 1 TO 6
  RUN initPlayer(plyrs(p))
  forceLiq(p) := FALSE
NEXT p
plyrs(1).cashBal   := 5000
plyrs(1).marginTot := 2000
RUN applyMgnInt(2, 1, plyrs, forceLiq)
GOSUB 600

PRINT
PRINT "Results: "; passed; " passed, "; failed; " failed."
END

100 ! Test 1: cashBal=-20, forceLiq=TRUE
    IF plyrs(1).cashBal = -20 AND forceLiq(1) = TRUE THEN
      PRINT "Test 1 PASS  mgnCharge=100 cashBal=-20 forceLiq=TRUE"
      passed := passed + 1
    ELSE
      PRINT "Test 1 FAIL  exp cashBal=-20 got="; plyrs(1).cashBal
      IF NOT forceLiq(1) THEN
        PRINT "           exp forceLiq=TRUE got=FALSE"
      ENDIF
      failed := failed + 1
    ENDIF
    RETURN

200 ! Test 2: Year 1 guard — cashBal=80, forceLiq=FALSE
    IF plyrs(1).cashBal = 80 AND NOT forceLiq(1) THEN
      PRINT "Test 2 PASS  Year1 guard cashBal=80 forceLiq=FALSE"
      passed := passed + 1
    ELSE
      PRINT "Test 2 FAIL  exp cashBal=80 got="; plyrs(1).cashBal
      IF forceLiq(1) THEN
        PRINT "           exp forceLiq=FALSE got=TRUE"
      ENDIF
      failed := failed + 1
    ENDIF
    RETURN

300 ! Test 3: Year 10 guard — cashBal=80, forceLiq=FALSE
    IF plyrs(1).cashBal = 80 AND NOT forceLiq(1) THEN
      PRINT "Test 3 PASS  Year10 guard cashBal=80 forceLiq=FALSE"
      passed := passed + 1
    ELSE
      PRINT "Test 3 FAIL  exp cashBal=80 got="; plyrs(1).cashBal
      IF forceLiq(1) THEN
        PRINT "           exp forceLiq=FALSE got=TRUE"
      ENDIF
      failed := failed + 1
    ENDIF
    RETURN

400 ! Test 4: bankrupt — cashBal=80, forceLiq=FALSE
    IF plyrs(1).cashBal = 80 AND NOT forceLiq(1) THEN
      PRINT "Test 4 PASS  bankrupt skipped cashBal=80 forceLiq=FALSE"
      passed := passed + 1
    ELSE
      PRINT "Test 4 FAIL  exp cashBal=80 got="; plyrs(1).cashBal
      IF forceLiq(1) THEN
        PRINT "           exp forceLiq=FALSE got=TRUE"
      ENDIF
      failed := failed + 1
    ENDIF
    RETURN

500 ! Test 5: zero margin — cashBal=5000, forceLiq=FALSE
    IF plyrs(1).cashBal = 5000 AND NOT forceLiq(1) THEN
      PRINT "Test 5 PASS  zero margin cashBal=5000 forceLiq=FALSE"
      passed := passed + 1
    ELSE
      PRINT "Test 5 FAIL  exp cashBal=5000 got="; plyrs(1).cashBal
      IF forceLiq(1) THEN
        PRINT "           exp forceLiq=FALSE got=TRUE"
      ENDIF
      failed := failed + 1
    ENDIF
    RETURN

600 ! Test 6: charge=100, cashBal=4900, forceLiq=FALSE
    IF plyrs(1).cashBal = 4900 AND NOT forceLiq(1) THEN
      PRINT "Test 6 PASS  charge=100 cashBal=4900 forceLiq=FALSE"
      passed := passed + 1
    ELSE
      PRINT "Test 6 FAIL  exp cashBal=4900 got="; plyrs(1).cashBal
      IF forceLiq(1) THEN
        PRINT "           exp forceLiq=FALSE got=TRUE"
      ENDIF
      failed := failed + 1
    ENDIF
    RETURN

900 PRINT "Runtime error "; ERR; " in TSTMGNINT"
    END

PROCEDURE TSTRSLVPRC
(* ============================================================ *)
(* PROCEDURE : TSTRSLVPRC                                       *)
(* PURPOSE   : Confirmation tests for resolvePrice (Task 3.3). *)
(*             Four tests per spec Section 7:                   *)
(*               A — split triggered, rounding verified         *)
(*               B — bankruptcy floor clamp                     *)
(*               C — dividend suspension boundary               *)
(*               D — dividend reinstatement                     *)
(* PARAMS    : none                                             *)
(* ============================================================ *)
DIM newPrice   : INTEGER
DIM newShares  : INTEGER
DIM splitOccrd : BOOLEAN
DIM divSuspNow : BOOLEAN
DIM divSuspPrv : BOOLEAN
DIM passed     : INTEGER
DIM failed     : INTEGER
DIM ok         : BOOLEAN

ON ERROR GOTO 900

passed := 0
failed := 0

! ---- Test A: split triggered --------------------------------
! curPrice=130, mktDelta=25, cardDelta=0, sharesOwnd=100.
! rawPrice = 155. Split: newPrice=(155+1)/2=78, newShares=200.
! divSuspPrv = FALSE (130 >= 50).
! divSuspNow = FALSE (155 >= 50, pre-split price used).
! splitOccrd = TRUE.
RUN resolvePrice(130, 25, 0, 100, newPrice, newShares, splitOccrd, divSuspNow, divSuspPrv)
GOSUB 100

! ---- Test B: bankruptcy floor clamp ------------------------
! curPrice=5, mktDelta=-10, cardDelta=0, sharesOwnd=50.
! rawPrice = -5 → clamped to 0.
! divSuspPrv = TRUE (5 < 50).
! divSuspNow = TRUE (0 < 50).
! splitOccrd = FALSE.
RUN resolvePrice(5, -10, 0, 50, newPrice, newShares, splitOccrd, divSuspNow, divSuspPrv)
GOSUB 200

! ---- Test C: dividend suspension boundary ------------------
! curPrice=55, mktDelta=-10, cardDelta=0, sharesOwnd=100.
! rawPrice = 45. No clamp, no split.
! divSuspPrv = FALSE (55 >= 50).
! divSuspNow = TRUE  (45 < 50).
! splitOccrd = FALSE.
RUN resolvePrice(55, -10, 0, 100, newPrice, newShares, splitOccrd, divSuspNow, divSuspPrv)
GOSUB 300

! ---- Test D: dividend reinstatement ------------------------
! curPrice=45, mktDelta=10, cardDelta=0, sharesOwnd=100.
! rawPrice = 55. No clamp, no split.
! divSuspPrv = TRUE  (45 < 50).
! divSuspNow = FALSE (55 >= 50).
! splitOccrd = FALSE.
RUN resolvePrice(45, 10, 0, 100, newPrice, newShares, splitOccrd, divSuspNow, divSuspPrv)
GOSUB 400

PRINT
PRINT "Results: "; passed; " passed, "; failed; " failed."
END

100 ! Test A: split at 155 → price=78, shares=200, splitOccrd=TRUE
    ok := TRUE
    IF newPrice <> 78 THEN
      PRINT "Test A FAIL  newPrice: exp=78 got="; newPrice
      ok := FALSE
    ENDIF
    IF newShares <> 200 THEN
      PRINT "Test A FAIL  newShares: exp=200 got="; newShares
      ok := FALSE
    ENDIF
    IF NOT splitOccrd THEN
      PRINT "Test A FAIL  splitOccrd: exp=TRUE got=FALSE"
      ok := FALSE
    ENDIF
    IF divSuspNow THEN
      PRINT "Test A FAIL  divSuspNow: exp=FALSE got=TRUE"
      ok := FALSE
    ENDIF
    IF divSuspPrv THEN
      PRINT "Test A FAIL  divSuspPrv: exp=FALSE got=TRUE"
      ok := FALSE
    ENDIF
    IF ok THEN
      PRINT "Test A PASS  split 155->78 shares 100->200"
      passed := passed + 1
    ELSE
      failed := failed + 1
    ENDIF
    RETURN

200 ! Test B: clamp -5→0, divSuspNow=TRUE, divSuspPrv=TRUE
    ok := TRUE
    IF newPrice <> 0 THEN
      PRINT "Test B FAIL  newPrice: exp=0 got="; newPrice
      ok := FALSE
    ENDIF
    IF newShares <> 50 THEN
      PRINT "Test B FAIL  newShares: exp=50 got="; newShares
      ok := FALSE
    ENDIF
    IF splitOccrd THEN
      PRINT "Test B FAIL  splitOccrd: exp=FALSE got=TRUE"
      ok := FALSE
    ENDIF
    IF NOT divSuspNow THEN
      PRINT "Test B FAIL  divSuspNow: exp=TRUE got=FALSE"
      ok := FALSE
    ENDIF
    IF NOT divSuspPrv THEN
      PRINT "Test B FAIL  divSuspPrv: exp=TRUE got=FALSE"
      ok := FALSE
    ENDIF
    IF ok THEN
      PRINT "Test B PASS  floor clamp 0 divSuspNow=TRUE divSuspPrv=TRUE"
      passed := passed + 1
    ELSE
      failed := failed + 1
    ENDIF
    RETURN

300 ! Test C: 55→45, divSuspPrv=FALSE, divSuspNow=TRUE
    ok := TRUE
    IF newPrice <> 45 THEN
      PRINT "Test C FAIL  newPrice: exp=45 got="; newPrice
      ok := FALSE
    ENDIF
    IF splitOccrd THEN
      PRINT "Test C FAIL  splitOccrd: exp=FALSE got=TRUE"
      ok := FALSE
    ENDIF
    IF NOT divSuspNow THEN
      PRINT "Test C FAIL  divSuspNow: exp=TRUE got=FALSE"
      ok := FALSE
    ENDIF
    IF divSuspPrv THEN
      PRINT "Test C FAIL  divSuspPrv: exp=FALSE got=TRUE"
      ok := FALSE
    ENDIF
    IF ok THEN
      PRINT "Test C PASS  55->45 suspension triggered"
      passed := passed + 1
    ELSE
      failed := failed + 1
    ENDIF
    RETURN

400 ! Test D: 45→55, divSuspPrv=TRUE, divSuspNow=FALSE
    ok := TRUE
    IF newPrice <> 55 THEN
      PRINT "Test D FAIL  newPrice: exp=55 got="; newPrice
      ok := FALSE
    ENDIF
    IF splitOccrd THEN
      PRINT "Test D FAIL  splitOccrd: exp=FALSE got=TRUE"
      ok := FALSE
    ENDIF
    IF divSuspNow THEN
      PRINT "Test D FAIL  divSuspNow: exp=FALSE got=TRUE"
      ok := FALSE
    ENDIF
    IF NOT divSuspPrv THEN
      PRINT "Test D FAIL  divSuspPrv: exp=TRUE got=FALSE"
      ok := FALSE
    ENDIF
    IF ok THEN
      PRINT "Test D PASS  45->55 reinstatement detected"
      passed := passed + 1
    ELSE
      failed := failed + 1
    ENDIF
    RETURN

900 PRINT "Runtime error "; ERR; " in TSTRSLVPRC"
    END

PROCEDURE TSTMKTYR
(* ============================================================ *)
(* PROCEDURE : TSTMKTYR                                         *)
(* PURPOSE   : Confirmation tests for applyMktYear (Task 3.4). *)
(*             Card 13 (Stryker +17), Bull market, roll=5.     *)
(*             Test 1: Stryker (stock 5) — split, delta flags, *)
(*                     shares doubled for holder, zero for non *)
(*             Test 2: Growth Corp (stock 1) — no card effect, *)
(*                     correct price, no split, no div flags   *)
(* PARAMS    : none                                             *)
(* ============================================================ *)
! Line exceeds 79 chars; TYPE statement requires single line.
TYPE PlyrRec = plyrName:STRING[20];plyrType,aiTier:BYTE;cashBal,marginTot:INTEGER;isBankrupt,hadCashPur:BOOLEAN;stckShrs(9):INTEGER;mgnHeld(9):BOOLEAN;bondUnts(3):INTEGER
TYPE MktState = stckPrice(9):INTEGER;divSuspnd(9):BOOLEAN
DIM plyrs(6) : PlyrRec
DIM mkt      : MktState
DIM bCrd(9)  : INTEGER
DIM mDlt(9)  : INTEGER
DIM cDlt(9)  : INTEGER
DIM splt(9)  : BOOLEAN
DIM susp(9)  : BOOLEAN
DIM rstd(9)  : BOOLEAN
DIM passed   : INTEGER
DIM failed   : INTEGER
DIM p        : INTEGER
DIM ok       : BOOLEAN

ON ERROR GOTO 900

passed := 0
failed := 0

! Initialize all player slots and market state.
FOR p := 1 TO 6
  RUN initPlayer(plyrs(p))
NEXT p
RUN initMkt(mkt)

! Player 1 holds 100 Stryker Drilling shares; player 2 holds none.
plyrs(1).stckShrs(5) := 100

! Card 13 = Stryker +17, Bull. Roll = 5.
! Bull table roll=5 for Stryker = 56. rawPrice = 100+56+17 = 173.
! Split: newPrice = (173+1)/2 = 87. Shares doubled for holders.
RUN applyMktYear(13, 5, 2, plyrs, mkt, bCrd, mDlt, cDlt, splt, susp, rstd)

GOSUB 100 \ ! Test 1: Stryker
GOSUB 200 \ ! Test 2: Growth Corp

PRINT
PRINT "Results: "; passed; " passed, "; failed; " failed."
END

100 ! Test 1: Stryker Drilling (stock 5) — split and share doubling
    ok := TRUE
    IF mDlt(5) <> 56 THEN
      PRINT "Test 1 FAIL  mDlt(5): exp=56 got="; mDlt(5)
      ok := FALSE
    ENDIF
    IF cDlt(5) <> 17 THEN
      PRINT "Test 1 FAIL  cDlt(5): exp=17 got="; cDlt(5)
      ok := FALSE
    ENDIF
    IF bCrd(5) <> 156 THEN
      PRINT "Test 1 FAIL  bCrd(5): exp=156 got="; bCrd(5)
      ok := FALSE
    ENDIF
    IF mkt.stckPrice(5) <> 87 THEN
      PRINT "Test 1 FAIL  stckPrice(5): exp=87 got="; mkt.stckPrice(5)
      ok := FALSE
    ENDIF
    IF NOT splt(5) THEN
      PRINT "Test 1 FAIL  splt(5): exp=TRUE got=FALSE"
      ok := FALSE
    ENDIF
    IF susp(5) THEN
      PRINT "Test 1 FAIL  susp(5): exp=FALSE got=TRUE"
      ok := FALSE
    ENDIF
    IF rstd(5) THEN
      PRINT "Test 1 FAIL  rstd(5): exp=FALSE got=TRUE"
      ok := FALSE
    ENDIF
    IF plyrs(1).stckShrs(5) <> 200 THEN
      PRINT "Test 1 FAIL  p1 shrs(5): exp=200 got="; plyrs(1).stckShrs(5)
      ok := FALSE
    ENDIF
    IF plyrs(2).stckShrs(5) <> 0 THEN
      PRINT "Test 1 FAIL  p2 shrs(5): exp=0 got="; plyrs(2).stckShrs(5)
      ok := FALSE
    ENDIF
    IF ok THEN
      PRINT "Test 1 PASS  Stryker split 173->87 shrs 100->200"
      passed := passed + 1
    ELSE
      failed := failed + 1
    ENDIF
    RETURN

200 ! Test 2: Growth Corp (stock 1) — no card effect, no split
    ok := TRUE
    IF mDlt(1) <> 23 THEN
      PRINT "Test 2 FAIL  mDlt(1): exp=23 got="; mDlt(1)
      ok := FALSE
    ENDIF
    IF cDlt(1) <> 0 THEN
      PRINT "Test 2 FAIL  cDlt(1): exp=0 got="; cDlt(1)
      ok := FALSE
    ENDIF
    IF bCrd(1) <> 123 THEN
      PRINT "Test 2 FAIL  bCrd(1): exp=123 got="; bCrd(1)
      ok := FALSE
    ENDIF
    IF mkt.stckPrice(1) <> 123 THEN
      PRINT "Test 2 FAIL  stckPrice(1): exp=123 got="; mkt.stckPrice(1)
      ok := FALSE
    ENDIF
    IF splt(1) THEN
      PRINT "Test 2 FAIL  splt(1): exp=FALSE got=TRUE"
      ok := FALSE
    ENDIF
    IF susp(1) THEN
      PRINT "Test 2 FAIL  susp(1): exp=FALSE got=TRUE"
      ok := FALSE
    ENDIF
    IF rstd(1) THEN
      PRINT "Test 2 FAIL  rstd(1): exp=FALSE got=TRUE"
      ok := FALSE
    ENDIF
    IF ok THEN
      PRINT "Test 2 PASS  GrowthCorp no-card 100->123 no split"
      passed := passed + 1
    ELSE
      failed := failed + 1
    ENDIF
    RETURN

900 PRINT "Runtime error "; ERR; " in TSTMKTYR"
    END

PROCEDURE TSTSHFLDCK
(* ============================================================ *)
(* PROCEDURE : TSTSHFLDCK                                       *)
(* PURPOSE   : Confirmation test for Task 4.1. Seeds RND,      *)
(*             calls shuffleDeck twice, prints all 36 values   *)
(*             each time, and verifies all card IDs 1..36      *)
(*             appear exactly once per shuffle.                 *)
(* PARAMS    : none                                             *)
(* SIDE EFX  : Advances RND sequence. Output to stdout.        *)
(* ============================================================ *)
DIM deckOrd(36) : BYTE
DIM chkArr(36)  : BYTE
DIM i           : INTEGER
DIM errCnt      : INTEGER
DIM rSeed       : REAL

ON ERROR GOTO 900

! Seed RNG from current seconds field; +1 ensures non-zero seed.
rSeed := RND(-(VAL(MID$(DATE$, 16, 2)) + 1))

PRINT "=== tstShuffleDeck ==="
PRINT

! --- Shuffle 1 ---
PRINT "Shuffle 1:"
RUN shuffleDeck(deckOrd)
GOSUB 100  \ ! print deck
GOSUB 200  \ ! verify deck
PRINT

! --- Shuffle 2 ---
PRINT "Shuffle 2:"
RUN shuffleDeck(deckOrd)
GOSUB 100  \ ! print deck
GOSUB 200  \ ! verify deck
PRINT

PRINT "Visual check: confirm sequences differ."
END

! ---- GOSUB 100: print all 36 values, 9 per line ----
100 FOR i := 1 TO 36
      PRINT deckOrd(i);
      IF MOD(i, 9) = 0 THEN
        PRINT
      ENDIF
    NEXT i
RETURN

! ---- GOSUB 200: verify all card IDs 1..36 exactly once ----
200 FOR i := 1 TO 36
      chkArr(i) := 0
    NEXT i
    FOR i := 1 TO 36
      chkArr(deckOrd(i)) := chkArr(deckOrd(i)) + 1
    NEXT i
    errCnt := 0
    FOR i := 1 TO 36
      IF chkArr(i) <> 1 THEN
        PRINT "  ERROR: card "; i; " count="; chkArr(i)
        errCnt := errCnt + 1
      ENDIF
    NEXT i
    IF errCnt = 0 THEN
      PRINT "  PASS: all 36 cards present exactly once."
    ELSE
      PRINT "  FAIL: "; errCnt; " error(s)."
    ENDIF
RETURN

900 ERROR(ERR)
END

PROCEDURE TSTDRWCRD
(* ============================================================ *)
(* PROCEDURE : TSTDRWCRD                                      *)
(* PURPOSE   : Confirmation test for Task 4.2.                 *)
(*             Verifies: all 36 cards drawn exactly once,       *)
(*             draw 37 triggers reshuffle and resets deckPos,   *)
(*             card drawn after reshuffle is valid (1..36).     *)
(* PARAMS    : none                                             *)
(* SIDE EFX  : Advances RND sequence. Output to stdout.        *)
(* ============================================================ *)
DIM deckOrd(36) : BYTE
DIM chkArr(36)  : BYTE
DIM deckPos     : BYTE
DIM cardId      : INTEGER
DIM i           : INTEGER
DIM errCnt      : INTEGER
DIM rSeed       : REAL

ON ERROR GOTO 900

! Seed RNG from current seconds; +1 ensures non-zero seed.
rSeed := RND(-(VAL(MID$(DATE$, 16, 2)) + 1))

PRINT "=== tstDrawCard ==="
PRINT

! --- Part 1: load a known sequential deck, draw all 36 ---
! Bypass shuffleDeck to get a predictable order for boundary test.
PRINT "Part 1: draw all 36 from sequential deck."
FOR i := 1 TO 36
  deckOrd(i) := i
NEXT i
deckPos := 1

FOR i := 1 TO 36
  chkArr(i) := 0
NEXT i

FOR i := 1 TO 36
  RUN drawCard(deckOrd, deckPos, cardId)
  IF cardId >= 1 AND cardId <= 36 THEN
    chkArr(cardId) := chkArr(cardId) + 1
  ELSE
    PRINT "  ERROR: draw "; i; " returned out-of-range cardId="; cardId
  ENDIF
NEXT i

errCnt := 0
FOR i := 1 TO 36
  IF chkArr(i) <> 1 THEN
    PRINT "  ERROR: card "; i; " count="; chkArr(i)
    errCnt := errCnt + 1
  ENDIF
NEXT i
IF errCnt = 0 THEN
  PRINT "  PASS: all 36 cards drawn exactly once."
ELSE
  PRINT "  FAIL: "; errCnt; " error(s) in draw pass."
ENDIF
PRINT

! --- Part 2: verify state after draw 36 ---
! After drawing card 36, drawCard increments deckPos to 37,
! triggers reshuffle, and resets deckPos to 1.
PRINT "Part 2: verify deckPos reset after draw 36."
IF deckPos = 1 THEN
  PRINT "  PASS: deckPos = 1 after reshuffle."
ELSE
  PRINT "  FAIL: deckPos = "; deckPos; " (expected 1)."
ENDIF
PRINT

! --- Part 3: draw 37th card from reshuffled deck ---
PRINT "Part 3: draw card 37 (first from reshuffled deck)."
RUN drawCard(deckOrd, deckPos, cardId)
IF cardId >= 1 AND cardId <= 36 THEN
  PRINT "  PASS: cardId="; cardId; " is valid (1..36)."
ELSE
  PRINT "  FAIL: cardId="; cardId; " is out of range."
ENDIF
IF deckPos = 2 THEN
  PRINT "  PASS: deckPos advanced to 2."
ELSE
  PRINT "  FAIL: deckPos = "; deckPos; " (expected 2)."
ENDIF
PRINT

PRINT "=== tstDrawCard complete ==="
END

900 ERROR(ERR)
END

PROCEDURE TSTSVEGME
(* ============================================================ *)
(* PROCEDURE : TSTSVEGME                                        *)
(* PURPOSE   : Confirmation test for Task 5.1.                 *)
(*             Initializes two players with known non-default   *)
(*             state, calls saveGame with savedPhase=0, then    *)
(*             reads the file back and verifies:                *)
(*               - file size = 440 bytes (EOF after full read)  *)
(*               - hdr.magic, fmtVersion, savedPhase correct   *)
(*               - checksum recomputes correctly                *)
(*               - plyrs(1): cashBal=7500, stckShrs(3)=50,     *)
(*                           bondUnts(2)=1                      *)
(*               - plyrs(2): cashBal=7500, stckShrs(3)=50,     *)
(*                           bondUnts(2)=1                      *)
(* PARAMS    : none                                             *)
(* SIDE EFX  : Creates and deletes SNBTEST in current dir.     *)
(* ============================================================ *)
! Line exceeds 79 chars; TYPE statement requires single line.
TYPE SaveHdr = magic,fmtVersion,currYear,plyrCount,rollMode,savedPhase,savedPlyr,deckPos,checksum:BYTE;obligation:INTEGER
! Line exceeds 79 chars; TYPE statement requires single line.
TYPE PlyrRec = plyrName:STRING[20];plyrType,aiTier:BYTE;cashBal,marginTot:INTEGER;isBankrupt,hadCashPur:BOOLEAN;stckShrs(9):INTEGER;mgnHeld(9):BOOLEAN;bondUnts(3):INTEGER
TYPE MktState = stckPrice(9):INTEGER;divSuspnd(9):BOOLEAN
DIM hdr        : SaveHdr
DIM deckOrd(36): BYTE
DIM plyrs(6)   : PlyrRec
DIM mkt        : MktState
DIM savNm      : STRING[20]
DIM path       : BYTE
DIM i          : INTEGER
DIM errCnt     : INTEGER
DIM chkExp     : INTEGER
DIM opened     : BOOLEAN

ON ERROR GOTO 900

errCnt := 0
opened := FALSE
savNm  := "SNBTEST"

! --- Build test state ---

FOR i := 1 TO 6
  RUN initPlayer(plyrs(i))
NEXT i
RUN initMkt(mkt)

FOR i := 1 TO 36
  deckOrd(i) := i
NEXT i

plyrs(1).plyrName    := "TestPlayer1"
plyrs(1).plyrType    := 1
plyrs(1).cashBal     := 7500
plyrs(1).stckShrs(3) := 50
plyrs(1).bondUnts(2) := 1

plyrs(2).plyrName    := "TestPlayer2"
plyrs(2).plyrType    := 1
plyrs(2).cashBal     := 7500
plyrs(2).stckShrs(3) := 50
plyrs(2).bondUnts(2) := 1

hdr.magic      := $53
hdr.fmtVersion := 1
hdr.currYear   := 1
hdr.plyrCount  := 2
hdr.rollMode   := 1
hdr.savedPhase := 0
hdr.savedPlyr  := 0
hdr.deckPos    := 1
hdr.obligation := 0
! hdr.checksum is set by saveGame.

PRINT "=== tstSvegme ==="
PRINT

! --- Call saveGame ---
RUN saveGame(savNm, hdr, deckOrd, plyrs, mkt)
PRINT "saveGame returned without error."
PRINT

! --- Read file back for verification ---
! Clear key fields so readback values are not stale from above.
hdr.magic            := 0
hdr.fmtVersion       := 0
hdr.checksum         := 0
hdr.savedPhase       := 99
plyrs(1).cashBal     := 0
plyrs(1).stckShrs(3) := 0
plyrs(1).bondUnts(2) := 0
plyrs(2).cashBal     := 0
plyrs(2).stckShrs(3) := 0
plyrs(2).bondUnts(2) := 0

ON ERROR GOTO 500
OPEN #path, savNm:READ
ON ERROR GOTO 900
opened := TRUE

GET #path, hdr
GET #path, deckOrd
GET #path, plyrs
GET #path, mkt

! EOF immediately after reading all 440 bytes confirms file size.
IF EOF(#path) THEN
  PRINT "  PASS: file size = 440 bytes."
ELSE
  PRINT "  FAIL: file size > 440 bytes."
  errCnt := errCnt + 1
ENDIF

CLOSE #path
GOTO 600 \ ! skip OPEN failure block

500 PRINT "  FAIL: cannot open SNBTEST (error "; ERR; ")."
    errCnt := errCnt + 1
    ON ERROR GOTO 900

600 IF NOT opened THEN
      GOTO 700
    ENDIF

! --- Header field checks ---
IF hdr.magic = $53 THEN
  PRINT "  PASS: hdr.magic = $53."
ELSE
  PRINT "  FAIL: hdr.magic = "; hdr.magic
  errCnt := errCnt + 1
ENDIF

IF hdr.fmtVersion = 1 THEN
  PRINT "  PASS: hdr.fmtVersion = 1."
ELSE
  PRINT "  FAIL: hdr.fmtVersion = "; hdr.fmtVersion
  errCnt := errCnt + 1
ENDIF

IF hdr.savedPhase = 0 THEN
  PRINT "  PASS: hdr.savedPhase = 0."
ELSE
  PRINT "  FAIL: hdr.savedPhase = "; hdr.savedPhase
  errCnt := errCnt + 1
ENDIF

! --- Checksum verification ---
chkExp := hdr.magic + hdr.fmtVersion + hdr.currYear
chkExp := chkExp + hdr.plyrCount + hdr.rollMode
chkExp := chkExp + hdr.savedPhase + hdr.savedPlyr
chkExp := chkExp + hdr.deckPos + hdr.obligation
chkExp := LAND(chkExp, 255)
IF chkExp = hdr.checksum THEN
  PRINT "  PASS: checksum correct ("; hdr.checksum; ")."
ELSE
  PRINT "  FAIL: checksum exp="; chkExp; " got="; hdr.checksum
  errCnt := errCnt + 1
ENDIF

! --- Player 1 field checks ---
IF plyrs(1).cashBal = 7500 THEN
  PRINT "  PASS: plyrs(1).cashBal = 7500."
ELSE
  PRINT "  FAIL: plyrs(1).cashBal = "; plyrs(1).cashBal
  errCnt := errCnt + 1
ENDIF

IF plyrs(1).stckShrs(3) = 50 THEN
  PRINT "  PASS: plyrs(1).stckShrs(3) = 50."
ELSE
  PRINT "  FAIL: plyrs(1).stckShrs(3) = "; plyrs(1).stckShrs(3)
  errCnt := errCnt + 1
ENDIF

IF plyrs(1).bondUnts(2) = 1 THEN
  PRINT "  PASS: plyrs(1).bondUnts(2) = 1."
ELSE
  PRINT "  FAIL: plyrs(1).bondUnts(2) = "; plyrs(1).bondUnts(2)
  errCnt := errCnt + 1
ENDIF

! --- Player 2 field checks ---
IF plyrs(2).cashBal = 7500 THEN
  PRINT "  PASS: plyrs(2).cashBal = 7500."
ELSE
  PRINT "  FAIL: plyrs(2).cashBal = "; plyrs(2).cashBal
  errCnt := errCnt + 1
ENDIF

IF plyrs(2).stckShrs(3) = 50 THEN
  PRINT "  PASS: plyrs(2).stckShrs(3) = 50."
ELSE
  PRINT "  FAIL: plyrs(2).stckShrs(3) = "; plyrs(2).stckShrs(3)
  errCnt := errCnt + 1
ENDIF

IF plyrs(2).bondUnts(2) = 1 THEN
  PRINT "  PASS: plyrs(2).bondUnts(2) = 1."
ELSE
  PRINT "  FAIL: plyrs(2).bondUnts(2) = "; plyrs(2).bondUnts(2)
  errCnt := errCnt + 1
ENDIF

700 ! --- Summary and cleanup ---
PRINT
IF errCnt = 0 THEN
  PRINT "PASS: all checks passed."
ELSE
  PRINT "FAIL: "; errCnt; " check(s) failed."
ENDIF

ON ERROR GOTO 800
DELETE savNm
800 ON ERROR GOTO 900
END

900 ERROR(ERR)
END

PROCEDURE TSTLODGME
(* ============================================================ *)
(* PROCEDURE : TSTLODGME                                        *)
(* PURPOSE   : Confirmation test for Task 5.2.                 *)
(*             Part 1: round-trip verify fields survive save   *)
(*                     and load unchanged.                     *)
(*             Part 2: corrupt magic byte; verify loadOK=FALSE *)
(*                     and "not a valid save file" message.    *)
(*             Part 3: corrupt currYear byte; verify           *)
(*                     loadOK=FALSE and "corrupt" message.     *)
(* PARAMS    : none                                             *)
(* SIDE EFX  : Creates and deletes SNBTEST in current dir.     *)
(*             loadGame prints diagnostic messages for         *)
(*             Parts 2 and 3; this is expected output.         *)
(* ============================================================ *)
! Line exceeds 79 chars; TYPE statement requires single line.
TYPE SaveHdr = magic,fmtVersion,currYear,plyrCount,rollMode,savedPhase,savedPlyr,deckPos,checksum:BYTE;obligation:INTEGER
! Line exceeds 79 chars; TYPE statement requires single line.
TYPE PlyrRec = plyrName:STRING[20];plyrType,aiTier:BYTE;cashBal,marginTot:INTEGER;isBankrupt,hadCashPur:BOOLEAN;stckShrs(9):INTEGER;mgnHeld(9):BOOLEAN;bondUnts(3):INTEGER
TYPE MktState = stckPrice(9):INTEGER;divSuspnd(9):BOOLEAN
DIM hdr        : SaveHdr
DIM deckOrd(36): BYTE
DIM plyrs(6)   : PlyrRec
DIM mkt        : MktState
DIM savNm      : STRING[20]
DIM loadOK     : BOOLEAN
DIM errCnt     : INTEGER
DIM i          : INTEGER
DIM path       : BYTE
DIM badByte    : BYTE

ON ERROR GOTO 900

errCnt := 0
savNm  := "SNBTEST"

PRINT "=== tstLodGme ==="
PRINT

GOSUB 100
GOSUB 200
GOSUB 300

GOTO 400

100 ! --- Part 1: happy path round-trip ---
PRINT "Part 1: round-trip save and load."

FOR i := 1 TO 6
  RUN initPlayer(plyrs(i))
NEXT i
RUN initMkt(mkt)
FOR i := 1 TO 36
  deckOrd(i) := i
NEXT i

plyrs(1).plyrName    := "Alice"
plyrs(1).plyrType    := 1
plyrs(1).cashBal     := 7500
plyrs(1).stckShrs(3) := 50
plyrs(1).bondUnts(2) := 1

hdr.magic      := $53
hdr.fmtVersion := 1
hdr.currYear   := 3
hdr.plyrCount  := 2
hdr.rollMode   := 2
hdr.savedPhase := 1
hdr.savedPlyr  := 2
hdr.deckPos    := 7
hdr.obligation := 0

RUN saveGame(savNm, hdr, deckOrd, plyrs, mkt)

! Clear fields to confirm readback is not stale.
hdr.currYear         := 0
hdr.savedPhase       := 99
hdr.savedPlyr        := 0
hdr.deckPos          := 0
plyrs(1).cashBal     := 0
plyrs(1).stckShrs(3) := 0
plyrs(1).bondUnts(2) := 0

RUN loadGame(savNm, hdr, deckOrd, plyrs, mkt, loadOK)

IF loadOK THEN
  PRINT "  PASS: loadOK = TRUE."
ELSE
  PRINT "  FAIL: loadOK = FALSE (unexpected)."
  errCnt := errCnt + 1
ENDIF

IF hdr.currYear = 3 THEN
  PRINT "  PASS: hdr.currYear = 3."
ELSE
  PRINT "  FAIL: hdr.currYear = "; hdr.currYear
  errCnt := errCnt + 1
ENDIF

IF hdr.savedPhase = 1 THEN
  PRINT "  PASS: hdr.savedPhase = 1."
ELSE
  PRINT "  FAIL: hdr.savedPhase = "; hdr.savedPhase
  errCnt := errCnt + 1
ENDIF

IF hdr.savedPlyr = 2 THEN
  PRINT "  PASS: hdr.savedPlyr = 2."
ELSE
  PRINT "  FAIL: hdr.savedPlyr = "; hdr.savedPlyr
  errCnt := errCnt + 1
ENDIF

IF hdr.deckPos = 7 THEN
  PRINT "  PASS: hdr.deckPos = 7."
ELSE
  PRINT "  FAIL: hdr.deckPos = "; hdr.deckPos
  errCnt := errCnt + 1
ENDIF

IF plyrs(1).cashBal = 7500 THEN
  PRINT "  PASS: plyrs(1).cashBal = 7500."
ELSE
  PRINT "  FAIL: plyrs(1).cashBal = "; plyrs(1).cashBal
  errCnt := errCnt + 1
ENDIF

IF plyrs(1).stckShrs(3) = 50 THEN
  PRINT "  PASS: plyrs(1).stckShrs(3) = 50."
ELSE
  PRINT "  FAIL: plyrs(1).stckShrs(3) = "; plyrs(1).stckShrs(3)
  errCnt := errCnt + 1
ENDIF

IF plyrs(1).bondUnts(2) = 1 THEN
  PRINT "  PASS: plyrs(1).bondUnts(2) = 1."
ELSE
  PRINT "  FAIL: plyrs(1).bondUnts(2) = "; plyrs(1).bondUnts(2)
  errCnt := errCnt + 1
ENDIF

PRINT
RETURN

200 ! --- Part 2: corrupt magic byte at offset 0 ---
! Expected: loadGame prints "not a valid save file", loadOK=FALSE.
PRINT "Part 2: corrupt magic byte (expect error message below)."

RUN saveGame(savNm, hdr, deckOrd, plyrs, mkt)

OPEN #path, savNm:UPDATE
SEEK #path, 0
badByte := 0
PUT #path, badByte
CLOSE #path

RUN loadGame(savNm, hdr, deckOrd, plyrs, mkt, loadOK)

IF NOT loadOK THEN
  PRINT "  PASS: loadOK = FALSE after bad magic."
ELSE
  PRINT "  FAIL: loadOK = TRUE after bad magic (should be FALSE)."
  errCnt := errCnt + 1
ENDIF

PRINT
RETURN

300 ! --- Part 3: corrupt currYear at offset 2 ---
! magic and fmtVersion intact; checksum will mismatch.
! Expected: loadGame prints "save file is corrupt", loadOK=FALSE.
PRINT "Part 3: corrupt currYear byte (expect error message below)."

RUN saveGame(savNm, hdr, deckOrd, plyrs, mkt)

OPEN #path, savNm:UPDATE
SEEK #path, 2
badByte := $FF
PUT #path, badByte
CLOSE #path

RUN loadGame(savNm, hdr, deckOrd, plyrs, mkt, loadOK)

IF NOT loadOK THEN
  PRINT "  PASS: loadOK = FALSE after checksum mismatch."
ELSE
  PRINT "  FAIL: loadOK = TRUE after corrupt byte (should be FALSE)."
  errCnt := errCnt + 1
ENDIF

PRINT
RETURN

400 ! --- Summary and cleanup ---
IF errCnt = 0 THEN
  PRINT "PASS: all checks passed."
ELSE
  PRINT "FAIL: "; errCnt; " check(s) failed."
ENDIF
PRINT

ON ERROR GOTO 500
DELETE savNm
500 ON ERROR GOTO 900
END

900 ERROR(ERR)
END

PROCEDURE TSTCHKPTS
(* ============================================================ *)
(* PROCEDURE : TSTCHKPTS                                        *)
(* PURPOSE   : Confirmation test for Task 5.3.                 *)
(*             Verifies all four savedPhase values (0-3)       *)
(*             write and reload correctly via saveGame and      *)
(*             loadGame. Each subtest uses distinct field       *)
(*             values to prevent false passes from stale data. *)
(*             Phase 3 additionally verifies obligation field. *)
(* PARAMS    : none                                             *)
(* SIDE EFX  : Creates and deletes SNBTEST in current dir.     *)
(* ============================================================ *)
! Line exceeds 79 chars; TYPE statement requires single line.
TYPE SaveHdr = magic,fmtVersion,currYear,plyrCount,rollMode,savedPhase,savedPlyr,deckPos,checksum:BYTE;obligation:INTEGER
! Line exceeds 79 chars; TYPE statement requires single line.
TYPE PlyrRec = plyrName:STRING[20];plyrType,aiTier:BYTE;cashBal,marginTot:INTEGER;isBankrupt,hadCashPur:BOOLEAN;stckShrs(9):INTEGER;mgnHeld(9):BOOLEAN;bondUnts(3):INTEGER
TYPE MktState = stckPrice(9):INTEGER;divSuspnd(9):BOOLEAN
DIM hdr        : SaveHdr
DIM deckOrd(36): BYTE
DIM plyrs(6)   : PlyrRec
DIM mkt        : MktState
DIM savNm      : STRING[20]
DIM loadOK     : BOOLEAN
DIM errCnt     : INTEGER
DIM i          : INTEGER

ON ERROR GOTO 900

errCnt := 0
savNm  := "SNBTEST"

! Initialize shared arrays once; content is not under test here.
FOR i := 1 TO 6
  RUN initPlayer(plyrs(i))
NEXT i
RUN initMkt(mkt)
FOR i := 1 TO 36
  deckOrd(i) := i
NEXT i

! Populate fixed header fields common to all four subtests.
hdr.magic      := $53
hdr.fmtVersion := 1
hdr.plyrCount  := 2
hdr.rollMode   := 1

PRINT "=== tstChkPts ==="
PRINT

GOSUB 100
GOSUB 200
GOSUB 300
GOSUB 400

GOTO 500

100 ! --- Phase 0: YEAR_START ---
! savedPlyr=0, obligation=0 (both unused at this checkpoint).
PRINT "Phase 0 (YEAR_START)."
hdr.currYear   := 1
hdr.savedPhase := 0
hdr.savedPlyr  := 0
hdr.deckPos    := 1
hdr.obligation := 0

RUN saveGame(savNm, hdr, deckOrd, plyrs, mkt)

hdr.savedPhase := 99
hdr.savedPlyr  := 99
hdr.obligation := 999
hdr.currYear   := 0

RUN loadGame(savNm, hdr, deckOrd, plyrs, mkt, loadOK)

IF NOT loadOK THEN
  PRINT "  FAIL: loadOK=FALSE."
  errCnt := errCnt + 1
  RETURN
ENDIF
IF hdr.savedPhase = 0 THEN
  PRINT "  PASS: savedPhase=0."
ELSE
  PRINT "  FAIL: savedPhase="; hdr.savedPhase; " (exp 0)."
  errCnt := errCnt + 1
ENDIF
IF hdr.savedPlyr = 0 THEN
  PRINT "  PASS: savedPlyr=0."
ELSE
  PRINT "  FAIL: savedPlyr="; hdr.savedPlyr; " (exp 0)."
  errCnt := errCnt + 1
ENDIF
IF hdr.obligation = 0 THEN
  PRINT "  PASS: obligation=0."
ELSE
  PRINT "  FAIL: obligation="; hdr.obligation; " (exp 0)."
  errCnt := errCnt + 1
ENDIF
IF hdr.currYear = 1 THEN
  PRINT "  PASS: currYear=1."
ELSE
  PRINT "  FAIL: currYear="; hdr.currYear; " (exp 1)."
  errCnt := errCnt + 1
ENDIF
PRINT
RETURN

200 ! --- Phase 1: SELL_PHASE ---
! savedPlyr=next player to sell; obligation unused (=0).
PRINT "Phase 1 (SELL_PHASE)."
hdr.currYear   := 4
hdr.savedPhase := 1
hdr.savedPlyr  := 2
hdr.deckPos    := 14
hdr.obligation := 0

RUN saveGame(savNm, hdr, deckOrd, plyrs, mkt)

hdr.savedPhase := 99
hdr.savedPlyr  := 99
hdr.obligation := 999
hdr.currYear   := 0

RUN loadGame(savNm, hdr, deckOrd, plyrs, mkt, loadOK)

IF NOT loadOK THEN
  PRINT "  FAIL: loadOK=FALSE."
  errCnt := errCnt + 1
  RETURN
ENDIF
IF hdr.savedPhase = 1 THEN
  PRINT "  PASS: savedPhase=1."
ELSE
  PRINT "  FAIL: savedPhase="; hdr.savedPhase; " (exp 1)."
  errCnt := errCnt + 1
ENDIF
IF hdr.savedPlyr = 2 THEN
  PRINT "  PASS: savedPlyr=2."
ELSE
  PRINT "  FAIL: savedPlyr="; hdr.savedPlyr; " (exp 2)."
  errCnt := errCnt + 1
ENDIF
IF hdr.obligation = 0 THEN
  PRINT "  PASS: obligation=0."
ELSE
  PRINT "  FAIL: obligation="; hdr.obligation; " (exp 0)."
  errCnt := errCnt + 1
ENDIF
IF hdr.deckPos = 14 THEN
  PRINT "  PASS: deckPos=14."
ELSE
  PRINT "  FAIL: deckPos="; hdr.deckPos; " (exp 14)."
  errCnt := errCnt + 1
ENDIF
PRINT
RETURN

300 ! --- Phase 2: BUY_PHASE ---
! savedPlyr=next player to buy; obligation unused (=0).
PRINT "Phase 2 (BUY_PHASE)."
hdr.currYear   := 7
hdr.savedPhase := 2
hdr.savedPlyr  := 3
hdr.deckPos    := 22
hdr.obligation := 0

RUN saveGame(savNm, hdr, deckOrd, plyrs, mkt)

hdr.savedPhase := 99
hdr.savedPlyr  := 99
hdr.obligation := 999
hdr.currYear   := 0

RUN loadGame(savNm, hdr, deckOrd, plyrs, mkt, loadOK)

IF NOT loadOK THEN
  PRINT "  FAIL: loadOK=FALSE."
  errCnt := errCnt + 1
  RETURN
ENDIF
IF hdr.savedPhase = 2 THEN
  PRINT "  PASS: savedPhase=2."
ELSE
  PRINT "  FAIL: savedPhase="; hdr.savedPhase; " (exp 2)."
  errCnt := errCnt + 1
ENDIF
IF hdr.savedPlyr = 3 THEN
  PRINT "  PASS: savedPlyr=3."
ELSE
  PRINT "  FAIL: savedPlyr="; hdr.savedPlyr; " (exp 3)."
  errCnt := errCnt + 1
ENDIF
IF hdr.obligation = 0 THEN
  PRINT "  PASS: obligation=0."
ELSE
  PRINT "  FAIL: obligation="; hdr.obligation; " (exp 0)."
  errCnt := errCnt + 1
ENDIF
IF hdr.deckPos = 22 THEN
  PRINT "  PASS: deckPos=22."
ELSE
  PRINT "  FAIL: deckPos="; hdr.deckPos; " (exp 22)."
  errCnt := errCnt + 1
ENDIF
PRINT
RETURN

400 ! --- Phase 3: FORCED_LIQ ---
! obligation carries the outstanding forced-liquidation amount.
! This is the only checkpoint where obligation is non-zero.
PRINT "Phase 3 (FORCED_LIQ)."
hdr.currYear   := 9
hdr.savedPhase := 3
hdr.savedPlyr  := 1
hdr.deckPos    := 31
hdr.obligation := 1750

RUN saveGame(savNm, hdr, deckOrd, plyrs, mkt)

hdr.savedPhase := 99
hdr.savedPlyr  := 99
hdr.obligation := 0
hdr.currYear   := 0

RUN loadGame(savNm, hdr, deckOrd, plyrs, mkt, loadOK)

IF NOT loadOK THEN
  PRINT "  FAIL: loadOK=FALSE."
  errCnt := errCnt + 1
  RETURN
ENDIF
IF hdr.savedPhase = 3 THEN
  PRINT "  PASS: savedPhase=3."
ELSE
  PRINT "  FAIL: savedPhase="; hdr.savedPhase; " (exp 3)."
  errCnt := errCnt + 1
ENDIF
IF hdr.savedPlyr = 1 THEN
  PRINT "  PASS: savedPlyr=1."
ELSE
  PRINT "  FAIL: savedPlyr="; hdr.savedPlyr; " (exp 1)."
  errCnt := errCnt + 1
ENDIF
IF hdr.obligation = 1750 THEN
  PRINT "  PASS: obligation=1750."
ELSE
  PRINT "  FAIL: obligation="; hdr.obligation; " (exp 1750)."
  errCnt := errCnt + 1
ENDIF
IF hdr.deckPos = 31 THEN
  PRINT "  PASS: deckPos=31."
ELSE
  PRINT "  FAIL: deckPos="; hdr.deckPos; " (exp 31)."
  errCnt := errCnt + 1
ENDIF
PRINT
RETURN

500 ! --- Summary ---
IF errCnt = 0 THEN
  PRINT "PASS: all phase checks passed."
ELSE
  PRINT "FAIL: "; errCnt; " check(s) failed."
ENDIF
PRINT

ON ERROR GOTO 600
DELETE savNm
600 ON ERROR GOTO 900
END

900 ERROR(ERR)
END

PROCEDURE TSTDISP
(* ================================================== *)
(* PROCEDURE: TSTDISP                                *)
(* PURPOSE:   Confirmation test for Task 6.1.        *)
(*            Verifies clrScr and printAt.           *)
(* PARAMS:    None                                    *)
(* ================================================== *)
DIM anyKey:STRING[1]

ON ERROR GOTO 900

! --- Test 1: clrScr ---
RUN clrScr
PRINT "clrScr called. Verify terminal cleared."
PRINT "Press any key to continue...";
GET #0, anyKey

! --- Test 2: printAt ---
RUN clrScr
RUN printAt(5, 10, "TEST")
PRINT
PRINT "printAt(5, 10, TEST) called."
PRINT "Verify TEST appears at row 5, column 10."
PRINT "Press any key to continue...";
GET #0, anyKey

RUN clrScr
PRINT "Task 6.1 test complete."
END

900 \ ! Error handler
PRINT "testDisp error ("; ERR; ")"
END

PROCEDURE TSTFMTM
(* ================================================== *)
(* PROCEDURE: TSTFMTM                                *)
(* PURPOSE:   Confirmation test for Task 6.2.        *)
(*            Verifies fmtMoney against spec cases.  *)
(* PARAMS:    None                                    *)
(* ================================================== *)
DIM result:STRING[8]
DIM anyKey:STRING[1]

ON ERROR GOTO 900

PRINT "--- testFmtM: fmtMoney ---"
PRINT

RUN fmtMoney(5000, result)
PRINT "fmtMoney(5000)  -> '"; result; "'"
PRINT "  expected      -> '   5000'"

RUN fmtMoney(0, result)
PRINT "fmtMoney(0)     -> '"; result; "'"
PRINT "  expected      -> '      0'"

RUN fmtMoney(-200, result)
PRINT "fmtMoney(-200)  -> '"; result; "'"
PRINT "  expected      -> '   -200'"

RUN fmtMoney(32767, result)
PRINT "fmtMoney(32767) -> '"; result; "'"
PRINT "  expected      -> '  32767'"

PRINT
PRINT "Verify each result matches expected exactly."
PRINT "Press any key to continue...";
GET #0, anyKey
PRINT
END

900 \ ! Error handler
PRINT "testFmtM error ("; ERR; ")"
END

