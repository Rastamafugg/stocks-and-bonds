PROCEDURE snbSellMargin
(* ================================================== *)
(* PROCEDURE: snbSellMargin                           *)
(* PURPOSE:   README entry for snbSellMargin module.  *)
(*            Lists all procedures in this module.    *)
(* PARAMS:    None                                    *)
(* ================================================== *)
PRINT "snbSellMargin"
PRINT "  applySells"
PRINT "  commitOrderQty"
PRINT "  promptEditOrderQty"
PRINT "  resolveOrderEditSel"
END

PROCEDURE commitOrderQty
(* ============================================================ *)
(* PROCEDURE : commitOrderQty                                   *)
(* PURPOSE   : Apply a single edited order quantity into the   *)
(*             order arrays shared by sell/liquidation screens.*)
(*             qty=0 removes the existing slot if present.     *)
(*             qty>0 updates the existing slot or appends a    *)
(*             new order when slotIdx=0.                       *)
(* PARAMS    : ordType   - order asset type array              *)
(*             ordId     - order asset id array                *)
(*             ordQty    - order quantity array                *)
(*             ordCnt    - number of active orders             *)
(*             slotIdx   - existing slot index or 0            *)
(*             assetType - asset type to write                 *)
(*             assetId   - asset id to write                   *)
(*             qty       - edited quantity                     *)
(* SIDE EFX  : Modifies ordType/ordId/ordQty/ordCnt in place.  *)
(* ============================================================ *)
PARAM ordType(12) : INTEGER
PARAM ordId(12)   : INTEGER
PARAM ordQty(12)  : INTEGER
PARAM ordCnt      : INTEGER
PARAM slotIdx     : INTEGER
PARAM assetType   : INTEGER
PARAM assetId     : INTEGER
PARAM qty         : INTEGER
DIM i            : INTEGER

IF qty = 0 THEN
  IF slotIdx > 0 AND slotIdx <= ordCnt THEN
    FOR i := slotIdx TO ordCnt - 1
      ordType(i) := ordType(i + 1)
      ordId(i)   := ordId(i + 1)
      ordQty(i)  := ordQty(i + 1)
    NEXT i
    ordType(ordCnt) := 0
    ordId(ordCnt)   := 0
    ordQty(ordCnt)  := 0
    ordCnt := ordCnt - 1
  ENDIF
ELSE
  IF slotIdx = 0 THEN
    ordCnt := ordCnt + 1
    slotIdx := ordCnt
  ENDIF
  ordType(slotIdx) := assetType
  ordId(slotIdx)   := assetId
  ordQty(slotIdx)  := qty
ENDIF

END

PROCEDURE promptEditOrderQty
(* ============================================================ *)
(* PROCEDURE : promptEditOrderQty                               *)
(* PURPOSE   : Preload the current edited quantity and dispatch *)
(*             to the stock or bond quantity editor for        *)
(*             sell/liquidation screens.                       *)
(* PARAMS    : title      - screen title for stock editor      *)
(*             assetType  - 1=stock 2=bond                     *)
(*             stockNm    - stock display name                 *)
(*             stockQty   - shares currently held              *)
(*             stockPrice - current stock price                *)
(*             stockMode  - getLotQty ordMode                  *)
(*             baseCash   - projected cash baseline            *)
(*             baseMgn    - projected margin/obligation base   *)
(*             baseStkMgn - projected stock margin or -1       *)
(*             bondPar    - bond par value                     *)
(*             bondQty    - bond units currently held          *)
(*             bondNav    - bond prompt allowNav flag          *)
(*             slotIdx    - existing order slot or 0           *)
(*             ordQty     - active order quantity array        *)
(*             qty        - edited quantity out                *)
(*             action     - prompt action/status out           *)
(* SIDE EFX  : Invokes getLotQty or inline bond prompt logic.  *)
(* ============================================================ *)
PARAM title       : STRING
PARAM assetType   : INTEGER
PARAM stockNm     : STRING[14]
PARAM stockQty    : INTEGER
PARAM stockPrice  : INTEGER
PARAM stockMode   : INTEGER
PARAM baseCash    : INTEGER
PARAM baseMgn     : INTEGER
PARAM baseStkMgn  : INTEGER
PARAM bondPar     : INTEGER
PARAM bondQty     : INTEGER
PARAM bondNav     : INTEGER
PARAM slotIdx     : INTEGER
PARAM ordQty(12)  : INTEGER
PARAM qty         : INTEGER
PARAM action      : INTEGER
DIM qIn          : STRING[8]
DIM pStr         : STRING[8]
DIM numOk        : BOOLEAN
DIM valid        : BOOLEAN

ON ERROR GOTO 900

action := 0
qty := 0
IF slotIdx > 0 THEN
  qty := ordQty(slotIdx)
ENDIF

IF assetType = 1 THEN
  ! Line exceeds 79 chars; getLotQty call requires full arguments.
  RUN getLotQty(title, stockNm, stockQty, stockPrice, qty, stockMode, 0, stockQty, baseCash, baseMgn, baseStkMgn, 0, action)
ELSE
  valid := FALSE
  WHILE NOT valid DO
    RUN fmtMoney(bondPar, pStr)
    PRINT "$"; pStr; " bond  "; bondQty; " unit(s) held"
    INPUT "  Sell units (0/Enter=clear): ", qIn
    IF qIn = "" THEN
      qty := 0
      valid := TRUE
    ELSE
      IF bondNav <> 0 THEN
        action := 0
        IF qIn = "S" OR qIn = "s" THEN
          action := 3
        ELSE IF qIn = "Q" OR qIn = "q" THEN
          action := 4
        ENDIF \ENDIF
        IF action = 3 OR action = 4 THEN
          END
        ENDIF
      ENDIF
      RUN getNumIn(qIn, qty, numOk)
      IF NOT numOk THEN
        PRINT "  Invalid: enter a number."
      ELSE IF qty < 0 THEN
        PRINT "  Invalid: enter 0 or a positive amount."
      ELSE IF qty > bondQty THEN
        PRINT "  Invalid: you hold only ";
        PRINT bondQty; " unit(s)."
      ELSE
        valid := TRUE
      ENDIF \ENDIF \ENDIF
    ENDIF
  ENDWHILE
ENDIF

END

900 PRINT "promptEditOrderQty error ("; ERR; ")"
END

PROCEDURE resolveOrderEditSel
(* ============================================================ *)
(* PROCEDURE : resolveOrderEditSel                              *)
(* PURPOSE   : Normalize a raw keypress and resolve the        *)
(*             selected asset row plus any existing order slot *)
(*             for sell/liquidation editor screens.            *)
(* PARAMS    : keyIn     - raw keypress string                 *)
(*             mapType   - asset type per visible row          *)
(*             mapId     - asset id per visible row            *)
(*             mapKey    - key code per visible row            *)
(*             mapCnt    - number of visible rows              *)
(*             ordType   - active order type array             *)
(*             ordId     - active order id array               *)
(*             ordQty    - active order quantity array         *)
(*             ordCnt    - number of active orders             *)
(*             keyCode   - normalized uppercase key code       *)
(*             selIdx    - selected visible row, or 0          *)
(*             slotIdx   - matching order slot, or 0           *)
(*             slotQty   - matching order qty, or 0            *)
(* SIDE EFX  : None beyond output PARAM values.                *)
(* ============================================================ *)
PARAM keyIn      : STRING[1]
PARAM mapType(12): INTEGER
PARAM mapId(12)  : INTEGER
PARAM mapKey(12) : INTEGER
PARAM mapCnt     : INTEGER
PARAM ordType(12): INTEGER
PARAM ordId(12)  : INTEGER
PARAM ordQty(12) : INTEGER
PARAM ordCnt     : INTEGER
PARAM keyCode    : INTEGER
PARAM selIdx     : INTEGER
PARAM slotIdx    : INTEGER
PARAM slotQty    : INTEGER
DIM i           : INTEGER

selIdx  := 0
slotIdx := 0
slotQty := 0

IF keyIn <> "" THEN
  keyCode := ASC(keyIn)
  IF keyCode >= ASC("a") AND keyCode <= ASC("z") THEN
    keyCode := keyCode - 32
  ENDIF
ELSE
  keyCode := 0
ENDIF

FOR i := 1 TO mapCnt
  IF mapKey(i) = keyCode THEN
    selIdx := i
  ENDIF
NEXT i
IF selIdx > 0 THEN
  RUN findOrderSlot(ordType, ordId, ordQty, ordCnt, mapType(selIdx), mapId(selIdx), slotIdx, slotQty)
ENDIF

END

PROCEDURE applySells
(* ============================================================ *)
(* PROCEDURE : applySells                                       *)
(* PURPOSE   : Apply validated sell orders from the sell phase *)
(*             single player record (spec Sections 11.1-11.3). *)
(*             Stock sell: proceeds = qty * currentPrice.      *)
(*             Margin-backed stock: repay 50% of proceeds,     *)
(*             clamped to that company's remaining margin      *)
(*             balance, before crediting cash.                 *)
(*             Bond sell: redeem at par; proceeds = qty * par. *)
(*             ordType: 1=STOCK 2=BOND.                        *)
(*             No-op when ordCnt = 0 (player passed).          *)
(* PARAMS    : plyr     - player record (modified in place)    *)
(*             mkt      - market state; stckPrice(9) read-only *)
(*             ordType  - asset type per order (1=stock 2=bond)*)
(*             ordId    - asset index per order (1-9 / 1-3)    *)
(*             ordQty   - quantity per order                   *)
(*             ordCnt   - number of valid orders (0..12)       *)
(* SIDE EFX  : Modifies plyr.cashBal, plyr.mgnBal,             *)
(*             plyr.stckShrs, plyr.bondUnts.                   *)
(* ============================================================ *)
! Line exceeds 79 chars; TYPE statement requires single line.
TYPE PlyrRec = plyrName:STRING[20];plyrType:BYTE;cashBal,obligation:INTEGER;isBankrupt,hadCashPur:BOOLEAN;aiTier:BYTE;stckShrs(9):INTEGER;mgnBal(9):INTEGER;bondUnts(3):INTEGER
TYPE MktState = stckPrice(9):INTEGER;divSuspnd(9):BOOLEAN
PARAM plyr        : PlyrRec
PARAM mkt         : MktState
PARAM ordType(12) : INTEGER
PARAM ordId(12)   : INTEGER
PARAM ordQty(12)  : INTEGER
PARAM ordCnt      : INTEGER
DIM bPar(3) : INTEGER
DIM i       : INTEGER
DIM s       : INTEGER
DIM b       : INTEGER
DIM prcd    : INTEGER
DIM repay   : INTEGER

! Bond par values: small=$1000  medium=$5000  large=$10000
RUN initBondPar(bPar)

FOR i := 1 TO ordCnt

  IF ordType(i) = 1 THEN

    ! --- Stock sell (spec Section 11.1 / 11.3) ---------------
    s    := ordId(i)
    prcd := ordQty(i) * mkt.stckPrice(s)

    IF plyr.mgnBal(s) > 0 THEN
      ! Repay company margin from half the sale proceeds.
      RUN calcSaleMgnRpy(plyr.mgnBal(s), prcd, repay)
      plyr.mgnBal(s) := plyr.mgnBal(s) - repay
      plyr.cashBal   := plyr.cashBal + (prcd - repay)
    ELSE
      plyr.cashBal := plyr.cashBal + prcd
    ENDIF

    plyr.stckShrs(s) := plyr.stckShrs(s) - ordQty(i)

  ELSE IF ordType(i) = 2 THEN

    ! --- Bond sell (spec Section 11.2) -----------------------
    ! Bonds redeem at par; no margin consideration.
    b                := ordId(i)
    prcd             := ordQty(i) * bPar(b)
    plyr.cashBal     := plyr.cashBal + prcd
    plyr.bondUnts(b) := plyr.bondUnts(b) - ordQty(i)

  ENDIF \ENDIF

NEXT i

END
