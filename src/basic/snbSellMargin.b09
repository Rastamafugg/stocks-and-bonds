PROCEDURE snbSellMargin
(* ================================================== *)
(* PROCEDURE: snbSellMargin                           *)
(* PURPOSE:   README entry for snbSellMargin module.  *)
(*            Lists all procedures in this module.    *)
(* PARAMS:    None                                    *)
(* ================================================== *)
PRINT "snbSellMargin"
PRINT "  applySells"
PRINT "  commitOrderQty"
PRINT "  promptEditOrderQty"
PRINT "  resolveOrderEditSel"
PRINT "  scrMgnCall"
PRINT "  scrMgnClr"
PRINT "  scrBankrupt"
PRINT "  aiLiqOrdr"
PRINT "  scrForceLiq"
END

PROCEDURE scrMgnCall
(* ============================================================ *)
(* PROCEDURE : scrMgnCall                                       *)
(* PURPOSE   : S20 Margin Call Alert screen.                   *)
(*             Displays the margin call condition for a single *)
(*             stock: player name, stock name, current price,  *)
(*             margin call threshold, and amount due.          *)
(*             Display-only. No player choice at this screen.  *)
(*             Routes unconditionally to S21 (forced           *)
(*             liquidation) after waitKey. The caller is       *)
(*             responsible for routing to scrForceLiq on       *)
(*             return.                                         *)
(*             Triggered when currentPrice <= MarginCallPrice  *)
(*             (spec constant $25) for a margin-held stock.    *)
(* PARAMS    : plyrNam   - player name                         *)
(*             stckNam   - name of stock triggering the call   *)
(*             curPrice  - current price of the stock          *)
(*             callPrice - margin call threshold (spec: $25)   *)
(*             amtDue    - total obligation due immediately    *)
(* SIDE EFX  : Clears screen. Waits for keypress via waitKey.  *)
(* ============================================================ *)
PARAM plyrNam   : STRING[20]
PARAM stckNam   : STRING[14]
PARAM curPrice  : INTEGER
PARAM callPrice : INTEGER
PARAM amtDue    : INTEGER
DIM pStr : STRING[8]

RUN clrScr
PRINT "*** MARGIN CALL ***"
PRINT
PRINT "Player  : "; plyrNam
PRINT "Stock   : "; stckNam
PRINT
RUN fmtMoney(curPrice, pStr)
PRINT "Current price     : $"; pStr
RUN fmtMoney(callPrice, pStr)
PRINT "Margin call at    : $"; pStr
PRINT
RUN fmtMoney(amtDue, pStr)
PRINT "Amount due        : $"; pStr
PRINT
PRINT "You must immediately liquidate assets to meet"
PRINT "this obligation."
PRINT
RUN waitKey

END

PROCEDURE scrBankrupt
(* ============================================================ *)
(* PROCEDURE : scrBankrupt                                      *)
(* PURPOSE   : S22 Bankruptcy Declaration screen.              *)
(*             Sets plyr.isBankrupt := TRUE, then displays     *)
(*             the elimination notice: player name, reason,    *)
(*             year, and final cash balance.                   *)
(*             Returns after waitKey. Caller is responsible    *)
(*             for removing the player from the active turn    *)
(*             order; this procedure only marks the record.   *)
(*             Triggered when forced liquidation cannot        *)
(*             satisfy the outstanding obligation, or when     *)
(*             cashBal remains negative after all assets are   *)
(*             sold (spec Section 12).                         *)
(* PARAMS    : plyr      - player record; isBankrupt set TRUE  *)
(*             finalCash - cash balance at time of elimination *)
(*             reason    - 1=MARGIN_INTEREST 2=MARGIN_CALL     *)
(*             currYear  - game year in which bankruptcy occurs*)
(* SIDE EFX  : Sets plyr.isBankrupt := TRUE.                  *)
(*             Clears screen. Waits for keypress via waitKey.  *)
(* ============================================================ *)
! Line exceeds 79 chars; TYPE statement requires single line.
TYPE PlyrRec = plyrName:STRING[20];plyrType:BYTE;cashBal,obligation:INTEGER;isBankrupt,hadCashPur:BOOLEAN;aiTier:BYTE;stckShrs(9):INTEGER;mgnBal(9):INTEGER;bondUnts(3):INTEGER
PARAM plyr      : PlyrRec
PARAM finalCash : INTEGER
PARAM reason    : BYTE
PARAM currYear  : INTEGER
DIM pStr : STRING[8]

! Mark the player record before display so that if the display
! path errors, the record is already correctly flagged.
plyr.isBankrupt := TRUE

RUN clrScr
PRINT "=== BANKRUPTCY ==="
PRINT "  Player  : "; plyr.plyrName
PRINT "  Year    : "; currYear; " of 10"
PRINT
IF reason = 1 THEN
  PRINT "  Reason  : Margin interest charge"
  PRINT "            Cash balance went negative after annual"
  PRINT "            margin interest was deducted."
ELSE
  PRINT "  Reason  : Margin call"
  PRINT "            Insufficient assets to meet the margin"
  PRINT "            call obligation."
ENDIF
PRINT
RUN fmtMoney(finalCash, pStr)
PRINT "  Final cash : $"; pStr
PRINT
PRINT "  "; plyr.plyrName; " has been eliminated from the game."
PRINT
RUN waitKey

END

PROCEDURE aiLiqOrdr
(* ============================================================ *)
(* PROCEDURE : aiLiqOrdr                                        *)
(* PURPOSE   : Build AI liquidation sell orders to cover an     *)
(*             immediate obligation using currently held assets. *)
(*             Stocks are sold before bonds. Stock quantities    *)
(*             are rounded up to the next multiple of 10.       *)
(*             This procedure does not modify plyr or mkt.      *)
(* PARAMS    : plyr      - player record (read-only)            *)
(*             mkt       - market state (read-only)             *)
(*             oblgRem   - obligation to cover                  *)
(*             ordType   - OUT: 1=STOCK 2=BOND                  *)
(*             ordId     - OUT: asset index per order           *)
(*             ordQty    - OUT: quantity per order              *)
(*             ordCnt    - OUT: number of orders                *)
(* SIDE EFX  : None beyond output PARAM population.             *)
(* ============================================================ *)
! Line exceeds 79 chars; TYPE statement requires single line.
TYPE PlyrRec = plyrName:STRING[20];plyrType:BYTE;cashBal,obligation:INTEGER;isBankrupt,hadCashPur:BOOLEAN;aiTier:BYTE;stckShrs(9):INTEGER;mgnBal(9):INTEGER;bondUnts(3):INTEGER
TYPE MktState = stckPrice(9):INTEGER;divSuspnd(9):BOOLEAN
PARAM plyr        : PlyrRec
PARAM mkt         : MktState
PARAM oblgRem     : INTEGER
PARAM ordType(12) : INTEGER
PARAM ordId(12)   : INTEGER
PARAM ordQty(12)  : INTEGER
PARAM ordCnt      : INTEGER
DIM bPar(3) : INTEGER
DIM needed  : INTEGER
DIM qty     : INTEGER
DIM prcd    : INTEGER
DIM i       : INTEGER
DIM s       : INTEGER
DIM b       : INTEGER

RUN initBondPar(bPar)
RUN clrOrders(ordType, ordId, ordQty, ordCnt)

needed := oblgRem
IF needed < 0 THEN
  needed := 0
ENDIF

FOR s := 1 TO 9
  IF needed > 0 THEN
    IF plyr.stckShrs(s) > 0 AND mkt.stckPrice(s) > 0 THEN
      qty := needed + mkt.stckPrice(s) - 1
      qty := qty / mkt.stckPrice(s)
      qty := ((qty + 9) / 10) * 10
      IF qty > plyr.stckShrs(s) THEN
        qty := plyr.stckShrs(s)
      ENDIF
      IF qty >= 10 AND ordCnt < 12 THEN
        ordCnt          := ordCnt + 1
        ordType(ordCnt) := 1
        ordId(ordCnt)   := s
        ordQty(ordCnt)  := qty
        prcd            := qty * mkt.stckPrice(s)
        needed          := needed - prcd
      ENDIF
    ENDIF
  ENDIF
NEXT s

FOR b := 1 TO 3
  LOOP
    EXITIF needed <= 0 THEN
    ENDEXIT
    EXITIF plyr.bondUnts(b) <= 0 THEN
    ENDEXIT
    EXITIF ordCnt >= 12 THEN
    ENDEXIT
    ordCnt          := ordCnt + 1
    ordType(ordCnt) := 2
    ordId(ordCnt)   := b
    ordQty(ordCnt)  := 1
    needed          := needed - bPar(b)
  ENDLOOP
NEXT b

END

PROCEDURE scrForceLiq
(* ============================================================ *)
(* PROCEDURE : scrForceLiq                                      *)
(* PURPOSE   : S21 Forced Liquidation screen.                  *)
(*             Displays outstanding obligation, current cash,  *)
(*             and all held assets in a persistent keyed       *)
(*             editor. Selecting an asset key edits only that  *)
(*             one pending sell order, then returns to the     *)
(*             main screen. Enter confirms current orders. D   *)
(*             declares bankruptcy.                            *)
(*             Stock qty: mult of 10, <=stckShrs. Bond qty:    *)
(*             positive integer <=bondUnts. Zero/Enter clears  *)
(*             the pending order for that asset.               *)
(*             Does NOT modify plyr or oblgRem; caller handles *)
(*             via applyLiqOrdr.                               *)
(* PARAMS    : plyrNam    - player name for display            *)
(*             oblgRem    - current obligation remaining       *)
(*             plyr       - player record (read-only)          *)
(*             mkt        - market state (read-only)           *)
(*             ordType    - OUT: 1=STOCK 2=BOND per order      *)
(*             ordId      - OUT: asset index per order         *)
(*             ordQty     - OUT: quantity per order            *)
(*             ordCnt     - OUT: number of orders (0..12)      *)
(*             action     - OUT: 1=SUBMIT 2=DECLARE_BANKRUPTCY *)
(* SIDE EFX  : Clears screen. Uses INPUT for order quantities. *)
(* ============================================================ *)
! Line exceeds 79 chars; TYPE statement requires single line.
TYPE PlyrRec = plyrName:STRING[20];plyrType:BYTE;cashBal,obligation:INTEGER;isBankrupt,hadCashPur:BOOLEAN;aiTier:BYTE;stckShrs(9):INTEGER;mgnBal(9):INTEGER;bondUnts(3):INTEGER
TYPE MktState = stckPrice(9):INTEGER;divSuspnd(9):BOOLEAN
PARAM plyrNam     : STRING[20]
PARAM oblgRem     : INTEGER
PARAM plyr        : PlyrRec
PARAM mkt         : MktState
PARAM ordType(12) : INTEGER
PARAM ordId(12)   : INTEGER
PARAM ordQty(12)  : INTEGER
PARAM ordCnt      : INTEGER
PARAM action      : BYTE
DIM sNam(9) : STRING[14]
DIM bPar(3) : INTEGER
DIM i       : INTEGER
DIM s       : INTEGER
DIM b       : INTEGER
DIM qty     : INTEGER
DIM qIn     : STRING[8]
DIM pStr    : STRING[8]
DIM pStr2   : STRING[8]
DIM numOk   : BOOLEAN
DIM keyCode : INTEGER
DIM mapCnt  : INTEGER
DIM mapType(12): INTEGER
DIM mapId(12)  : INTEGER
DIM mapKey(12) : INTEGER
DIM mapQty(12) : INTEGER
DIM stockCnt : INTEGER
DIM bondCnt  : INTEGER
DIM keyLbl   : STRING[1]
DIM slotIdx : INTEGER
DIM slotQty : INTEGER
DIM selIdx  : INTEGER
DIM kIn     : STRING[1]
DIM simCash : INTEGER
DIM simMgn  : INTEGER
DIM simOblg : INTEGER
DIM repay   : INTEGER
DIM prcd    : INTEGER
DIM baseCash : INTEGER
DIM baseMgn  : INTEGER
DIM baseOblg : INTEGER
DIM currMgnTot : INTEGER

ON ERROR GOTO 900

RUN initStockNames(sNam)
RUN initBondPar(bPar)
RUN clrOrders(ordType, ordId, ordQty, ordCnt)

LOOP

  simCash := plyr.cashBal
  RUN calcMgnTot(plyr, currMgnTot)
  simMgn  := currMgnTot
  simOblg := oblgRem
  FOR i := 1 TO ordCnt
    IF ordType(i) = 1 THEN
      prcd := ordQty(i) * mkt.stckPrice(ordId(i))
      simCash := simCash + prcd
    ELSE
      prcd := ordQty(i) * bPar(ordId(i))
      simCash := simCash + prcd
    ENDIF
    simOblg := simOblg - prcd
    IF simOblg < 0 THEN
      simOblg := 0
    ENDIF
  NEXT i

  RUN clrScr
  PRINT "=== FORCED LIQUIDATION ==="
  PRINT "  Player: "; plyrNam
  PRINT
  RUN fmtMoney(plyr.cashBal, pStr)
  RUN fmtMoney(simCash, pStr2)
  PRINT "  Current cash         : $"; pStr; " [$"; pStr2; "]"
  RUN fmtMoney(currMgnTot, pStr)
  PRINT "  Current margin       : $"; pStr
  RUN fmtMoney(oblgRem, pStr)
  RUN fmtMoney(simOblg, pStr2)
  PRINT "  Obligation remaining : $"; pStr; " [$"; pStr2; "]"
  PRINT

  RUN prepAssetMaps(plyr, mkt, 2, ordType, ordId, ordQty, ordCnt, mapType, mapId, mapKey, mapQty, mapCnt, stockCnt, bondCnt)

  PRINT "  STOCKS:";
  IF stockCnt = 1 THEN
    PRINT " press 1"
  ELSE IF stockCnt > 1 THEN
    PRINT " press 1-"; stockCnt
  ELSE
    PRINT
  ENDIF \ENDIF
  FOR i := 1 TO mapCnt
    IF mapType(i) = 1 THEN
      s := mapId(i)
      slotQty := mapQty(i)
      keyLbl := CHR$(mapKey(i))
      ! Line exceeds 79 chars; PRINT USING row format requires single line.
      PRINT USING "'  ',S1<,' ',S12<,I5>,' shrs @ $',I4>", keyLbl, sNam(s), plyr.stckShrs(s), mkt.stckPrice(s);
      IF plyr.mgnBal(s) > 0 THEN
        PRINT " [M]";
      ENDIF
      IF slotQty > 0 THEN
        PRINT "  [Sell "; slotQty; "]";
      ENDIF
      PRINT
    ENDIF
  NEXT i
  PRINT
  PRINT "  BONDS:";
  IF bondCnt = 1 THEN
    PRINT " press A"
  ELSE IF bondCnt > 1 THEN
    PRINT " press A-"; CHR$(ASC("A") + bondCnt - 1)
  ELSE
    PRINT
  ENDIF \ENDIF
  FOR i := 1 TO mapCnt
    IF mapType(i) = 2 THEN
      b := mapId(i)
      slotQty := mapQty(i)
      keyLbl := CHR$(mapKey(i))
      ! Line exceeds 79 chars; PRINT USING row format requires single line.
      PRINT USING "'  ',S1<,' $',I6>,' bond  ',I3>,' unit(s)'", keyLbl, bPar(b), plyr.bondUnts(b);
      IF slotQty > 0 THEN
        PRINT "  [Sell "; slotQty; "]";
      ENDIF
      PRINT
    ENDIF
  NEXT i
  PRINT
  PRINT "  Enter=confirm  D=bankrupt"
  GET #0, kIn
  PRINT

  RUN resolveOrderEditSel(kIn, mapType, mapId, mapKey, mapCnt, ordType, ordId, ordQty, ordCnt, keyCode, selIdx, slotIdx, slotQty)

  IF keyCode = ASC("D") THEN
    action := 2
    ordCnt := 0
    END
  ELSE IF keyCode = 13 THEN
    action := 1
    END
  ELSE
    IF selIdx > 0 THEN
      s := mapId(selIdx)
      b := mapId(selIdx)
      baseCash := plyr.cashBal
      baseMgn  := currMgnTot
      baseOblg := oblgRem
      FOR i := 1 TO ordCnt
        IF i <> slotIdx THEN
          IF ordType(i) = 1 THEN
            prcd := ordQty(i) * mkt.stckPrice(ordId(i))
          ELSE
            prcd := ordQty(i) * bPar(ordId(i))
          ENDIF
          repay := baseOblg
          IF prcd < repay THEN
            repay := prcd
          ENDIF
          baseOblg := baseOblg - repay
          baseCash := baseCash + (prcd - repay)
          IF baseOblg < 0 THEN
            baseOblg := 0
          ENDIF
        ENDIF
      NEXT i
      RUN promptEditOrderQty("=== FORCED LIQUIDATION ===", mapType(selIdx), sNam(s), plyr.stckShrs(s), mkt.stckPrice(s), 3, baseCash, baseOblg, -1, bPar(b), plyr.bondUnts(b), 0, slotIdx, ordQty, qty, keyCode)
      RUN commitOrderQty(ordType, ordId, ordQty, ordCnt, slotIdx, mapType(selIdx), mapId(selIdx), qty)
    ENDIF
  ENDIF \ENDIF

ENDLOOP

action := 1
END

900 PRINT "scrForceLiq error ("; ERR; ")"
END

PROCEDURE scrMgnClr
(* ============================================================ *)
(* PROCEDURE : scrMgnClr                                        *)
(* PURPOSE   : S23 Year 10 Margin Clearance Required screen.   *)
(*             Enforced at the Year 10 boundary for any player *)
(*             with total margin > 0. Uses a persistent keyed  *)
(*             editor for per-asset sells plus M for cash      *)
(*             repayment. Enter confirms pending sells and     *)
(*             repayment.                                      *)
(*             D declares bankruptcy. Caller re-enters this    *)
(*             screen if total margin > 0 after return.        *)
(* PARAMS    : plyr   - player record (modified)               *)
(*             mkt    - market state (read-only)               *)
(*             action - OUT: 1=SUBMIT 2=DECLARE_BANKRUPTCY     *)
(* SIDE EFX  : Clears screen. Uses INPUT.                      *)
(*             Modifies plyr via applyLiqOrdr and repayment.   *)
(* ============================================================ *)
! Line exceeds 79 chars; TYPE statement requires single line.
TYPE PlyrRec = plyrName:STRING[20];plyrType:BYTE;cashBal,obligation:INTEGER;isBankrupt,hadCashPur:BOOLEAN;aiTier:BYTE;stckShrs(9):INTEGER;mgnBal(9):INTEGER;bondUnts(3):INTEGER
TYPE MktState = stckPrice(9):INTEGER;divSuspnd(9):BOOLEAN
PARAM plyr        : PlyrRec
PARAM mkt         : MktState
PARAM action      : BYTE
DIM sNam(9)    : STRING[14]
DIM bPar(3)    : INTEGER
DIM ordType(12): INTEGER
DIM ordId(12)  : INTEGER
DIM ordQty(12) : INTEGER
DIM ordCnt     : INTEGER
DIM oblgRem    : INTEGER
DIM repay      : INTEGER
DIM actualRpy  : INTEGER
DIM maxRpy     : INTEGER
DIM i          : INTEGER
DIM s          : INTEGER
DIM b          : INTEGER
DIM qty        : INTEGER
DIM qIn        : STRING[8]
DIM pStr       : STRING[8]
DIM pStr2      : STRING[8]
DIM valid      : BOOLEAN
DIM numOk      : BOOLEAN
DIM keyCode    : INTEGER
DIM mapCnt     : INTEGER
DIM mapType(12): INTEGER
DIM mapId(12)  : INTEGER
DIM mapKey(12) : INTEGER
DIM mapQty(12) : INTEGER
DIM stockCnt   : INTEGER
DIM bondCnt    : INTEGER
DIM keyLbl     : STRING[1]
DIM j          : INTEGER
DIM slotIdx    : INTEGER
DIM slotQty    : INTEGER
DIM selIdx     : INTEGER
DIM kIn        : STRING[1]
DIM simCash    : INTEGER
DIM simMgn     : INTEGER
DIM prcd       : INTEGER
DIM doneClr    : BOOLEAN
DIM baseCash   : INTEGER
DIM baseMgn    : INTEGER
DIM ordModeVal : INTEGER
DIM currMgnTot : INTEGER
DIM simBal(9)  : INTEGER
DIM baseBal(9) : INTEGER

ON ERROR GOTO 900

RUN initStockNames(sNam)
RUN initBondPar(bPar)
repay  := 0
doneClr := FALSE
RUN clrOrders(ordType, ordId, ordQty, ordCnt)

LOOP

  simCash := plyr.cashBal
  FOR s := 1 TO 9
    simBal(s) := plyr.mgnBal(s)
  NEXT s
  simMgn  := 0
  FOR i := 1 TO ordCnt
    IF ordType(i) = 1 THEN
      prcd := ordQty(i) * mkt.stckPrice(ordId(i))
      RUN calcSaleMgnRpy(simBal(ordId(i)), prcd, actualRpy)
      simBal(ordId(i)) := simBal(ordId(i)) - actualRpy
      simCash := simCash + (prcd - actualRpy)
    ELSE
      prcd := ordQty(i) * bPar(ordId(i))
      simCash := simCash + prcd
    ENDIF
  NEXT i
  FOR s := 1 TO 9
    simMgn := simMgn + simBal(s)
  NEXT s
  actualRpy := repay
  IF actualRpy > simMgn THEN
    actualRpy := simMgn
  ENDIF
  IF actualRpy > simCash THEN
    actualRpy := simCash
  ENDIF
  IF actualRpy < 0 THEN
    actualRpy := 0
  ENDIF
  simCash := simCash - actualRpy
  simMgn  := simMgn - actualRpy
  RUN calcMgnTot(plyr, currMgnTot)

  RUN clrScr
  PRINT "=== YEAR 10 - MARGIN CLEARANCE REQUIRED ==="
  PRINT "  Player: "; plyr.plyrName
  PRINT
  RUN fmtMoney(currMgnTot, pStr)
  RUN fmtMoney(simMgn, pStr2)
  PRINT "  Margin outstanding : $"; pStr; " [$"; pStr2; "]"
  RUN fmtMoney(plyr.cashBal, pStr)
  RUN fmtMoney(simCash, pStr2)
  PRINT "  Current cash       : $"; pStr; " [$"; pStr2; "]"
  PRINT "  All margin must be cleared before the buy phase."
  PRINT

  RUN prepAssetMaps(plyr, mkt, 2, ordType, ordId, ordQty, ordCnt, mapType, mapId, mapKey, mapQty, mapCnt, stockCnt, bondCnt)

  PRINT "  STOCKS:";
  IF stockCnt = 1 THEN
    PRINT " press 1"
  ELSE IF stockCnt > 1 THEN
    PRINT " press 1-"; stockCnt
  ELSE
    PRINT
  ENDIF \ENDIF
  FOR i := 1 TO mapCnt
    IF mapType(i) = 1 THEN
      s := mapId(i)
      slotQty := mapQty(i)
      keyLbl := CHR$(mapKey(i))
      ! Line exceeds 79 chars; PRINT USING row format requires single line.
      PRINT USING "'  ',S1<,' ',S12<,I5>,' shrs @ $',I4>", keyLbl, sNam(s), plyr.stckShrs(s), mkt.stckPrice(s);
      IF plyr.mgnBal(s) > 0 THEN
        PRINT " [M]";
      ENDIF
      IF slotQty > 0 THEN
        PRINT "  [Sell "; slotQty; "]";
      ENDIF
      PRINT
    ENDIF
  NEXT i
  PRINT
  PRINT "  BONDS:";
  IF bondCnt = 1 THEN
    PRINT " press A"
  ELSE IF bondCnt > 1 THEN
    PRINT " press A-"; CHR$(ASC("A") + bondCnt - 1)
  ELSE
    PRINT
  ENDIF \ENDIF
  FOR i := 1 TO mapCnt
    IF mapType(i) = 2 THEN
      b := mapId(i)
      slotQty := mapQty(i)
      keyLbl := CHR$(mapKey(i))
      ! Line exceeds 79 chars; PRINT USING row format requires single line.
      PRINT USING "'  ',S1<,' $',I6>,' bond  ',I3>,' unit(s)'", keyLbl, bPar(b), plyr.bondUnts(b);
      IF slotQty > 0 THEN
        PRINT "  [Sell "; slotQty; "]";
      ENDIF
      PRINT
    ENDIF
  NEXT i
  PRINT
  PRINT "  M=repay with cash  Enter=confirm  D=bankrupt"
  GET #0, kIn
  PRINT
  doneClr := FALSE

  RUN resolveOrderEditSel(kIn, mapType, mapId, mapKey, mapCnt, ordType, ordId, ordQty, ordCnt, keyCode, selIdx, slotIdx, slotQty)

  IF keyCode = ASC("D") THEN
    action := 2
    END
  ELSE IF keyCode = 13 THEN
    action := 1
    doneClr := TRUE
  ELSE IF keyCode = ASC("M") THEN
    maxRpy := currMgnTot
      IF simCash < maxRpy THEN
        maxRpy := simCash
    ENDIF
    IF maxRpy < 0 THEN
      maxRpy := 0
    ENDIF
    IF maxRpy > 0 THEN
      RUN fmtMoney(maxRpy, pStr)
      PRINT "Cash repayment (0.."; pStr; "):"
      valid := FALSE
      WHILE NOT valid DO
        INPUT "  Amount (0/Enter=none): ", qIn
        IF qIn = "" THEN
          repay := 0
          valid := TRUE
        ELSE
          RUN getNumIn(qIn, repay, numOk)
          IF NOT numOk THEN
            PRINT "  Invalid: enter a number."
          ELSE IF repay < 0 THEN
            PRINT "  Invalid: enter 0 or a positive amount."
          ELSE IF repay > maxRpy THEN
            RUN fmtMoney(maxRpy, pStr)
            PRINT "  Invalid: maximum repayment is $"; pStr
          ELSE
            valid := TRUE
          ENDIF \ENDIF \ENDIF
        ENDIF
      ENDWHILE
    ELSE
      PRINT "No cash repayment available."
      RUN waitKey
    ENDIF
  ELSE
    IF selIdx > 0 THEN
      s := mapId(selIdx)
      b := mapId(selIdx)
      baseCash := plyr.cashBal
      FOR j := 1 TO 9
        baseBal(j) := plyr.mgnBal(j)
      NEXT j
      FOR i := 1 TO ordCnt
        IF i <> slotIdx THEN
          IF ordType(i) = 1 THEN
            prcd := ordQty(i) * mkt.stckPrice(ordId(i))
            RUN calcSaleMgnRpy(baseBal(ordId(i)), prcd, actualRpy)
            baseBal(ordId(i)) := baseBal(ordId(i)) - actualRpy
            baseCash := baseCash + (prcd - actualRpy)
          ELSE
            prcd := ordQty(i) * bPar(ordId(i))
            baseCash := baseCash + prcd
          ENDIF
        ENDIF
      NEXT i
      baseMgn := 0
      FOR j := 1 TO 9
        baseMgn := baseMgn + baseBal(j)
      NEXT j
      actualRpy := repay
      IF actualRpy > baseMgn THEN
        actualRpy := baseMgn
      ENDIF
      IF actualRpy > baseCash THEN
        actualRpy := baseCash
      ENDIF
      IF actualRpy < 0 THEN
        actualRpy := 0
      ENDIF
      baseCash := baseCash - actualRpy
      baseMgn  := baseMgn - actualRpy
      ordModeVal := 0
      IF plyr.mgnBal(s) > 0 THEN
        ordModeVal := 2
      ENDIF
      RUN promptEditOrderQty("=== YEAR 10 - MARGIN CLEARANCE REQUIRED ===", mapType(selIdx), sNam(s), plyr.stckShrs(s), mkt.stckPrice(s), ordModeVal, baseCash, baseMgn, baseBal(s), bPar(b), plyr.bondUnts(b), 0, slotIdx, ordQty, qty, keyCode)
      RUN commitOrderQty(ordType, ordId, ordQty, ordCnt, slotIdx, mapType(selIdx), mapId(selIdx), qty)
    ENDIF
  ENDIF \ENDIF \ENDIF

  EXITIF doneClr THEN
  ENDEXIT

ENDLOOP

IF ordCnt > 0 THEN
  RUN applySells(plyr, mkt, ordType, ordId, ordQty, ordCnt)
ENDIF
RUN applyCashMgnRepay(plyr, repay, actualRpy)

action := 1
END

900 PRINT "scrMgnClr error ("; ERR; ")"
END

PROCEDURE commitOrderQty
(* ============================================================ *)
(* PROCEDURE : commitOrderQty                                   *)
(* PURPOSE   : Apply a single edited order quantity into the   *)
(*             order arrays shared by sell/liquidation screens.*)
(*             qty=0 removes the existing slot if present.     *)
(*             qty>0 updates the existing slot or appends a    *)
(*             new order when slotIdx=0.                       *)
(* PARAMS    : ordType   - order asset type array              *)
(*             ordId     - order asset id array                *)
(*             ordQty    - order quantity array                *)
(*             ordCnt    - number of active orders             *)
(*             slotIdx   - existing slot index or 0            *)
(*             assetType - asset type to write                 *)
(*             assetId   - asset id to write                   *)
(*             qty       - edited quantity                     *)
(* SIDE EFX  : Modifies ordType/ordId/ordQty/ordCnt in place.  *)
(* ============================================================ *)
PARAM ordType(12) : INTEGER
PARAM ordId(12)   : INTEGER
PARAM ordQty(12)  : INTEGER
PARAM ordCnt      : INTEGER
PARAM slotIdx     : INTEGER
PARAM assetType   : INTEGER
PARAM assetId     : INTEGER
PARAM qty         : INTEGER

IF qty = 0 THEN
  IF slotIdx > 0 THEN
    RUN dropOrderAt(ordType, ordId, ordQty, ordCnt, slotIdx)
  ENDIF
ELSE
  IF slotIdx = 0 THEN
    ordCnt := ordCnt + 1
    slotIdx := ordCnt
  ENDIF
  ordType(slotIdx) := assetType
  ordId(slotIdx)   := assetId
  ordQty(slotIdx)  := qty
ENDIF

END

PROCEDURE promptEditOrderQty
(* ============================================================ *)
(* PROCEDURE : promptEditOrderQty                               *)
(* PURPOSE   : Preload the current edited quantity and dispatch *)
(*             to the stock or bond quantity editor for        *)
(*             sell/liquidation screens.                       *)
(* PARAMS    : title      - screen title for stock editor      *)
(*             assetType  - 1=stock 2=bond                     *)
(*             stockNm    - stock display name                 *)
(*             stockQty   - shares currently held              *)
(*             stockPrice - current stock price                *)
(*             stockMode  - getLotQty ordMode                  *)
(*             baseCash   - projected cash baseline            *)
(*             baseMgn    - projected margin/obligation base   *)
(*             baseStkMgn - projected stock margin or -1       *)
(*             bondPar    - bond par value                     *)
(*             bondQty    - bond units currently held          *)
(*             bondNav    - promptBondQty allowNav flag        *)
(*             slotIdx    - existing order slot or 0           *)
(*             ordQty     - active order quantity array        *)
(*             qty        - edited quantity out                *)
(*             action     - prompt action/status out           *)
(* SIDE EFX  : Invokes getLotQty or promptBondQty.             *)
(* ============================================================ *)
PARAM title       : STRING
PARAM assetType   : INTEGER
PARAM stockNm     : STRING[14]
PARAM stockQty    : INTEGER
PARAM stockPrice  : INTEGER
PARAM stockMode   : INTEGER
PARAM baseCash    : INTEGER
PARAM baseMgn     : INTEGER
PARAM baseStkMgn  : INTEGER
PARAM bondPar     : INTEGER
PARAM bondQty     : INTEGER
PARAM bondNav     : INTEGER
PARAM slotIdx     : INTEGER
PARAM ordQty(12)  : INTEGER
PARAM qty         : INTEGER
PARAM action      : INTEGER

action := 0
qty := 0
IF slotIdx > 0 THEN
  qty := ordQty(slotIdx)
ENDIF

IF assetType = 1 THEN
  ! Line exceeds 79 chars; getLotQty call requires full arguments.
  RUN getLotQty(title, stockNm, stockQty, stockPrice, qty, stockMode, 0, stockQty, baseCash, baseMgn, baseStkMgn, 0, action)
ELSE
  RUN promptBondQty(bondPar, bondQty, bondNav, qty, action)
ENDIF

END

PROCEDURE resolveOrderEditSel
(* ============================================================ *)
(* PROCEDURE : resolveOrderEditSel                              *)
(* PURPOSE   : Normalize a raw keypress and resolve the        *)
(*             selected asset row plus any existing order slot *)
(*             for sell/liquidation editor screens.            *)
(* PARAMS    : keyIn     - raw keypress string                 *)
(*             mapType   - asset type per visible row          *)
(*             mapId     - asset id per visible row            *)
(*             mapKey    - key code per visible row            *)
(*             mapCnt    - number of visible rows              *)
(*             ordType   - active order type array             *)
(*             ordId     - active order id array               *)
(*             ordQty    - active order quantity array         *)
(*             ordCnt    - number of active orders             *)
(*             keyCode   - normalized uppercase key code       *)
(*             selIdx    - selected visible row, or 0          *)
(*             slotIdx   - matching order slot, or 0           *)
(*             slotQty   - matching order qty, or 0            *)
(* SIDE EFX  : None beyond output PARAM values.                *)
(* ============================================================ *)
PARAM keyIn      : STRING[1]
PARAM mapType(12): INTEGER
PARAM mapId(12)  : INTEGER
PARAM mapKey(12) : INTEGER
PARAM mapCnt     : INTEGER
PARAM ordType(12): INTEGER
PARAM ordId(12)  : INTEGER
PARAM ordQty(12) : INTEGER
PARAM ordCnt     : INTEGER
PARAM keyCode    : INTEGER
PARAM selIdx     : INTEGER
PARAM slotIdx    : INTEGER
PARAM slotQty    : INTEGER

selIdx  := 0
slotIdx := 0
slotQty := 0

IF keyIn <> "" THEN
  keyCode := ASC(keyIn)
  IF keyCode >= ASC("a") AND keyCode <= ASC("z") THEN
    keyCode := keyCode - 32
  ENDIF
ELSE
  keyCode := 0
ENDIF

RUN findMapSel(mapKey, mapCnt, keyCode, selIdx)
IF selIdx > 0 THEN
  RUN findOrderSlot(ordType, ordId, ordQty, ordCnt, mapType(selIdx), mapId(selIdx), slotIdx, slotQty)
ENDIF

END

PROCEDURE applySells
(* ============================================================ *)
(* PROCEDURE : applySells                                       *)
(* PURPOSE   : Apply validated sell orders from scrSell to a   *)
(*             single player record (spec Sections 11.1-11.3). *)
(*             Stock sell: proceeds = qty * currentPrice.      *)
(*             Margin-backed stock: repay 50% of proceeds,     *)
(*             clamped to that company's remaining margin      *)
(*             balance, before crediting cash.                 *)
(*             Bond sell: redeem at par; proceeds = qty * par. *)
(*             ordType: 1=STOCK 2=BOND.                        *)
(*             No-op when ordCnt = 0 (player passed).          *)
(* PARAMS    : plyr     - player record (modified in place)    *)
(*             mkt      - market state; stckPrice(9) read-only *)
(*             ordType  - asset type per order (1=stock 2=bond)*)
(*             ordId    - asset index per order (1-9 / 1-3)    *)
(*             ordQty   - quantity per order                   *)
(*             ordCnt   - number of valid orders (0..12)       *)
(* SIDE EFX  : Modifies plyr.cashBal, plyr.mgnBal,             *)
(*             plyr.stckShrs, plyr.bondUnts.                   *)
(* ============================================================ *)
! Line exceeds 79 chars; TYPE statement requires single line.
TYPE PlyrRec = plyrName:STRING[20];plyrType:BYTE;cashBal,obligation:INTEGER;isBankrupt,hadCashPur:BOOLEAN;aiTier:BYTE;stckShrs(9):INTEGER;mgnBal(9):INTEGER;bondUnts(3):INTEGER
TYPE MktState = stckPrice(9):INTEGER;divSuspnd(9):BOOLEAN
PARAM plyr        : PlyrRec
PARAM mkt         : MktState
PARAM ordType(12) : INTEGER
PARAM ordId(12)   : INTEGER
PARAM ordQty(12)  : INTEGER
PARAM ordCnt      : INTEGER
DIM bPar(3) : INTEGER
DIM i       : INTEGER
DIM s       : INTEGER
DIM b       : INTEGER
DIM prcd    : INTEGER
DIM repay   : INTEGER

! Bond par values: small=$1000  medium=$5000  large=$10000
RUN initBondPar(bPar)

FOR i := 1 TO ordCnt

  IF ordType(i) = 1 THEN

    ! --- Stock sell (spec Section 11.1 / 11.3) ---------------
    s    := ordId(i)
    prcd := ordQty(i) * mkt.stckPrice(s)

    IF plyr.mgnBal(s) > 0 THEN
      ! Repay company margin from half the sale proceeds.
      RUN calcSaleMgnRpy(plyr.mgnBal(s), prcd, repay)
      plyr.mgnBal(s) := plyr.mgnBal(s) - repay
      plyr.cashBal   := plyr.cashBal + (prcd - repay)
    ELSE
      plyr.cashBal := plyr.cashBal + prcd
    ENDIF

    plyr.stckShrs(s) := plyr.stckShrs(s) - ordQty(i)

  ELSE IF ordType(i) = 2 THEN

    ! --- Bond sell (spec Section 11.2) -----------------------
    ! Bonds redeem at par; no margin consideration.
    b                := ordId(i)
    prcd             := ordQty(i) * bPar(b)
    plyr.cashBal     := plyr.cashBal + prcd
    plyr.bondUnts(b) := plyr.bondUnts(b) - ordQty(i)

  ENDIF \ENDIF

NEXT i

END
