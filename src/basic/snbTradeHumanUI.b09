PROCEDURE snbTradeHumanUI
(* ================================================== *)
(* PROCEDURE: snbTradeHumanUI                         *)
(* PURPOSE:   README entry for snbTradeHumanUI module.*)
(*            Lists all procedures in this module.    *)
(* PARAMS:    None                                    *)
(* ================================================== *)
PRINT "snbTradeHumanUI"
PRINT "  getLotQty"
PRINT "  promptBondQty"
PRINT "  clrOrders"
PRINT "  dropOrderAt"
PRINT "  findMapSel"
PRINT "  findOrderSlot"
