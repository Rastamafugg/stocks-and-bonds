END

PROCEDURE getLotQty
(* ================================================== *)
(* PROCEDURE: getLotQty                               *)
(* PURPOSE:   Edit a stock quantity using only the    *)
(*            committed quantity. Up/Down alters the  *)
(*            amount by 10. Enter confirms the        *)
(*            committed quantity.                     *)
(* PARAMS:    title    - editor title line            *)
(*            stockNm  - stock display name           *)
(*            holdQty  - shares currently held        *)
(*            price    - stock price                  *)
(*            qty      - IN/OUT committed quantity    *)
(*            ordMode  - IN/OUT 0=SELL 1=CASH         *)
(*                       2=MARG 3=LIQ                 *)
(*            canMode  - 1 enables C/M mode toggle    *)
(*            maxQty   - maximum allowed quantity     *)
(*            currCash - current cash for live        *)
(*                       projection; <0 disables      *)
(*            currMrgObl - current margin or current  *)
(*                       obligation, per ordMode      *)
(*            currStkMgn - current stock margin for   *)
(*                       display; <0 disables         *)
(*            allowNav - 1 allows S/Q, else no nav    *)
(*            navAct   - OUT 1=confirm 3=save 4=quit  *)
(* EFFECTS:   Clears screen and redraws editor using  *)
(*            ordered PRINT statements.               *)
(* ================================================== *)
TYPE Register = cc,a,b,dp:BYTE; x,y,u:INTEGER
PARAM title    : STRING
PARAM stockNm  : STRING
PARAM holdQty  : INTEGER
PARAM price    : INTEGER
PARAM qty      : INTEGER
PARAM ordMode  : INTEGER
PARAM canMode  : INTEGER
PARAM maxQty   : INTEGER
PARAM currCash : INTEGER
PARAM currMrgObl : INTEGER
PARAM currStkMgn : INTEGER
PARAM allowNav : INTEGER
PARAM navAct   : INTEGER

DIM buf          : STRING[8]
DIM dispTxt      : STRING[48]
DIM infoTxt      : STRING[80]
DIM errTxt       : STRING[48]
DIM maxTxt       : STRING[8]
DIM priceLbl     : STRING[8]
DIM lblCsh       : STRING[8]
DIM lblCshPrj    : STRING[8]
DIM lblMgnObl    : STRING[8]
DIM lblMgnOblPrj : STRING[8]
DIM lblStkMgn    : STRING[8]
DIM lblStkMgnPrj : STRING[8]
DIM kIn          : STRING[1]
DIM lastChr      : STRING[1]
DIM keyCode      : INTEGER
DIM numOk        : BOOLEAN
DIM workQty      : INTEGER
DIM totalQty     : INTEGER
DIM regs         : Register
DIM callCod      : BYTE
DIM iCC          : INTEGER
DIM iBits        : INTEGER
DIM dispQty      : INTEGER
DIM cashNow      : INTEGER
DIM mgnNow       : INTEGER
DIM stkMgnNow    : INTEGER
DIM prjCost      : INTEGER
DIM prjCash      : INTEGER
DIM prjAmt       : INTEGER

ON ERROR GOTO 900

navAct := 1
buf := ""
errTxt := ""

LOOP
  RUN clrScr
  PRINT title
  PRINT
  dispQty := qty
  cashNow := currCash
  mgnNow  := currMrgObl
  stkMgnNow := currStkMgn
  IF dispQty > 0 THEN
    prjCost := dispQty * price
    IF ordMode = 2 AND canMode <> 0 THEN \ ! MARG
      prjCash := prjCost / 2
      cashNow := cashNow - prjCash
      mgnNow  := mgnNow + (prjCost - prjCash)
      IF currStkMgn >= 0 THEN
        stkMgnNow := currStkMgn + (prjCost - prjCash)
      ENDIF
    ELSE IF ordMode = 1 THEN \ ! CASH
      cashNow := currCash - prjCost
    ELSE IF ordMode = 3 THEN \ ! LIQ
      prjAmt := currMrgObl
      IF prjCost < prjAmt THEN
        prjAmt := prjCost
      ENDIF
      mgnNow  := currMrgObl - prjAmt
      cashNow := currCash + (prjCost - prjAmt)
    ELSE IF ordMode = 2 THEN \ ! MARG sell
      prjAmt := 0
      IF currStkMgn >= 0 THEN
        RUN calcSaleMgnRpy(currStkMgn, prjCost, prjAmt)
        stkMgnNow := currStkMgn - prjAmt
      ENDIF
      mgnNow  := currMrgObl - prjAmt
      cashNow := currCash + (prjCost - prjAmt)
    ELSE
      cashNow := currCash + prjCost
    ENDIF \ENDIF \ENDIF \ENDIF
  ENDIF
  RUN fmtMoney(currCash, lblCsh)
  RUN fmtMoney(cashNow, lblCshPrj)
  RUN fmtMoney(currMrgObl, lblMgnObl)
  RUN fmtMoney(mgnNow, lblMgnOblPrj)
  IF currStkMgn >= 0 THEN
    RUN fmtMoney(currStkMgn, lblStkMgn)
    RUN fmtMoney(stkMgnNow, lblStkMgnPrj)
  ENDIF
  PRINT "  Cash: $"; lblCsh; " [$"; lblCshPrj; "]";
  IF ordMode = 3 THEN \ ! LIQ
    PRINT "  Obligation: $"; lblMgnObl; " [$"; lblMgnOblPrj; "]"
  ELSE
    PRINT "  Margin: $"; lblMgnObl; " [$"; lblMgnOblPrj; "]";
    IF currStkMgn >= 0 THEN
      PRINT "  Stock Mgn: $"; lblStkMgn; " [$"; lblStkMgnPrj; "]"
    ELSE
      PRINT
    ENDIF
  ENDIF
  IF ordMode = 3 THEN
    PRINT
  ENDIF
  RUN fmtMoney(price, priceLbl)
  infoTxt := "  " + stockNm + "  " + TRIM$(STR$(holdQty))
  infoTxt := infoTxt + " shrs @ $" + priceLbl
  IF qty > 0 THEN
    IF ordMode = 0 OR ordMode = 3 OR (ordMode = 2 AND canMode = 0) THEN \ ! SELL / LIQ / MARG sell
      infoTxt := infoTxt + "  [Sell " + TRIM$(STR$(qty)) + "]"
    ELSE
      totalQty := holdQty + qty
      IF ordMode = 2 THEN \ ! MARG
        infoTxt := infoTxt + "  + [" + TRIM$(STR$(qty))
        infoTxt := infoTxt + " Shrs M] = " + TRIM$(STR$(totalQty))
      ELSE
        infoTxt := infoTxt + "  + [" + TRIM$(STR$(qty))
        infoTxt := infoTxt + " Shrs C] = " + TRIM$(STR$(totalQty))
      ENDIF
      infoTxt := infoTxt + " Total"
    ENDIF
  ENDIF
  PRINT infoTxt
  PRINT
  PRINT "  Adjust Stock Amount:"
  PRINT
  ! Line exceeds 79 chars; command row is kept on one line for screen layout.
  PRINT "  Enter=Confirm Amount  Up/Down=+/-10"
  IF canMode <> 0 THEN
    PRINT "  C=Pay Cash        M=Pay on Margin"
  ENDIF
  IF allowNav <> 0 THEN
    PRINT "  S=save+exit       Q=quit"
  ENDIF
  PRINT
  dispTxt := "  Qty (Up/Down, 0 clears): " + TRIM$(STR$(qty)) + "   "
  PRINT dispTxt
  IF errTxt <> "" THEN
    PRINT
    PRINT errTxt
  ENDIF

  GET #0, kIn
  IF kIn <> "" THEN
    keyCode := ASC(kIn)
    IF keyCode >= ASC("a") AND keyCode <= ASC("z") THEN
      keyCode := keyCode - 32
      kIn := CHR$(keyCode)
    ENDIF
  ELSE
    keyCode := 0
  ENDIF
  callCod := $8D      \ ! I$GetStt
  regs.a  := 0        \ ! stdin path
  regs.b  := $27      \ ! SS.KySns
  RUN SysCall(callCod, regs)
  iCC := regs.cc
  IF LAND(iCC, 1) <> 0 THEN
    iBits := 0
  ELSE
    iBits := regs.a
  ENDIF

  errTxt := ""
  IF LAND(iBits, $08) <> 0 THEN
    buf := ""
    qty := qty + 10
    IF qty > maxQty THEN
      qty := maxQty
    ENDIF
  ELSE IF LAND(iBits, $10) <> 0 THEN
    buf := ""
    qty := qty - 10
    IF qty < 0 THEN
      qty := 0
    ENDIF
  ELSE IF keyCode = 13 THEN
    END
  ELSE IF allowNav <> 0 AND keyCode = ASC("S") THEN
    navAct := 3
    END
  ELSE IF allowNav <> 0 AND keyCode = ASC("Q") THEN
    navAct := 4
    END
  ELSE IF canMode <> 0 AND keyCode = ASC("C") THEN \ ! CASH
    ordMode := 1 \ ! CASH
    buf := ""
  ELSE IF canMode <> 0 AND keyCode = ASC("M") THEN \ ! MARG
    ordMode := 2 \ ! MARG
    buf := ""
  ENDIF \ENDIF \ENDIF \ENDIF \ENDIF \ENDIF \ENDIF
ENDLOOP

END

900 \ ! Error handler
PRINT "getLotQty error ("; ERR; ")"
END

PROCEDURE clrOrders
(* ================================================== *)
(* PROCEDURE: clrOrders                               *)
(* PURPOSE:   Clear pending order arrays and count.   *)
(* PARAMS:    ordType - order type array              *)
(*            ordId   - order asset-id array          *)
(*            ordQty  - order quantity array          *)
(*            ordCnt  - receives 0                    *)
(* EFFECTS:   Zeroes all 12 order slots.             *)
(* ================================================== *)
PARAM ordType(12) : INTEGER
PARAM ordId(12)   : INTEGER
PARAM ordQty(12)  : INTEGER
PARAM ordCnt      : INTEGER
DIM i             : INTEGER

ordCnt := 0
FOR i := 1 TO 12
  ordType(i) := 0
  ordId(i)   := 0
  ordQty(i)  := 0
NEXT i
END

PROCEDURE findOrderSlot
(* ================================================== *)
(* PROCEDURE: findOrderSlot                           *)
(* PURPOSE:   Find existing pending order slot for    *)
(*            one asset.                              *)
(* PARAMS:    ordType - order type array              *)
(*            ordId   - order asset-id array          *)
(*            ordQty  - order quantity array          *)
(*            ordCnt  - valid order count             *)
(*            wantTyp - desired order type            *)
(*            wantId  - desired asset id              *)
(*            slotIdx - receives 0 or matching slot   *)
(*            slotQty - receives 0 or slot quantity   *)
(* EFFECTS:   None beyond output PARAM assignment.    *)
(* ================================================== *)
PARAM ordType(12) : INTEGER
PARAM ordId(12)   : INTEGER
PARAM ordQty(12)  : INTEGER
PARAM ordCnt      : INTEGER
PARAM wantTyp     : INTEGER
PARAM wantId      : INTEGER
PARAM slotIdx     : INTEGER
PARAM slotQty     : INTEGER
DIM i             : INTEGER

slotIdx := 0
slotQty := 0
FOR i := 1 TO ordCnt
  IF ordType(i) = wantTyp AND ordId(i) = wantId THEN
    slotIdx := i
    slotQty := ordQty(i)
  ENDIF
NEXT i
END

PROCEDURE prepAssetMaps
(* ================================================== *)
(* PROCEDURE: prepAssetMaps                           *)
(* PURPOSE:   Build visible asset maps, counts, and   *)
(*            pending slot quantities for sell-style  *)
(*            editor screens.                         *)
(* PARAMS:    plyr     - player record                *)
(*            mkt      - market state                 *)
(*            mode     - 1=sell 2=margin/liquidation  *)
(*            ordType  - order type array             *)
(*            ordId    - order asset-id array         *)
(*            ordQty   - order quantity array         *)
(*            ordCnt   - valid order count            *)
(*            mapType  - receives asset types         *)
(*            mapId    - receives asset ids           *)
(*            mapKey   - receives key codes           *)
(*            mapQty   - receives pending slot qty    *)
(*            mapCnt   - receives total map count     *)
(*            stockCnt - receives visible stock count *)
(*            bondCnt  - receives visible bond count  *)
(* EFFECTS:   Overwrites map arrays and counters.     *)
(* ================================================== *)
! Line exceeds 79 chars; TYPE statement requires single line.
TYPE PlyrRec = plyrName:STRING[20];plyrType:BYTE;cashBal,obligation:INTEGER;isBankrupt,hadCashPur:BOOLEAN;aiTier:BYTE;stckShrs(9):INTEGER;mgnBal(9):INTEGER;bondUnts(3):INTEGER
TYPE MktState = stckPrice(9):INTEGER;divSuspnd(9):BOOLEAN
PARAM plyr        : PlyrRec
PARAM mkt         : MktState
PARAM mode        : INTEGER
PARAM ordType(12) : INTEGER
PARAM ordId(12)   : INTEGER
PARAM ordQty(12)  : INTEGER
PARAM ordCnt      : INTEGER
PARAM mapType(12) : INTEGER
PARAM mapId(12)   : INTEGER
PARAM mapKey(12)  : INTEGER
PARAM mapQty(12)  : INTEGER
PARAM mapCnt      : INTEGER
PARAM stockCnt    : INTEGER
PARAM bondCnt     : INTEGER
DIM i             : INTEGER
DIM s             : INTEGER
DIM b             : INTEGER
DIM key           : INTEGER
DIM slotIdx       : INTEGER
DIM slotQty       : INTEGER

mapCnt := 0
stockCnt := 0
bondCnt := 0
FOR i := 1 TO 12
  mapType(i) := 0
  mapId(i)   := 0
  mapKey(i)  := 0
  mapQty(i)  := 0
NEXT i

FOR s := 1 TO 9
  IF plyr.stckShrs(s) > 0 THEN
    IF mode <> 1 OR mkt.stckPrice(s) > 0 THEN
      stockCnt := stockCnt + 1
      mapCnt := mapCnt + 1
      mapType(mapCnt) := 1
      mapId(mapCnt)   := s
      mapKey(mapCnt)  := ASC("0") + stockCnt
      RUN findOrderSlot(ordType, ordId, ordQty, ordCnt, 1, s, slotIdx, slotQty)
      mapQty(mapCnt) := slotQty
    ENDIF
  ENDIF
NEXT s

key := 0
FOR b := 1 TO 3
  IF plyr.bondUnts(b) > 0 THEN
    bondCnt := bondCnt + 1
    mapCnt := mapCnt + 1
    mapType(mapCnt) := 2
    mapId(mapCnt)   := b
    IF mode = 1 THEN
      key := key + 1
      mapKey(mapCnt) := ASC("A") + key - 1
    ELSE
      mapKey(mapCnt) := ASC("A") + b - 1
    ENDIF
    RUN findOrderSlot(ordType, ordId, ordQty, ordCnt, 2, b, slotIdx, slotQty)
    mapQty(mapCnt) := slotQty
  ENDIF
NEXT b
END
