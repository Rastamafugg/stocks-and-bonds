PROCEDURE TSTCERTSV
(* ============================================================ *)
(* PROCEDURE : TSTCERTSV                                        *)
(* PURPOSE   : Prototype certificate-state save/load harness.   *)
(*             Writes a separate test file using a candidate    *)
(*             certificate-aware format, reloads it, and        *)
(*             validates that aggregate holdings and margin     *)
(*             totals match the certificate records.            *)
(* PARAMS    : None                                             *)
(* SIDE EFX  : Creates and deletes TSTCERTS. Interactive pauses *)
(*             between result blocks for review.                *)
(* ============================================================ *)
! Line exceeds 79 chars; TYPE statement requires single line.
TYPE ProtoHdr = magic,fmtVersion,maxYears,plyrCount,rollMode,mgnRule,currYear,savedPhase,savedPlyr,gameStage,bnkrFlgs,certCount,checksum:BYTE
! Line exceeds 79 chars; TYPE statement requires single line.
TYPE ProtoPlyr = plyrName:STRING[20];plyrType:BYTE;cashBal,marginTot,obligation:INTEGER;isBankrupt,hadCashPur:BOOLEAN;aiTier:BYTE;stckShrs(9):INTEGER;bondUnts(3):INTEGER
TYPE MktState = stckPrice(9):INTEGER;divSuspnd(9):BOOLEAN
TYPE CertRec = ownerId,stockId,purchTyp:BYTE;sharesQty,purchPrc,marginBal:INTEGER
DIM hdrA        : ProtoHdr
DIM hdrB        : ProtoHdr
DIM deckA(36)   : BYTE
DIM deckB(36)   : BYTE
DIM plyrsA(6)   : ProtoPlyr
DIM plyrsB(6)   : ProtoPlyr
DIM mktA        : MktState
DIM mktB        : MktState
DIM certsA(24)  : CertRec
DIM certsB(24)  : CertRec
DIM loadOK      : BOOLEAN
DIM isOK        : BOOLEAN
DIM opOK        : BOOLEAN
DIM blockOK     : BOOLEAN
DIM failCnt     : INTEGER
DIM msgTxt      : STRING[80]
DIM expCash     : INTEGER
DIM i           : INTEGER

ON ERROR GOTO 900

failCnt := 0
RUN initProtoState(hdrA, deckA, plyrsA, mktA, certsA)

hdrA.magic      := $54
hdrA.fmtVersion := 2
hdrA.maxYears   := 10
hdrA.plyrCount  := 2
hdrA.rollMode   := 1
hdrA.mgnRule    := 1
hdrA.currYear   := 4
hdrA.savedPhase := 2
hdrA.savedPlyr  := 1
hdrA.gameStage  := 2
hdrA.bnkrFlgs   := 0
hdrA.certCount  := 3

FOR i := 1 TO 36
  deckA(i) := i
NEXT i

plyrsA(1).plyrName    := "ALICE"
plyrsA(1).plyrType    := 1
plyrsA(1).cashBal     := 3200
plyrsA(1).marginTot   := 2500
plyrsA(1).hadCashPur  := TRUE
plyrsA(1).stckShrs(1) := 50
plyrsA(1).stckShrs(2) := 10

plyrsA(2).plyrName    := "BETA"
plyrsA(2).plyrType    := 2
plyrsA(2).cashBal     := 5000
plyrsA(2).marginTot   := 3000
plyrsA(2).hadCashPur  := TRUE
plyrsA(2).aiTier      := 2
plyrsA(2).stckShrs(4) := 20

FOR i := 1 TO 9
  mktA.stckPrice(i) := 100
  mktA.divSuspnd(i) := FALSE
NEXT i
mktA.stckPrice(2) := 90
mktA.stckPrice(4) := 25

certsA(1).ownerId   := 1
certsA(1).stockId   := 1
certsA(1).purchTyp  := 2
certsA(1).sharesQty := 50
certsA(1).purchPrc  := 100
certsA(1).marginBal := 2500

certsA(2).ownerId   := 1
certsA(2).stockId   := 2
certsA(2).purchTyp  := 1
certsA(2).sharesQty := 10
certsA(2).purchPrc  := 90
certsA(2).marginBal := 0

certsA(3).ownerId   := 2
certsA(3).stockId   := 4
certsA(3).purchTyp  := 2
certsA(3).sharesQty := 20
certsA(3).purchPrc  := 300
certsA(3).marginBal := 3000

PRINT "=== TSTCERTSV: CERTIFICATE SAVE PROTOTYPE ==="
PRINT
PRINT "Block 1: round-trip save/load with valid certificate data."
RUN protoSave("TSTCERTS", hdrA, deckA, plyrsA, mktA, certsA)
RUN initProtoState(hdrB, deckB, plyrsB, mktB, certsB)
RUN protoLoad("TSTCERTS", hdrB, deckB, plyrsB, mktB, certsB, loadOK)
IF NOT loadOK THEN
  PRINT "  FAIL: load failed."
  failCnt := failCnt + 1
ELSE
  RUN protoValidate(hdrB, plyrsB, certsB, isOK, msgTxt)
  IF NOT isOK THEN
    PRINT "  FAIL: "; msgTxt
    failCnt := failCnt + 1
  ELSE IF hdrB.certCount <> 3 THEN
    PRINT "  FAIL: certCount expected 3, got "; hdrB.certCount
    failCnt := failCnt + 1
  ELSE IF plyrsB(1).marginTot <> 2500 THEN
    PRINT "  FAIL: player 1 marginTot mismatch."
    failCnt := failCnt + 1
  ELSE IF plyrsB(2).stckShrs(4) <> 20 THEN
    PRINT "  FAIL: player 2 stock 4 share count mismatch."
    failCnt := failCnt + 1
  ELSE
    PRINT "  PASS: round-trip load validated."
  ENDIF \ENDIF \ENDIF \ENDIF \ENDIF
PRINT
RUN tWaitKey

PRINT "Block 2: split one margin certificate into two children."
RUN protoLoad("TSTCERTS", hdrB, deckB, plyrsB, mktB, certsB, loadOK)
blockOK := TRUE
IF NOT loadOK THEN
  PRINT "  FAIL: load failed."
  failCnt := failCnt + 1
  blockOK := FALSE
ENDIF
IF blockOK THEN
  opOK := FALSE
  RUN protoSplitCert(hdrB, plyrsB, certsB, 1, opOK, msgTxt)
  IF NOT opOK THEN
    PRINT "  FAIL: "; msgTxt
    failCnt := failCnt + 1
    blockOK := FALSE
  ENDIF
ENDIF
IF blockOK THEN
  RUN protoValidate(hdrB, plyrsB, certsB, isOK, msgTxt)
  IF NOT isOK THEN
    PRINT "  FAIL: "; msgTxt
    failCnt := failCnt + 1
    blockOK := FALSE
  ENDIF
ENDIF
IF blockOK THEN
  IF hdrB.certCount <> 4 THEN
    PRINT "  FAIL: split did not create a fourth certificate."
    failCnt := failCnt + 1
    blockOK := FALSE
  ENDIF
ENDIF
IF blockOK THEN
  IF certsB(1).sharesQty <> 50 OR certsB(4).sharesQty <> 50 THEN
    PRINT "  FAIL: split certificate share counts are wrong."
    failCnt := failCnt + 1
    blockOK := FALSE
  ENDIF
ENDIF
IF blockOK THEN
  IF certsB(1).marginBal <> 1250 OR certsB(4).marginBal <> 1250 THEN
    PRINT "  FAIL: split margin balances are wrong."
    failCnt := failCnt + 1
    blockOK := FALSE
  ENDIF
ENDIF
IF blockOK THEN
  IF plyrsB(1).stckShrs(1) <> 100 OR plyrsB(1).marginTot <> 2500 THEN
    PRINT "  FAIL: player aggregates were not rebuilt after split."
    failCnt := failCnt + 1
    blockOK := FALSE
  ENDIF
ENDIF
IF blockOK THEN
  PRINT "  PASS: split preserved aggregate share and margin state."
ENDIF
PRINT
RUN tWaitKey

PRINT "Block 3: apply a partial sale from one split certificate."
RUN protoLoad("TSTCERTS", hdrB, deckB, plyrsB, mktB, certsB, loadOK)
blockOK := TRUE
IF NOT loadOK THEN
  PRINT "  FAIL: load failed."
  failCnt := failCnt + 1
  blockOK := FALSE
ENDIF
IF blockOK THEN
  opOK := FALSE
  RUN protoSplitCert(hdrB, plyrsB, certsB, 1, opOK, msgTxt)
  IF NOT opOK THEN
    PRINT "  FAIL: "; msgTxt
    failCnt := failCnt + 1
    blockOK := FALSE
  ENDIF
ENDIF
IF blockOK THEN
  expCash := 3200 + (20 * 120) - 500
  opOK := FALSE
  RUN protoSellPart(plyrsB, 2, certsB, hdrB.certCount, 1, 20, 120, opOK, msgTxt)
  IF NOT opOK THEN
    PRINT "  FAIL: "; msgTxt
    failCnt := failCnt + 1
    blockOK := FALSE
  ENDIF
ENDIF
IF blockOK THEN
  RUN protoValidate(hdrB, plyrsB, certsB, isOK, msgTxt)
  IF NOT isOK THEN
    PRINT "  FAIL: "; msgTxt
    failCnt := failCnt + 1
    blockOK := FALSE
  ENDIF
ENDIF
IF blockOK THEN
  IF certsB(1).sharesQty <> 30 OR certsB(1).marginBal <> 750 THEN
    PRINT "  FAIL: partial sale did not reduce certificate 1 correctly."
    failCnt := failCnt + 1
    blockOK := FALSE
  ENDIF
ENDIF
IF blockOK THEN
  IF plyrsB(1).stckShrs(1) <> 80 OR plyrsB(1).marginTot <> 2000 THEN
    PRINT "  FAIL: player aggregates were not rebuilt after partial sale."
    failCnt := failCnt + 1
    blockOK := FALSE
  ENDIF
ENDIF
IF blockOK THEN
  IF plyrsB(1).cashBal <> expCash THEN
    PRINT "  FAIL: cash balance after partial sale is wrong."
    failCnt := failCnt + 1
    blockOK := FALSE
  ENDIF
ENDIF
IF blockOK THEN
  PRINT "  PASS: partial sale updated cash, shares, and margin correctly."
ENDIF
PRINT
RUN tWaitKey

PRINT "Block 4: reject incorrect player margin total."
RUN protoLoad("TSTCERTS", hdrB, deckB, plyrsB, mktB, certsB, loadOK)
plyrsB(1).marginTot := 2400
RUN protoValidate(hdrB, plyrsB, certsB, isOK, msgTxt)
IF isOK THEN
  PRINT "  FAIL: validator accepted bad margin total."
  failCnt := failCnt + 1
ELSE
  PRINT "  PASS: "; msgTxt
ENDIF
PRINT
RUN tWaitKey

PRINT "Block 5: reject aggregate share mismatch."
RUN protoLoad("TSTCERTS", hdrB, deckB, plyrsB, mktB, certsB, loadOK)
plyrsB(2).stckShrs(4) := 10
RUN protoValidate(hdrB, plyrsB, certsB, isOK, msgTxt)
IF isOK THEN
  PRINT "  FAIL: validator accepted bad share aggregate."
  failCnt := failCnt + 1
ELSE
  PRINT "  PASS: "; msgTxt
ENDIF
PRINT
RUN tWaitKey

PRINT "Block 6: reject cash certificate with margin balance."
RUN protoLoad("TSTCERTS", hdrB, deckB, plyrsB, mktB, certsB, loadOK)
certsB(2).marginBal := 100
RUN protoValidate(hdrB, plyrsB, certsB, isOK, msgTxt)
IF isOK THEN
  PRINT "  FAIL: validator accepted invalid cash certificate."
  failCnt := failCnt + 1
ELSE
  PRINT "  PASS: "; msgTxt
ENDIF
PRINT
RUN tWaitKey

DELETE "TSTCERTS"
PRINT "=== TSTCERTSV SUMMARY ==="
PRINT "Failures: "; failCnt
IF failCnt = 0 THEN
  PRINT "TSTCERTSV: PASS"
ELSE
  PRINT "TSTCERTSV: FAIL"
ENDIF
END

900 PRINT "TSTCERTSV error ("; ERR; ")"
PRINT "TSTCERTSV: FAIL"
END

PROCEDURE initProtoState
(* ============================================================ *)
(* PROCEDURE : initProtoState                                   *)
(* PURPOSE   : Initialize all prototype state records and       *)
(*             arrays to zero or FALSE defaults.                *)
(* PARAMS    : hdr      - prototype header                      *)
(*             deckOrd  - prototype deck array                  *)
(*             plyrs    - prototype player array                *)
(*             mkt      - market state                          *)
(*             certs    - certificate slot array                *)
(* SIDE EFX  : Modifies all passed records in place.            *)
(* ============================================================ *)
! Line exceeds 79 chars; TYPE statement requires single line.
TYPE ProtoHdr = magic,fmtVersion,maxYears,plyrCount,rollMode,mgnRule,currYear,savedPhase,savedPlyr,gameStage,bnkrFlgs,certCount,checksum:BYTE
! Line exceeds 79 chars; TYPE statement requires single line.
TYPE ProtoPlyr = plyrName:STRING[20];plyrType:BYTE;cashBal,marginTot,obligation:INTEGER;isBankrupt,hadCashPur:BOOLEAN;aiTier:BYTE;stckShrs(9):INTEGER;bondUnts(3):INTEGER
TYPE MktState = stckPrice(9):INTEGER;divSuspnd(9):BOOLEAN
TYPE CertRec = ownerId,stockId,purchTyp:BYTE;sharesQty,purchPrc,marginBal:INTEGER
PARAM hdr        : ProtoHdr
PARAM deckOrd(36): BYTE
PARAM plyrs(6)   : ProtoPlyr
PARAM mkt        : MktState
PARAM certs(24)  : CertRec
DIM i            : INTEGER
DIM p            : INTEGER
DIM b            : INTEGER

hdr.magic      := 0
hdr.fmtVersion := 0
hdr.maxYears   := 0
hdr.plyrCount  := 0
hdr.rollMode   := 0
hdr.mgnRule    := 0
hdr.currYear   := 0
hdr.savedPhase := 0
hdr.savedPlyr  := 0
hdr.gameStage  := 0
hdr.bnkrFlgs   := 0
hdr.certCount  := 0
hdr.checksum   := 0

FOR i := 1 TO 36
  deckOrd(i) := 0
NEXT i

FOR p := 1 TO 6
  plyrs(p).plyrName   := ""
  plyrs(p).plyrType   := 0
  plyrs(p).cashBal    := 0
  plyrs(p).marginTot  := 0
  plyrs(p).obligation := 0
  plyrs(p).isBankrupt := FALSE
  plyrs(p).hadCashPur := FALSE
  plyrs(p).aiTier     := 0
  FOR i := 1 TO 9
    plyrs(p).stckShrs(i) := 0
  NEXT i
  FOR b := 1 TO 3
    plyrs(p).bondUnts(b) := 0
  NEXT b
NEXT p

FOR i := 1 TO 9
  mkt.stckPrice(i) := 0
  mkt.divSuspnd(i) := FALSE
NEXT i

FOR i := 1 TO 24
  certs(i).ownerId   := 0
  certs(i).stockId   := 0
  certs(i).purchTyp  := 0
  certs(i).sharesQty := 0
  certs(i).purchPrc  := 0
  certs(i).marginBal := 0
NEXT i
END

PROCEDURE protoSave
(* ============================================================ *)
(* PROCEDURE : protoSave                                        *)
(* PURPOSE   : Write the prototype certificate-aware state      *)
(*             file to disk.                                    *)
(* PARAMS    : savePath  - target file name                     *)
(*             hdr       - prototype header; checksum set here  *)
(*             deckOrd   - deck order                           *)
(*             plyrs     - player state                         *)
(*             mkt       - market state                         *)
(*             certs     - certificate slots                    *)
(* SIDE EFX  : Creates or replaces savePath.                    *)
(* ============================================================ *)
! Line exceeds 79 chars; TYPE statement requires single line.
TYPE ProtoHdr = magic,fmtVersion,maxYears,plyrCount,rollMode,mgnRule,currYear,savedPhase,savedPlyr,gameStage,bnkrFlgs,certCount,checksum:BYTE
! Line exceeds 79 chars; TYPE statement requires single line.
TYPE ProtoPlyr = plyrName:STRING[20];plyrType:BYTE;cashBal,marginTot,obligation:INTEGER;isBankrupt,hadCashPur:BOOLEAN;aiTier:BYTE;stckShrs(9):INTEGER;bondUnts(3):INTEGER
TYPE MktState = stckPrice(9):INTEGER;divSuspnd(9):BOOLEAN
TYPE CertRec = ownerId,stockId,purchTyp:BYTE;sharesQty,purchPrc,marginBal:INTEGER
PARAM savePath   : STRING[20]
PARAM hdr        : ProtoHdr
PARAM deckOrd(36): BYTE
PARAM plyrs(6)   : ProtoPlyr
PARAM mkt        : MktState
PARAM certs(24)  : CertRec
DIM path         : BYTE
DIM pathOpen     : BOOLEAN
DIM chkSum       : INTEGER
DIM iMaxYr       : INTEGER
DIM iDeckCnt     : INTEGER
DIM iCertCnt     : INTEGER
DIM i            : INTEGER

ON ERROR GOTO 900

pathOpen := FALSE
chkSum := hdr.magic + hdr.fmtVersion + hdr.maxYears
chkSum := chkSum + hdr.plyrCount + hdr.rollMode
chkSum := chkSum + hdr.mgnRule + hdr.currYear
chkSum := chkSum + hdr.savedPhase + hdr.savedPlyr
chkSum := chkSum + hdr.gameStage + hdr.bnkrFlgs
chkSum := chkSum + hdr.certCount
hdr.checksum := LAND(chkSum, 255)

ON ERROR GOTO 100
DELETE savePath

100 ON ERROR GOTO 900

CREATE #path, savePath:WRITE
pathOpen := TRUE

PUT #path, hdr

iMaxYr := hdr.maxYears
iDeckCnt := iMaxYr + 1
IF iDeckCnt > 36 THEN
  iDeckCnt := 36
ENDIF
FOR i := 1 TO iDeckCnt
  PUT #path, deckOrd(i)
NEXT i

PUT #path, plyrs
PUT #path, mkt

iCertCnt := hdr.certCount
IF iCertCnt > 24 THEN
  iCertCnt := 24
ENDIF
FOR i := 1 TO iCertCnt
  PUT #path, certs(i)
NEXT i

CLOSE #path
pathOpen := FALSE
END

900 IF pathOpen THEN
      CLOSE #path
    ENDIF
    PRINT "protoSave error ("; ERR; ") writing: "; savePath
END

PROCEDURE protoLoad
(* ============================================================ *)
(* PROCEDURE : protoLoad                                        *)
(* PURPOSE   : Read the prototype certificate-aware state       *)
(*             file from disk.                                  *)
(* PARAMS    : savePath  - source file name                     *)
(*             hdr       - receives header                      *)
(*             deckOrd   - receives deck section                *)
(*             plyrs     - receives player state                *)
(*             mkt       - receives market state                *)
(*             certs     - receives certificate slots           *)
(*             loadOK    - TRUE on success                      *)
(* SIDE EFX  : Prints diagnostics on failure.                   *)
(* ============================================================ *)
! Line exceeds 79 chars; TYPE statement requires single line.
TYPE ProtoHdr = magic,fmtVersion,maxYears,plyrCount,rollMode,mgnRule,currYear,savedPhase,savedPlyr,gameStage,bnkrFlgs,certCount,checksum:BYTE
! Line exceeds 79 chars; TYPE statement requires single line.
TYPE ProtoPlyr = plyrName:STRING[20];plyrType:BYTE;cashBal,marginTot,obligation:INTEGER;isBankrupt,hadCashPur:BOOLEAN;aiTier:BYTE;stckShrs(9):INTEGER;bondUnts(3):INTEGER
TYPE MktState = stckPrice(9):INTEGER;divSuspnd(9):BOOLEAN
TYPE CertRec = ownerId,stockId,purchTyp:BYTE;sharesQty,purchPrc,marginBal:INTEGER
PARAM savePath   : STRING[20]
PARAM hdr        : ProtoHdr
PARAM deckOrd(36): BYTE
PARAM plyrs(6)   : ProtoPlyr
PARAM mkt        : MktState
PARAM certs(24)  : CertRec
PARAM loadOK     : BOOLEAN
DIM path         : BYTE
DIM pathOpen     : BOOLEAN
DIM chkExp       : INTEGER
DIM iMaxYr       : INTEGER
DIM iDeckCnt     : INTEGER
DIM iCertCnt     : INTEGER
DIM i            : INTEGER

ON ERROR GOTO 900

pathOpen := FALSE
loadOK := FALSE
RUN initProtoState(hdr, deckOrd, plyrs, mkt, certs)

OPEN #path, savePath:READ
pathOpen := TRUE
GET #path, hdr

IF hdr.magic <> $54 THEN
  PRINT "protoLoad: not a prototype save file: "; savePath
  END
ENDIF
IF hdr.fmtVersion <> 2 THEN
  PRINT "protoLoad: unsupported format version: "; savePath
  END
ENDIF

chkExp := hdr.magic + hdr.fmtVersion + hdr.maxYears
chkExp := chkExp + hdr.plyrCount + hdr.rollMode
chkExp := chkExp + hdr.mgnRule + hdr.currYear
chkExp := chkExp + hdr.savedPhase + hdr.savedPlyr
chkExp := chkExp + hdr.gameStage + hdr.bnkrFlgs
chkExp := chkExp + hdr.certCount
chkExp := LAND(chkExp, 255)
IF chkExp <> hdr.checksum THEN
  PRINT "protoLoad: corrupt header checksum: "; savePath
  END
ENDIF

iMaxYr := hdr.maxYears
iDeckCnt := iMaxYr + 1
IF iDeckCnt > 36 THEN
  iDeckCnt := 36
ENDIF
FOR i := 1 TO iDeckCnt
  GET #path, deckOrd(i)
NEXT i

GET #path, plyrs
GET #path, mkt

iCertCnt := hdr.certCount
IF iCertCnt > 24 THEN
  PRINT "protoLoad: certCount exceeds slot limit."
  END
ENDIF
FOR i := 1 TO iCertCnt
  GET #path, certs(i)
NEXT i

CLOSE #path
pathOpen := FALSE
loadOK := TRUE
END

900 IF pathOpen THEN
      CLOSE #path
    ENDIF
    PRINT "protoLoad error ("; ERR; ") reading: "; savePath
    loadOK := FALSE
END

PROCEDURE protoRebuildAgg
(* ============================================================ *)
(* PROCEDURE : protoRebuildAgg                                  *)
(* PURPOSE   : Recompute player stock aggregates and margin     *)
(*             totals from the active certificate slots.        *)
(* PARAMS    : plyrs - player records updated in place          *)
(*             pCnt  - active player count                      *)
(*             certs - certificate slots                        *)
(*             cCnt  - active certificate count                 *)
(* SIDE EFX  : Rebuilds stckShrs() and marginTot on players.    *)
(* ============================================================ *)
! Line exceeds 79 chars; TYPE statement requires single line.
TYPE ProtoPlyr = plyrName:STRING[20];plyrType:BYTE;cashBal,marginTot,obligation:INTEGER;isBankrupt,hadCashPur:BOOLEAN;aiTier:BYTE;stckShrs(9):INTEGER;bondUnts(3):INTEGER
TYPE CertRec = ownerId,stockId,purchTyp:BYTE;sharesQty,purchPrc,marginBal:INTEGER
PARAM plyrs(6) : ProtoPlyr
PARAM pCnt     : INTEGER
PARAM certs(24): CertRec
PARAM cCnt     : INTEGER
DIM p          : INTEGER
DIM s          : INTEGER
DIM i          : INTEGER
DIM ownVal     : INTEGER
DIM stkVal     : INTEGER

FOR p := 1 TO pCnt
  plyrs(p).marginTot := 0
  FOR s := 1 TO 9
    plyrs(p).stckShrs(s) := 0
  NEXT s
NEXT p

FOR i := 1 TO cCnt
  ownVal := certs(i).ownerId
  stkVal := certs(i).stockId
  IF ownVal >= 1 AND ownVal <= pCnt THEN
    IF stkVal >= 1 AND stkVal <= 9 THEN
      plyrs(ownVal).stckShrs(stkVal) := plyrs(ownVal).stckShrs(stkVal) + certs(i).sharesQty
      plyrs(ownVal).marginTot := plyrs(ownVal).marginTot + certs(i).marginBal
    ENDIF \ENDIF
NEXT i
END

PROCEDURE protoSplitCert
(* ============================================================ *)
(* PROCEDURE : protoSplitCert                                   *)
(* PURPOSE   : Prototype a 2-for-1 split by duplicating one     *)
(*             certificate into a second child certificate and  *)
(*             dividing margin debt across the two children.    *)
(* PARAMS    : hdr    - header; certCount updated in place      *)
(*             plyrs  - player aggregates rebuilt here          *)
(*             certs  - certificate slots modified in place     *)
(*             cIdx   - certificate index to split             *)
(*             didOK  - TRUE on success                         *)
(*             msgTxt - status or error text                    *)
(* SIDE EFX  : Increments certCount by one on success.          *)
(* ============================================================ *)
! Line exceeds 79 chars; TYPE statement requires single line.
TYPE ProtoHdr = magic,fmtVersion,maxYears,plyrCount,rollMode,mgnRule,currYear,savedPhase,savedPlyr,gameStage,bnkrFlgs,certCount,checksum:BYTE
! Line exceeds 79 chars; TYPE statement requires single line.
TYPE ProtoPlyr = plyrName:STRING[20];plyrType:BYTE;cashBal,marginTot,obligation:INTEGER;isBankrupt,hadCashPur:BOOLEAN;aiTier:BYTE;stckShrs(9):INTEGER;bondUnts(3):INTEGER
TYPE CertRec = ownerId,stockId,purchTyp:BYTE;sharesQty,purchPrc,marginBal:INTEGER
PARAM hdr      : ProtoHdr
PARAM plyrs(6) : ProtoPlyr
PARAM certs(24): CertRec
PARAM cIdx     : INTEGER
PARAM didOK    : BOOLEAN
PARAM msgTxt   : STRING[80]
DIM iCertCnt   : INTEGER
DIM newIdx     : INTEGER
DIM oldMgn     : INTEGER
DIM halfMgn    : INTEGER
DIM newPrc     : INTEGER

didOK := FALSE
msgTxt := ""
iCertCnt := hdr.certCount
IF cIdx < 1 OR cIdx > iCertCnt THEN
  msgTxt := "split certificate index out of range"
  END
ENDIF
IF iCertCnt >= 24 THEN
  msgTxt := "no free certificate slot for split"
  END
ENDIF
IF certs(cIdx).sharesQty <= 0 THEN
  msgTxt := "cannot split an empty certificate"
  END
ENDIF
IF MOD(certs(cIdx).sharesQty, 10) <> 0 THEN
  msgTxt := "split source shares must be a multiple of 10"
  END
ENDIF

newIdx := iCertCnt + 1
certs(newIdx).ownerId := certs(cIdx).ownerId
certs(newIdx).stockId := certs(cIdx).stockId
certs(newIdx).purchTyp := certs(cIdx).purchTyp
certs(newIdx).sharesQty := certs(cIdx).sharesQty

newPrc := certs(cIdx).purchPrc / 2
IF MOD(certs(cIdx).purchPrc, 2) <> 0 THEN
  newPrc := newPrc + 1
ENDIF
certs(cIdx).purchPrc := newPrc
certs(newIdx).purchPrc := newPrc

oldMgn := certs(cIdx).marginBal
IF certs(cIdx).purchTyp = 2 THEN
  halfMgn := oldMgn / 2
  certs(cIdx).marginBal := halfMgn
  certs(newIdx).marginBal := oldMgn - halfMgn
ELSE
  certs(cIdx).marginBal := 0
  certs(newIdx).marginBal := 0
ENDIF

hdr.certCount := newIdx
RUN protoRebuildAgg(plyrs, hdr.plyrCount, certs, hdr.certCount)
didOK := TRUE
msgTxt := "split applied"
END

PROCEDURE protoSellPart
(* ============================================================ *)
(* PROCEDURE : protoSellPart                                    *)
(* PURPOSE   : Prototype a partial certificate sale while       *)
(*             repaying proportional margin debt from the same  *)
(*             certificate.                                     *)
(* PARAMS    : plyrs   - player state updated in place          *)
(*             pCnt    - active player count                    *)
(*             certs   - certificate slots updated in place     *)
(*             cCnt    - active certificate count               *)
(*             cIdx    - certificate index to sell from         *)
(*             qtySell - shares to sell; partial only           *)
(*             currPrc - current sale price per share           *)
(*             didOK   - TRUE on success                        *)
(*             msgTxt  - status or error text                   *)
(* SIDE EFX  : Updates cash, share count, and margin balance.   *)
(* ============================================================ *)
! Line exceeds 79 chars; TYPE statement requires single line.
TYPE ProtoPlyr = plyrName:STRING[20];plyrType:BYTE;cashBal,marginTot,obligation:INTEGER;isBankrupt,hadCashPur:BOOLEAN;aiTier:BYTE;stckShrs(9):INTEGER;bondUnts(3):INTEGER
TYPE CertRec = ownerId,stockId,purchTyp:BYTE;sharesQty,purchPrc,marginBal:INTEGER
PARAM plyrs(6) : ProtoPlyr
PARAM pCnt     : INTEGER
PARAM certs(24): CertRec
PARAM cCnt     : INTEGER
PARAM cIdx     : INTEGER
PARAM qtySell  : INTEGER
PARAM currPrc  : INTEGER
PARAM didOK    : BOOLEAN
PARAM msgTxt   : STRING[80]
DIM ownVal     : INTEGER
DIM lotCnt     : INTEGER
DIM sellLots   : INTEGER
DIM repayAmt   : INTEGER
DIM proceeds   : INTEGER

didOK := FALSE
msgTxt := ""
IF cIdx < 1 OR cIdx > cCnt THEN
  msgTxt := "sale certificate index out of range"
  END
ENDIF
IF qtySell <= 0 THEN
  msgTxt := "sale quantity must be positive"
  END
ENDIF
IF MOD(qtySell, 10) <> 0 THEN
  msgTxt := "sale quantity must be a multiple of 10"
  END
ENDIF
IF qtySell >= certs(cIdx).sharesQty THEN
  msgTxt := "prototype partial sale requires qty < certificate shares"
  END
ENDIF
IF currPrc < 0 THEN
  msgTxt := "current price must be non-negative"
  END
ENDIF

ownVal := certs(cIdx).ownerId
IF ownVal < 1 OR ownVal > pCnt THEN
  msgTxt := "sale certificate owner out of range"
  END
ENDIF

proceeds := qtySell * currPrc
repayAmt := 0
IF certs(cIdx).purchTyp = 2 THEN
  lotCnt := certs(cIdx).sharesQty / 10
  sellLots := qtySell / 10
  repayAmt := certs(cIdx).marginBal / lotCnt
  repayAmt := repayAmt * sellLots
ENDIF

plyrs(ownVal).cashBal := plyrs(ownVal).cashBal + proceeds - repayAmt
certs(cIdx).sharesQty := certs(cIdx).sharesQty - qtySell
certs(cIdx).marginBal := certs(cIdx).marginBal - repayAmt
RUN protoRebuildAgg(plyrs, pCnt, certs, cCnt)
didOK := TRUE
msgTxt := "partial sale applied"
END

PROCEDURE protoValidate
(* ============================================================ *)
(* PROCEDURE : protoValidate                                    *)
(* PURPOSE   : Validate the in-memory prototype state against   *)
(*             certificate-aware consistency rules.             *)
(* PARAMS    : hdr      - prototype header                      *)
(*             plyrs    - player state                          *)
(*             certs    - certificate slots                     *)
(*             isOK     - TRUE when all checks pass             *)
(*             msgTxt   - failure message on first defect       *)
(* SIDE EFX  : None.                                            *)
(* ============================================================ *)
! Line exceeds 79 chars; TYPE statement requires single line.
TYPE ProtoHdr = magic,fmtVersion,maxYears,plyrCount,rollMode,mgnRule,currYear,savedPhase,savedPlyr,gameStage,bnkrFlgs,certCount,checksum:BYTE
! Line exceeds 79 chars; TYPE statement requires single line.
TYPE ProtoPlyr = plyrName:STRING[20];plyrType:BYTE;cashBal,marginTot,obligation:INTEGER;isBankrupt,hadCashPur:BOOLEAN;aiTier:BYTE;stckShrs(9):INTEGER;bondUnts(3):INTEGER
TYPE CertRec = ownerId,stockId,purchTyp:BYTE;sharesQty,purchPrc,marginBal:INTEGER
PARAM hdr      : ProtoHdr
PARAM plyrs(6) : ProtoPlyr
PARAM certs(24): CertRec
PARAM isOK     : BOOLEAN
PARAM msgTxt   : STRING[80]
DIM sumShrs(6,9): INTEGER
DIM sumMgn(6)   : INTEGER
DIM i           : INTEGER
DIM p           : INTEGER
DIM s           : INTEGER
DIM iPCnt       : INTEGER
DIM iCertCnt    : INTEGER
DIM ownVal      : INTEGER
DIM stkVal      : INTEGER
DIM typVal      : INTEGER

isOK := FALSE
msgTxt := ""

IF hdr.magic <> $54 THEN
  msgTxt := "invalid header magic"
  END
ENDIF
IF hdr.fmtVersion <> 2 THEN
  msgTxt := "invalid format version"
  END
ENDIF

iPCnt := hdr.plyrCount
iCertCnt := hdr.certCount
IF iPCnt < 1 OR iPCnt > 6 THEN
  msgTxt := "player count out of range"
  END
ENDIF
IF iCertCnt < 0 OR iCertCnt > 24 THEN
  msgTxt := "certificate count out of range"
  END
ENDIF

FOR p := 1 TO 6
  sumMgn(p) := 0
  FOR s := 1 TO 9
    sumShrs(p, s) := 0
  NEXT s
NEXT p

FOR i := 1 TO iCertCnt
  ownVal := certs(i).ownerId
  stkVal := certs(i).stockId
  typVal := certs(i).purchTyp
  IF ownVal < 1 OR ownVal > iPCnt THEN
    msgTxt := "certificate owner out of range"
    END
  ENDIF
  IF stkVal < 1 OR stkVal > 9 THEN
    msgTxt := "certificate stock out of range"
    END
  ENDIF
  IF certs(i).sharesQty <= 0 THEN
    msgTxt := "certificate shares must be positive"
    END
  ENDIF
  IF MOD(certs(i).sharesQty, 10) <> 0 THEN
    msgTxt := "certificate shares must be a multiple of 10"
    END
  ENDIF
  IF typVal <> 1 AND typVal <> 2 THEN
    msgTxt := "certificate purchase type invalid"
    END
  ENDIF
  IF typVal = 1 THEN
    IF certs(i).marginBal <> 0 THEN
      msgTxt := "cash certificate has non-zero margin balance"
      END
    ENDIF
  ELSE
    IF certs(i).marginBal <= 0 THEN
      msgTxt := "margin certificate has non-positive margin"
      END
    ENDIF
  ENDIF
  sumShrs(ownVal, stkVal) := sumShrs(ownVal, stkVal) + certs(i).sharesQty
  sumMgn(ownVal) := sumMgn(ownVal) + certs(i).marginBal
NEXT i

FOR p := 1 TO iPCnt
  IF plyrs(p).marginTot <> sumMgn(p) THEN
    msgTxt := "player margin total does not match certificates"
    END
  ENDIF
  FOR s := 1 TO 9
    IF plyrs(p).stckShrs(s) <> sumShrs(p, s) THEN
      msgTxt := "player share totals do not match certificates"
      END
    ENDIF
  NEXT s
NEXT p

isOK := TRUE
msgTxt := "state valid"
END

PROCEDURE tWaitKey
(* ============================================================ *)
(* PROCEDURE : tWaitKey                                         *)
(* PURPOSE   : Local wait-for-key helper for TSTCERTSV.         *)
(* PARAMS    : None                                             *)
(* SIDE EFX  : Prints prompt and waits for one key.             *)
(* ============================================================ *)
DIM k : STRING[1]

ON ERROR GOTO 900

PRINT "  Press any key to continue...";
GET #0, k
PRINT
END

900 PRINT "tWaitKey error ("; ERR; ")"
END
