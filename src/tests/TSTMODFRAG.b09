PROCEDURE TSTMODFRAG
(* ============================================================ *)
(* PROCEDURE : TSTMODFRAG                                       *)
(* PURPOSE   : Probe module placement and removal under the     *)
(*             current live memory layout using observed-good   *)
(*             setup loads first.                               *)
(*                                                             *)
(*             Revised sequence:                                *)
(*               1. load snbDividend (8168)                     *)
(*               2. load snb (8256)                             *)
(*               3. unlink snbDividend                          *)
(*               4. attempt load snbBuy (8771)                  *)
(*               5. attempt load snbSellDraft (9802)            *)
(*                                                             *)
(*             Size comparisons used by this probe:             *)
(*               freed by unlink snbDividend = 8168             *)
(*               snbBuy needs                = 8771             *)
(*               snbSellDraft needs          = 9802             *)
(*               snbBuy exceeds freed block  = 603              *)
(*               snbSellDraft exceeds it by  = 1634             *)
(*                                                             *)
(*             Therefore, if only the unlinked snbDividend      *)
(*             block is available, both later loads should fail.*)
(*             If either load succeeds, the live module map is  *)
(*             providing a larger contiguous block than this     *)
(*             simple model predicts.                           *)
(* PRE       : SysCall machine-lang module resident.            *)
(*             These four merged modules packed and attr e.     *)
(* NOTE      : F$Mem(0) removed. It reported constant process   *)
(*             data memory and was not useful for this test.    *)
(*             Use mfree and mdir -e outside this harness for   *)
(*             free-block inspection.                           *)
(* ============================================================ *)
DIM modNam       : STRING[20]
DIM errCode      : INTEGER
DIM sizeDiv      : INTEGER
DIM sizeSnb      : INTEGER
DIM sizeBuy      : INTEGER
DIM sizeSell     : INTEGER
DIM gapBuy       : INTEGER
DIM gapSell      : INTEGER
DIM passed       : INTEGER
DIM failed       : INTEGER
DIM testNum      : INTEGER
DIM ok           : BOOLEAN
DIM isRes        : BOOLEAN
DIM hdrDividend  : INTEGER
DIM hdrSnb       : INTEGER
DIM hdrBuy       : INTEGER
DIM hdrSell      : INTEGER

ON ERROR GOTO 900

sizeDiv     := 8168
sizeSnb     := 8256
sizeBuy     := 8771
sizeSell    := 9802
gapBuy      := sizeBuy - sizeDiv
gapSell     := sizeSell - sizeDiv
passed      := 0
failed      := 0
testNum     := 0
hdrDividend := 0
hdrSnb      := 0
hdrBuy      := 0
hdrSell     := 0

PRINT "=== TSTMODFRAG ==="
PRINT
PRINT "Revised sequence:"
PRINT "  load snbDividend"
PRINT "  load snb"
PRINT "  unlink snbDividend"
PRINT "  load snbBuy"
PRINT "  load snbSellDraft"
PRINT
PRINT "Predicted hole after unlink snbDividend = "; sizeDiv
PRINT "snbBuy exceeds that hole by             = "; gapBuy
PRINT "snbSellDraft exceeds it by              = "; gapSell
PRINT
RUN showMfree("Initial memory map before cleanup")
RUN waitKey

PRINT "-- Cleanup baseline --"
modNam := "snbSellDraft"
RUN dropFragModule(modNam, ok, errCode)
modNam := "snbBuy"
RUN dropFragModule(modNam, ok, errCode)
modNam := "snb"
RUN dropFragModule(modNam, ok, errCode)
modNam := "snbDividend"
RUN dropFragModule(modNam, ok, errCode)

testNum := testNum + 1
PRINT "Test "; testNum; ": snbDividend not resident at start"
modNam := "snbDividend"
ok := FALSE
GOSUB 100

testNum := testNum + 1
PRINT "Test "; testNum; ": snb not resident at start"
modNam := "snb"
ok := FALSE
GOSUB 100

testNum := testNum + 1
PRINT "Test "; testNum; ": snbBuy not resident at start"
modNam := "snbBuy"
ok := FALSE
GOSUB 100

testNum := testNum + 1
PRINT "Test "; testNum; ": snbSellDraft not resident at start"
modNam := "snbSellDraft"
ok := FALSE
GOSUB 100
PRINT
RUN showMfree("After cleanup baseline")
RUN waitKey

PRINT "-- Block 1: Load snbDividend --"
testNum := testNum + 1
PRINT "Test "; testNum; ": F$Load snbDividend"
modNam := "snbDividend"
RUN loadFragModule(modNam, hdrDividend, ok, errCode)
IF ok THEN
  PRINT "PASS: snbDividend loaded"
  PRINT "Observed hdrAddr = "; hdrDividend
  passed := passed + 1
ELSE
  PRINT "FAIL: snbDividend load failed err "; errCode
  failed := failed + 1
ENDIF

testNum := testNum + 1
PRINT "Test "; testNum; ": snbDividend resident after load"
modNam := "snbDividend"
ok := TRUE
GOSUB 100
PRINT
RUN showMfree("After loading snbDividend")
RUN waitKey

PRINT "-- Block 2: Load snb --"
testNum := testNum + 1
PRINT "Test "; testNum; ": F$Load snb"
modNam := "snb"
RUN loadFragModule(modNam, hdrSnb, ok, errCode)
IF ok THEN
  PRINT "PASS: snb loaded"
  PRINT "Observed hdrAddr = "; hdrSnb
  passed := passed + 1
ELSE
  PRINT "FAIL: snb load failed err "; errCode
  failed := failed + 1
ENDIF

testNum := testNum + 1
PRINT "Test "; testNum; ": snb resident after load"
modNam := "snb"
ok := TRUE
GOSUB 100
PRINT
RUN showMfree("After loading snb")
RUN waitKey

PRINT "-- Block 3: Unlink snbDividend --"
testNum := testNum + 1
PRINT "Test "; testNum; ": F$UnLink snbDividend by hdrAddr"
RUN unlinkFragModule(hdrDividend, ok, errCode)
IF ok THEN
  PRINT "PASS: snbDividend unlinked"
  hdrDividend := 0
  passed := passed + 1
ELSE
  PRINT "FAIL: snbDividend unlink failed err "; errCode
  failed := failed + 1
ENDIF

testNum := testNum + 1
PRINT "Test "; testNum; ": snbDividend not resident after unlink"
modNam := "snbDividend"
ok := FALSE
GOSUB 100

testNum := testNum + 1
PRINT "Test "; testNum; ": snb still resident after snbDividend unlink"
modNam := "snb"
ok := TRUE
GOSUB 100
PRINT
RUN showMfree("After unlinking snbDividend")
RUN waitKey

PRINT "-- Block 4: Attempt load snbBuy --"
testNum := testNum + 1
PRINT "Test "; testNum; ": F$Load snbBuy after freeing 8168-byte block"
PRINT "Predicted outcome: fail if only that block was freed"
modNam := "snbBuy"
RUN loadFragModule(modNam, hdrBuy, ok, errCode)
IF ok THEN
  PRINT "FAIL: snbBuy loaded unexpectedly"
  PRINT "Observed hdrAddr = "; hdrBuy
  PRINT "Inference: live map provided a larger contiguous"
  PRINT "block than the 8168-byte freed module alone."
  failed := failed + 1
ELSE
  PRINT "PASS: snbBuy load failed as predicted"
  PRINT "Observed err code = "; errCode
  passed := passed + 1
ENDIF

testNum := testNum + 1
PRINT "Test "; testNum; ": snbBuy residency after attempt"
modNam := "snbBuy"
IF hdrBuy <> 0 THEN
  ok := TRUE
ELSE
  ok := FALSE
ENDIF
GOSUB 100
PRINT
RUN showMfree("After snbBuy load attempt")
RUN showMdir("After snbBuy load attempt")
RUN waitKey

PRINT "-- Block 5: Attempt load snbSellDraft --"
testNum := testNum + 1
PRINT "Test "; testNum; ": F$Load snbSellDraft after same unlink"
PRINT "Predicted outcome: fail if only that block was freed"
modNam := "snbSellDraft"
RUN loadFragModule(modNam, hdrSell, ok, errCode)
IF ok THEN
  PRINT "FAIL: snbSellDraft loaded unexpectedly"
  PRINT "Observed hdrAddr = "; hdrSell
  PRINT "Inference: live map provided a larger contiguous"
  PRINT "block than the simple freed-block model predicts."
  failed := failed + 1
ELSE
  PRINT "PASS: snbSellDraft load failed as predicted"
  PRINT "Observed err code = "; errCode
  passed := passed + 1
ENDIF

testNum := testNum + 1
PRINT "Test "; testNum; ": snbSellDraft residency after attempt"
modNam := "snbSellDraft"
IF hdrSell <> 0 THEN
  ok := TRUE
ELSE
  ok := FALSE
ENDIF
GOSUB 100
PRINT
RUN showMfree("After first snbSellDraft load attempt")
RUN showMdir("After first snbSellDraft load attempt")
RUN waitKey

PRINT "-- Block 6: Remove adjacent module and retry --"
testNum := testNum + 1
PRINT "Test "; testNum; ": F$UnLink snb by hdrAddr"
RUN unlinkFragModule(hdrSnb, ok, errCode)
IF ok THEN
  PRINT "PASS: snb unlinked"
  hdrSnb := 0
  passed := passed + 1
ELSE
  PRINT "FAIL: snb unlink failed err "; errCode
  failed := failed + 1
ENDIF

testNum := testNum + 1
PRINT "Test "; testNum; ": snb not resident after unlink"
modNam := "snb"
ok := FALSE
GOSUB 100
PRINT
RUN showMfree("After unlinking snb")
RUN waitKey

testNum := testNum + 1
PRINT "Test "; testNum; ": retry F$Load snbSellDraft after adjacent unlink"
PRINT "Predicted outcome: load should now succeed if the freed"
PRINT "snbDividend and snb regions coalesced into one larger block"
modNam := "snbSellDraft"
RUN loadFragModule(modNam, hdrSell, ok, errCode)
IF ok THEN
  PRINT "PASS: snbSellDraft loaded after adjacent unlink"
  PRINT "Observed hdrAddr = "; hdrSell
  passed := passed + 1
ELSE
  PRINT "FAIL: snbSellDraft still failed err "; errCode
  PRINT "This means the adjacent unlink did not produce a"
  PRINT "large enough contiguous block under the live map."
  failed := failed + 1
ENDIF

testNum := testNum + 1
PRINT "Test "; testNum; ": snbSellDraft resident after retry"
modNam := "snbSellDraft"
IF hdrSell <> 0 THEN
  ok := TRUE
ELSE
  ok := FALSE
ENDIF
GOSUB 100
PRINT
RUN showMfree("After retrying snbSellDraft load")
RUN waitKey

PRINT "-- Cleanup end state --"
IF hdrSell <> 0 THEN
  RUN unlinkFragModule(hdrSell, ok, errCode)
ENDIF
IF hdrBuy <> 0 THEN
  RUN unlinkFragModule(hdrBuy, ok, errCode)
ENDIF
IF hdrSnb <> 0 THEN
  RUN unlinkFragModule(hdrSnb, ok, errCode)
ENDIF
modNam := "snbSellDraft"
RUN dropFragModule(modNam, ok, errCode)
modNam := "snbBuy"
RUN dropFragModule(modNam, ok, errCode)
modNam := "snb"
RUN dropFragModule(modNam, ok, errCode)
modNam := "snbDividend"
RUN dropFragModule(modNam, ok, errCode)

PRINT
PRINT "=== SUMMARY ==="
PRINT "Passed: "; passed
PRINT "Failed: "; failed
PRINT
RUN showMfree("Final memory map after cleanup")
END

100 \ ! GOSUB: compare residency of modNam against ok.
    RUN checkFragModule(modNam, isRes, errCode)
    IF isRes = ok THEN
      IF isRes THEN
        PRINT "PASS: "; modNam; " resident (expected)"
      ELSE
        PRINT "PASS: "; modNam; " not resident (expected)"
      ENDIF
      passed := passed + 1
    ELSE
      IF isRes THEN
        PRINT "FAIL: "; modNam; " resident (unexpected)"
      ELSE
        PRINT "FAIL: "; modNam; " not resident (unexpected)"
      ENDIF
      failed := failed + 1
    ENDIF
    RETURN

900 PRINT "TSTMODFRAG error ("; ERR; ")"
PRINT "Passed: "; passed; "  Failed: "; failed
END

PROCEDURE loadFragModule
(* ============================================================ *)
(* PROCEDURE : loadFragModule                                   *)
(* PURPOSE   : Issue F$Load for the named merged module and     *)
(*             return the header address from regs.u.           *)
(* ============================================================ *)
TYPE Register = cc,a,b,dp:BYTE; x,y,u:INTEGER
PARAM modName : STRING[20]
PARAM hdrAddr : INTEGER
PARAM ok      : BOOLEAN
PARAM errCode : INTEGER
DIM regs      : Register
DIM callCode  : BYTE
DIM nameAddr  : INTEGER
DIM iCC       : INTEGER

ON ERROR GOTO 900

ok       := FALSE
errCode  := 0
hdrAddr  := 0
callCode := $01
nameAddr := ADDR(modName)
regs.a   := 0
regs.x   := nameAddr
RUN SysCall(callCode, regs)
iCC := regs.cc
IF LAND(iCC, 1) = 0 THEN
  hdrAddr := regs.u
  ok := TRUE
ELSE
  errCode := regs.b
ENDIF
END

900 PRINT "loadFragModule error ("; ERR; ")"
END

PROCEDURE unlinkFragModule
(* ============================================================ *)
(* PROCEDURE : unlinkFragModule                                 *)
(* PURPOSE   : Issue F$UnLink by module header address.         *)
(* ============================================================ *)
TYPE Register = cc,a,b,dp:BYTE; x,y,u:INTEGER
PARAM hdrAddr : INTEGER
PARAM ok      : BOOLEAN
PARAM errCode : INTEGER
DIM regs      : Register
DIM callCode  : BYTE
DIM iCC       : INTEGER

ON ERROR GOTO 900

ok      := FALSE
errCode := 0
IF hdrAddr = 0 THEN
  END
ENDIF
callCode := $02
regs.u   := hdrAddr
RUN SysCall(callCode, regs)
iCC := regs.cc
IF LAND(iCC, 1) = 0 THEN
  ok := TRUE
ELSE
  errCode := regs.b
ENDIF
END

900 PRINT "unlinkFragModule error ("; ERR; ")"
END

PROCEDURE dropFragModule
(* ============================================================ *)
(* PROCEDURE : dropFragModule                                   *)
(* PURPOSE   : Best-effort cleanup by linking a module by name  *)
(*             and immediately unlinking it by the returned     *)
(*             header address. A missing module counts as a     *)
(*             successful cleanup state.                        *)
(* ============================================================ *)
PARAM modName : STRING[20]
PARAM ok      : BOOLEAN
PARAM errCode : INTEGER
DIM hdrAddr  : INTEGER

ON ERROR GOTO 900

RUN findFragHdr(modName, hdrAddr, ok, errCode)
IF NOT ok THEN
  ok := TRUE
  errCode := 0
  END
ENDIF
RUN unlinkFragModule(hdrAddr, ok, errCode)
END

900 PRINT "dropFragModule error ("; ERR; ")"
END

PROCEDURE findFragHdr
(* ============================================================ *)
(* PROCEDURE : findFragHdr                                      *)
(* PURPOSE   : Link a module by name and return the header      *)
(*             address. The caller must later F$UnLink using    *)
(*             that header address.                             *)
(* ============================================================ *)
TYPE Register = cc,a,b,dp:BYTE; x,y,u:INTEGER
PARAM modName : STRING[20]
PARAM hdrAddr : INTEGER
PARAM ok      : BOOLEAN
PARAM errCode : INTEGER
DIM regs      : Register
DIM callCode  : BYTE
DIM nameAddr  : INTEGER
DIM iCC       : INTEGER

ON ERROR GOTO 900

ok       := FALSE
errCode  := 0
hdrAddr  := 0
callCode := $00
nameAddr := ADDR(modName)
regs.a   := 0
regs.x   := nameAddr
RUN SysCall(callCode, regs)
iCC := regs.cc
IF LAND(iCC, 1) = 0 THEN
  hdrAddr := regs.u
  ok := TRUE
ELSE
  errCode := regs.b
ENDIF
END

900 PRINT "findFragHdr error ("; ERR; ")"
END

PROCEDURE checkFragModule
(* ============================================================ *)
(* PROCEDURE : checkFragModule                                  *)
(* PURPOSE   : Test module residency with F$Link. If the link   *)
(*             succeeds, immediately F$UnLink to undo the probe *)
(*             link-count increment.                            *)
(* ============================================================ *)
PARAM modName : STRING[20]
PARAM isRes   : BOOLEAN
PARAM errCode : INTEGER
DIM hdrAddr : INTEGER

ON ERROR GOTO 900

RUN findFragHdr(modName, hdrAddr, isRes, errCode)
IF isRes THEN
  RUN unlinkFragModule(hdrAddr, isRes, errCode)
  isRes := TRUE
ENDIF
END

900 PRINT "checkFragModule error ("; ERR; ")"
END

PROCEDURE waitKey
(* ============================================================ *)
(* PROCEDURE : waitKey                                          *)
(* PURPOSE   : Pause between output blocks.                     *)
(* ============================================================ *)
DIM keyIn : STRING[1]

ON ERROR GOTO 900

PRINT "Press any key to continue...";
GET #0, keyIn
PRINT
END

900 PRINT "waitKey error ("; ERR; ")"
END

PROCEDURE showMfree
(* ============================================================ *)
(* PROCEDURE : showMfree                                        *)
(* PURPOSE   : Print a label and run the mfree shell command    *)
(*             for manual free-block inspection.                *)
(* ============================================================ *)
PARAM labelTxt : STRING[48]

ON ERROR GOTO 900

PRINT "-- "; labelTxt; " --"
SHELL "mfree"
PRINT
END

900 PRINT "showMfree error ("; ERR; ")"
END

PROCEDURE showMdir
(* ============================================================ *)
(* PROCEDURE : showMdir                                         *)
(* PURPOSE   : Print a label and run the compact mdir shell     *)
(*             command for manual module-residency inspection.  *)
(* ============================================================ *)
PARAM labelTxt : STRING[48]

ON ERROR GOTO 900

PRINT "-- "; labelTxt; " --"
SHELL "mdir"
PRINT
END

900 PRINT "showMdir error ("; ERR; ")"
END
